# ===========================================
# VARIABLES D'ENVIRONNEMENT - MUSIQUE FACILE
# ===========================================
# Copier ce fichier en .env et remplir les valeurs

# Google Tag Manager
PUBLIC_GTM_ID=GTM-NP758HSC

# Site URL (pour canonical URLs)
PUBLIC_SITE_URL=https://musique-facile.fr

# ===========================================
# BREVO (capture email blog)
# ===========================================
# Utilisé par src/pages/api/subscribe.ts
# Récupérer la clé API : https://app.brevo.com/settings/keys/api
BREVO_API_KEY=xkeysib-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ID de la liste générale (requis). Numérique.
# Dashboard Brevo → Contacts → Listes → clique sur la liste → l'ID est dans l'URL
BREVO_LIST_GENERAL=1

# IDs des listes par instrument (optionnel — fallback sur GENERAL si absent)
# BREVO_LIST_GUITARE=2
# BREVO_LIST_PIANO=3
# BREVO_LIST_UKULELE=4

# Expéditeur des emails transactionnels (utilisé par /api/subscribe et /api/stage-inscription)
# BREVO_SENDER_EMAIL=contact@musique-facile.fr
# BREVO_SENDER_NAME=Fred Fieffé · Musique Facile

# ===========================================
# STAGE D'UKULÉLÉ JUILLET 2026
# ===========================================
# Utilisé par src/pages/api/stage-inscription.ts
# Réutilise BREVO_API_KEY ci-dessus.

# Liste DÉDIÉE au stage (requis) — créer une nouvelle liste "Stage Ukulélé Juillet 2026" dans Brevo
# ⚠️ Ne PAS réutiliser BREVO_LIST_UKULELE ni BREVO_LIST_GENERAL : on isole les prospects stage
# pour ne leur envoyer QUE les emails liés au stage (RGPD + ciblage propre).
BREVO_LIST_STAGE_2026=

# Adresse qui reçoit les notifications d'inscription au stage (défaut: contact@musique-facile.fr)
# STAGE_NOTIFICATION_EMAIL=contact@musique-facile.fr

# ===========================================
# ANCIENS PROVIDERS (non utilisés actuellement)
# ===========================================
# ActiveCampaign
# ACTIVECAMPAIGN_API_KEY=your_api_key_here
# ACTIVECAMPAIGN_URL=https://yourname.api-us1.com

# SendGrid
# SENDGRID_API_KEY=SG.xxxxx
