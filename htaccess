# ========================================
# 1. SÉCURITÉ DE BASE
# ========================================

# Désactiver listing de répertoires
Options -Indexes

# Bloquer TOUS les fichiers cachés (.env, .git, etc.)
<FilesMatch "^\.">
    Require all denied
</FilesMatch>

# ========================================
# 2. BLOQUER MALWARES + PHP
# ========================================

# Bloquer fichiers malveillants spécifiques
<FilesMatch "^(about|radio|admin|content|lock360)\.php$">
    Require all denied
</FilesMatch>

# Bloquer TOUS les fichiers PHP (site 100% statique Astro)
<FilesMatch "\.php$">
    Require all denied
</FilesMatch>

# Bloquer fichiers sensibles (backup, logs, SQL)
<FilesMatch "\.(bak|backup|old|sql|log|env|ini)$">
    Require all denied
</FilesMatch>

# ========================================
# 3. REWRITES & REDIRECTIONS
# ========================================

<IfModule mod_rewrite.c>
    RewriteEngine On

    # Bloquer les dossiers malveillants identifiés
    RewriteRule ^(408809|ae508f52|bf98fb3c|dc26a699)/ - [F,L]

    # Bloquer patterns de dossiers suspects
    RewriteRule ^[0-9]{5,}/ - [F,L]
    RewriteRule ^[a-f0-9]{8}/ - [F,L]

    # Protection contre injection SQL basique
    RewriteCond %{QUERY_STRING} (union|select|insert|drop|delete|update|cast|declare|exec) [NC,OR]
    RewriteCond %{QUERY_STRING} (base64_encode|base64_decode|eval) [NC]
    RewriteRule ^(.*)$ - [F,L]

    # Bloquer tentatives WordPress (tu n'en as plus)
    RewriteCond %{REQUEST_URI} (wp-login|xmlrpc|wp-admin) [NC]
    RewriteRule ^(.*)$ - [F,L]

    # Force HTTPS
    RewriteCond %{HTTPS} off
    RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

    # Force non-www (change en www si tu préfères)
    RewriteCond %{HTTP_HOST} ^www\.(.*)$ [NC]
    RewriteRule ^(.*)$ https://%1%{REQUEST_URI} [L,R=301]

    # Supprimer le paramètre ?i= (spam SEO - 1869 URLs parasites détectées)
    RewriteCond %{QUERY_STRING} (^|&)i= [NC]
    RewriteRule ^(.*)$ /$1? [R=301,L]

    # ---- Redirections anciennes URLs WordPress ----
