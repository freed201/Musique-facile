# ========================================
# 4. HEADERS DE SÉCURITÉ (OWASP)
# ========================================

<IfModule mod_headers.c>
    # Protection XSS (Cross-Site Scripting)
    Header set X-XSS-Protection "1; mode=block"

    # Empêcher le MIME sniffing
    Header set X-Content-Type-Options "nosniff"

    # Protection Clickjacking
    Header set X-Frame-Options "SAMEORIGIN"

    # Politique de référent stricte
    Header set Referrer-Policy "strict-origin-when-cross-origin"

    # HSTS - Force HTTPS pendant 1 an
    Header set Strict-Transport-Security "max-age=31536000; includeSubDomains"

    # Content Security Policy (CSP) - Adapté pour Astro + Vimeo
    Header set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net https://player.vimeo.com https://*.googletagmanager.com https://*.google-analytics.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: https:; media-src 'self' https://player.vimeo.com https://*.vimeocdn.com; frame-src 'self' https://player.vimeo.com https://www.youtube.com; connect-src 'self' https://*.google-analytics.com; object-src 'none'; base-uri 'self'; form-action 'self'; upgrade-insecure-requests;"

    # Permissions Policy (contrôle des APIs navigateur)
    Header set Permissions-Policy "geolocation=(), microphone=(), camera=(), payment=(), usb=(), magnetometer=(), gyroscope=()"

    # Cacher les infos du serveur
    Header unset Server
    Header unset X-Powered-By
</IfModule>

# ========================================
# 5. COMPRESSION GZIP (PERFORMANCE)
# ========================================

<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html
    AddOutputFilterByType DEFLATE text/css
    AddOutputFilterByType DEFLATE text/javascript
    AddOutputFilterByType DEFLATE application/javascript
    AddOutputFilterByType DEFLATE application/json
    AddOutputFilterByType DEFLATE text/xml
    AddOutputFilterByType DEFLATE application/xml
</IfModule>

# ========================================
# 6. CACHE NAVIGATEUR (PERFORMANCE)
# ========================================

<IfModule mod_expires.c>
    ExpiresActive On

    # HTML - pas de cache
    ExpiresByType text/html "access plus 0 seconds"

    # CSS/JS - 1 an (Astro fait du hash de fichiers)
    ExpiresByType text/css "access plus 1 year"
    ExpiresByType application/javascript "access plus 1 year"
    ExpiresByType text/javascript "access plus 1 year"

    # Images - 1 an
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/jpg "access plus 1 year"
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType image/gif "access plus 1 year"
    ExpiresByType image/webp "access plus 1 year"
    ExpiresByType image/svg+xml "access plus 1 year"
    ExpiresByType image/x-icon "access plus 1 year"

    # Fonts - 1 an
    ExpiresByType font/woff "access plus 1 year"
    ExpiresByType font/woff2 "access plus 1 year"

    # Autres
    ExpiresByType application/pdf "access plus 1 month"
    ExpiresByType application/json "access plus 0 seconds"
</IfModule>

