---
/**
 * Ressources Externes Optimisées
 * - Les fonts sont maintenant chargées localement via @fontsource (pas de blocage externe)
 * - Scripts vidéo chargés uniquement sur les pages qui en ont besoin
 * - Preconnect aux domaines externes pour réduire la latence
 */

interface Props {
  loadVideoScripts?: boolean;
}

const { loadVideoScripts = false } = Astro.props;

const videoScripts = [
  {
    url: "https://player.vimeo.com/api/player.js",
    defer: true
  },
  {
    url: "https://www.youtube.com/iframe_api",
    defer: true
  }
];

// Preconnect au GTM (toujours nécessaire)
const preconnectDomains = [
  'https://www.googletagmanager.com'
];

// Preconnect vidéo seulement si nécessaire
const videoPreconnectDomains = [
  'https://www.youtube.com',
  'https://player.vimeo.com'
];
---

<!-- Preconnect pour améliorer les temps de chargement des ressources externes -->
{preconnectDomains.map(domain => (
  <>
    <link rel="preconnect" href={domain} />
    <link rel="dns-prefetch" href={domain} />
  </>
))}

{loadVideoScripts && videoPreconnectDomains.map(domain => (
  <>
    <link rel="preconnect" href={domain} />
    <link rel="dns-prefetch" href={domain} />
  </>
))}

<!-- Scripts vidéo chargés seulement sur les pages avec vidéos -->
{loadVideoScripts && videoScripts.map(resource => (
  <script
    src={resource.url}
    defer={resource.defer}
    crossorigin="anonymous"
  ></script>
))}
