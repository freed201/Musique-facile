---
/**
 * ParallaxDecor.astro
 * Elements decoratifs SVG flottants positionnes entre les sections
 * Se deplacent en parallax au scroll (gere par ParallaxManager)
 * Masques sur mobile et avec prefers-reduced-motion
 */

interface Props {
  /** Variante de placement : 'left', 'right', 'scattered' */
  variant?: 'left' | 'right' | 'scattered';
}

const { variant = 'scattered' } = Astro.props;
---

<div class={`parallax-decor-group decor-${variant}`} aria-hidden="true">
  {variant === 'left' && (
    <>
      <svg class="parallax-decor decor-note" data-parallax-decor data-parallax-speed="0.06" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
        <path d="M9 18V5l12-2v13"/>
        <circle cx="6" cy="18" r="3"/>
        <circle cx="18" cy="16" r="3"/>
      </svg>
      <svg class="parallax-decor decor-wave" data-parallax-decor data-parallax-speed="0.04" width="48" height="24" viewBox="0 0 48 24" fill="none" stroke="currentColor" stroke-width="1">
        <path d="M0 12 C8 4, 16 20, 24 12 S40 4, 48 12"/>
      </svg>
    </>
  )}
  {variant === 'right' && (
    <>
      <svg class="parallax-decor decor-treble" data-parallax-decor data-parallax-speed="0.07" width="28" height="42" viewBox="0 0 24 36" fill="currentColor" opacity="0.5">
        <text x="0" y="28" font-size="28" font-family="serif">&#119070;</text>
      </svg>
      <div class="parallax-decor decor-ring" data-parallax-decor data-parallax-speed="0.05"></div>
    </>
  )}
  {variant === 'scattered' && (
    <>
      <svg class="parallax-decor decor-note-s1" data-parallax-decor data-parallax-speed="0.05" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
        <path d="M9 18V5l12-2v13"/>
        <circle cx="6" cy="18" r="3"/>
        <circle cx="18" cy="16" r="3"/>
      </svg>
      <div class="parallax-decor decor-dot-s1" data-parallax-decor data-parallax-speed="0.08"></div>
      <div class="parallax-decor decor-dot-s2" data-parallax-decor data-parallax-speed="0.04"></div>
    </>
  )}
</div>

<style>
  .parallax-decor-group {
    position: relative;
    height: 0;
    overflow: visible;
    pointer-events: none;
    z-index: 0;
  }

  .parallax-decor {
    position: absolute;
    pointer-events: none;
    opacity: 0.06;
    color: var(--brand-400, #a78bfa);
  }

  /* Variante left */
  .decor-left .decor-note {
    left: 3%;
    top: -40px;
  }

  .decor-left .decor-wave {
    left: 8%;
    top: 20px;
    opacity: 0.04;
  }

  /* Variante right */
  .decor-right .decor-treble {
    right: 5%;
    top: -30px;
  }

  .decor-right .decor-ring {
    right: 10%;
    top: 10px;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    border: 1px solid var(--brand-400, #a78bfa);
    opacity: 0.08;
  }

  /* Variante scattered */
  .decor-scattered .decor-note-s1 {
    left: 5%;
    top: -20px;
  }

  .decor-scattered .decor-dot-s1 {
    right: 8%;
    top: -10px;
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background: var(--brand-400, #a78bfa);
    opacity: 0.06;
  }

  .decor-scattered .decor-dot-s2 {
    left: 15%;
    top: 30px;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--brand-400, #a78bfa);
    opacity: 0.04;
  }

  /* Mobile: masquer */
  @media (max-width: 767px) {
    .parallax-decor-group {
      display: none;
    }
  }

  /* Reduced motion */
  @media (prefers-reduced-motion: reduce) {
    .parallax-decor {
      transform: none !important;
    }
  }
</style>
