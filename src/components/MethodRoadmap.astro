---
/**
 * MethodRoadmap.astro
 * Section "Methode" — roadmap en 4 etapes montrant le parcours eleve.
 * Timeline verticale avec animation stagger au scroll.
 */

interface Step {
  number: number;
  title: string;
  description: string;
  icon: string;
}

interface Props {
  title?: string;
  subtitle?: string;
  steps?: Step[];
  ctaText?: string;
  ctaUrl?: string;
}

const defaultSteps: Step[] = [
  {
    number: 1,
    title: "Choisissez votre instrument",
    description: "Guitare, piano, ukulélé ou solfège : chaque parcours est conçu pour les débutants complets.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>`
  },
  {
    number: 2,
    title: "Suivez le parcours progressif",
    description: "Des vidéos HD pas à pas, organisées du plus simple au plus avancé. Vous jouez dès la première leçon.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>`
  },
  {
    number: 3,
    title: "Pratiquez à votre rythme (15 min/jour)",
    description: "Pas besoin de bloquer des heures. 15 minutes par jour suffisent pour progresser concrètement.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22c5.523 0 10-4.477 10-10S17.523 2 12 2 2 6.477 2 12s4.477 10 10 10z"/><path d="M12 6v6l4 2"/></svg>`
  },
  {
    number: 4,
    title: "Jouez vos morceaux dès la semaine 1",
    description: "92% de nos élèves jouent leur première chanson en 5 jours. Vous serez le prochain.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18V5l12-2v13"/><circle cx="6" cy="18" r="3"/><circle cx="18" cy="16" r="3"/></svg>`
  }
];

const {
  title = "La méthode qui a formé 80 000 élèves",
  subtitle = "Un parcours simple, structuré et prouvé — en 4 étapes.",
  steps = defaultSteps,
  ctaText = "Je commence maintenant",
  ctaUrl = "/cours"
} = Astro.props;
---

<section class="method-section" aria-label="Notre méthode en 4 étapes" data-animate="reveal">
  <div class="method-container">
    <div class="method-header">
      <h2 class="method-title">{title}</h2>
      <p class="method-subtitle">{subtitle}</p>
    </div>

    <div class="timeline" data-stagger-group=".timeline-step">
      {steps.map((step, index) => (
        <div class="timeline-step" style={`--step-delay: ${index * 150}ms`}>
          <div class="timeline-marker">
            <div class="marker-circle">
              <span class="marker-number">{step.number}</span>
            </div>
            {index < steps.length - 1 && <div class="marker-line" />}
          </div>

          <div class="timeline-content">
            <div class="step-icon" set:html={step.icon} />
            <h3 class="step-title">{step.title}</h3>
            <p class="step-description">{step.description}</p>
          </div>
        </div>
      ))}
    </div>

    <div class="method-cta">
      <a href={ctaUrl} class="method-btn">
        {ctaText}
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
          <path d="M4 10h12m0 0l-4-4m4 4l-4 4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    </div>
  </div>
</section>

<style>
  .method-section {
    padding: var(--space-20) var(--space-4);
    background: var(--bg-alt);
  }

  .method-container {
    max-width: 800px;
    margin: 0 auto;
  }

  .method-header {
    text-align: center;
    margin-bottom: var(--space-16);
  }

  .method-title {
    font-family: var(--font-heading);
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: var(--font-bold);
    color: var(--text-primary);
    margin-bottom: var(--space-4);
  }

  .method-subtitle {
    font-size: var(--text-lg);
    color: var(--text-secondary);
    max-width: 500px;
    margin: 0 auto;
    line-height: var(--leading-relaxed);
  }

  /* Timeline */
  .timeline {
    display: flex;
    flex-direction: column;
    gap: 0;
    position: relative;
  }

  .timeline-step {
    display: flex;
    gap: var(--space-6);
    position: relative;
  }

  /* Marker (cercle + ligne) */
  .timeline-marker {
    display: flex;
    flex-direction: column;
    align-items: center;
    flex-shrink: 0;
  }

  .marker-circle {
    width: 48px;
    height: 48px;
    border-radius: var(--radius-full);
    background: var(--brand-500);
    color: white;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-heading);
    font-weight: var(--font-bold);
    font-size: var(--text-lg);
    flex-shrink: 0;
    position: relative;
    z-index: 1;
    box-shadow: var(--shadow-brand);
  }

  .marker-line {
    width: 3px;
    flex-grow: 1;
    min-height: 40px;
    background: linear-gradient(to bottom, var(--brand-300), var(--brand-100));
    border-radius: 2px;
  }

  /* Content */
  .timeline-content {
    padding-bottom: var(--space-10);
    padding-top: var(--space-1);
  }

  .step-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    background: var(--brand-50);
    color: var(--brand-500);
    border-radius: var(--radius-lg);
    margin-bottom: var(--space-3);
  }

  .step-title {
    font-family: var(--font-heading);
    font-size: var(--text-xl);
    font-weight: var(--font-semibold);
    color: var(--text-primary);
    margin-bottom: var(--space-2);
  }

  .step-description {
    font-size: var(--text-base);
    color: var(--text-secondary);
    line-height: var(--leading-relaxed);
    margin: 0;
    max-width: 500px;
  }

  /* CTA */
  .method-cta {
    text-align: center;
    margin-top: var(--space-8);
  }

  .method-btn {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-4) var(--space-8);
    background: var(--brand-500);
    color: white;
    font-family: var(--font-heading);
    font-size: var(--text-lg);
    font-weight: var(--font-semibold);
    text-decoration: none;
    border-radius: var(--radius-lg);
    transition: all 0.3s ease;
    box-shadow: var(--shadow-brand);
  }

  .method-btn:hover {
    background: var(--brand-600);
    transform: translateY(-2px);
    box-shadow: 0 12px 24px rgba(108, 63, 160, 0.35);
  }

  /* Desktop : horizontal layout option */
  @media (min-width: 768px) {
    .method-container {
      max-width: 900px;
    }

    .timeline-content {
      padding-bottom: var(--space-12);
    }
  }

  /* Dark mode — system */
  @media (prefers-color-scheme: dark) {
    .method-section {
      background: #0f172a;
    }

    .step-icon {
      background: rgba(108, 63, 160, 0.2);
    }

    .marker-line {
      background: linear-gradient(to bottom, rgba(108, 63, 160, 0.4), rgba(108, 63, 160, 0.1));
    }
  }

  /* Dark mode — manual toggle */
  :global([data-theme="dark"]) .method-section {
    background: #0f172a;
  }

  :global([data-theme="dark"]) .step-icon {
    background: rgba(108, 63, 160, 0.2);
  }

  :global([data-theme="dark"]) .marker-line {
    background: linear-gradient(to bottom, rgba(108, 63, 160, 0.4), rgba(108, 63, 160, 0.1));
  }
</style>
