---
/**
 * InlineOptIn.astro — Capture email contextuelle à insérer dans un article.
 * Minimal : 1 champ email + 1 case consentement + 1 bouton (max conversion).
 * Le pitch et le thème s'adaptent à l'instrument de l'article.
 *
 * Le formulaire POST vers /api/subscribe (endpoint serverless Vercel).
 * En cas de succès, affiche un état "success" remplaçant le form.
 */
interface Props {
  instrument?: 'guitare' | 'piano' | 'ukulele' | 'solfege' | 'général';
  source?: string;
  leadMagnet?: string;
}

const { instrument = 'général', source, leadMagnet } = Astro.props;

// Mode lead magnet (guide PDF gratuit) ou newsletter générique selon présence du prop leadMagnet
const mode = leadMagnet ? 'leadMagnet' : 'newsletter';

const pitchMap: Record<string, {
  newsletter: { hook: string; promise: string };
  leadMagnet: { hook: string; promise: string };
  theme: string;
}> = {
  guitare: {
    newsletter: {
      hook: 'Reçois nos meilleurs conseils guitare par email',
      promise: '1 email par semaine : un riff à apprendre, un conseil de pro, des morceaux à jouer. Zéro spam.',
    },
    leadMagnet: {
      hook: 'Joue 100 chansons avec 5 accords — guide gratuit',
      promise: 'Reçois le PDF "Les 5 Accords Magiques" dans ta boîte mail. Diagrammes, rythmique universelle, 100 morceaux à essayer ce soir.',
    },
    theme: 'guitar',
  },
  piano: {
    newsletter: {
      hook: 'Reçois nos meilleurs conseils piano par email',
      promise: '1 email par semaine : un exercice utile, un morceau accessible, une astuce qui débloque. Zéro spam.',
    },
    leadMagnet: {
      hook: 'Lis les notes au piano sans bloquer — guide gratuit',
      promise: 'Reçois le PDF "Lire les notes au piano — 5 astuces" dans ta boîte mail. Notes repères, super portée, lecture par tierces.',
    },
    theme: 'piano',
  },
  ukulele: {
    newsletter: {
      hook: 'Reçois nos meilleurs conseils ukulélé par email',
      promise: '1 email par semaine : une chanson facile, une rythmique, un truc qui fait progresser. Zéro spam.',
    },
    leadMagnet: {
      hook: 'Joue à l\'ukulélé avec 4 accords — guide gratuit',
      promise: 'Reçois le PDF "Les 4 Accords du Ukulélé" dans ta boîte mail. Diagrammes, rythmiques, chansons à jouer dès ce soir.',
    },
    theme: 'ukulele',
  },
  solfege: {
    newsletter: {
      hook: 'Le solfège sans prise de tête, par email',
      promise: '1 email par semaine pour comprendre la musique pas à pas, avec des exemples concrets. Zéro spam.',
    },
    leadMagnet: {
      hook: 'Le solfège, enfin clair — guide gratuit',
      promise: 'Reçois nos meilleurs guides pour apprendre la musique sans solfège abstrait. Zéro spam.',
    },
    theme: 'solfege',
  },
  'général': {
    newsletter: {
      hook: 'Reçois nos meilleurs conseils musique par email',
      promise: '1 email par semaine : conseils, morceaux, exercices. Adapté à ton instrument. Zéro spam.',
    },
    leadMagnet: {
      hook: 'Reçois ton guide musique gratuit',
      promise: 'Le PDF arrive dans ta boîte mail dans 2 minutes. Pas de spam, désinscription en 1 clic.',
    },
    theme: 'main',
  },
};

const entry = pitchMap[instrument] ?? pitchMap['général'];
const data = { ...entry[mode], theme: entry.theme };
const submitLabel = mode === 'leadMagnet' ? 'Je télécharge le guide' : 'Je m\'inscris';

// ID unique pour éviter les collisions si plusieurs occurrences sur la page
const formId = `inline-optin-${Math.random().toString(36).slice(2, 9)}`;
---

<aside
  class={`inline-optin theme-optin-${data.theme}`}
  data-inline-optin
  role="complementary"
  aria-label="Inscription newsletter"
  data-nosnippet
>
  <span class="optin__tag">Newsletter</span>
  <form
    id={formId}
    class="optin__form"
    data-instrument={instrument}
    data-source={source ?? ''}
    data-lead-magnet={leadMagnet ?? ''}
    novalidate
  >
    <div class="optin__head">
      <h3 class="optin__hook">{data.hook}</h3>
      <p class="optin__promise">{data.promise}</p>
    </div>

    <div class="optin__row">
      <label class="visually-hidden" for={`${formId}-email`}>Adresse email</label>
      <input
        type="email"
        id={`${formId}-email`}
        name="email"
        class="optin__email"
        placeholder="ton@email.com"
        autocomplete="email"
        required
      />
      <button type="submit" class="optin__submit">
        <span class="optin__submit-label">{submitLabel}</span>
        <span class="optin__submit-arrow" aria-hidden="true">→</span>
      </button>
    </div>

    <div class="optin__consent">
      <input type="checkbox" id={`${formId}-consent`} name="consent" required />
      <label for={`${formId}-consent`}>
        J'accepte de recevoir les emails de Musique Facile. Désinscription en 1 clic à tout moment.
      </label>
    </div>

    <p class="optin__error" data-error hidden></p>
  </form>

  <div class="optin__success" data-success hidden>
    <div class="optin__check" aria-hidden="true">✓</div>
    <h3>Inscription confirmée !</h3>
    <p>Tu vas recevoir un premier email d'accueil dans quelques minutes. Pense à vérifier tes spams.</p>
  </div>
</aside>

<script>
  type OptinState = 'idle' | 'submitting' | 'success' | 'error';

  document.querySelectorAll<HTMLElement>('[data-inline-optin]').forEach((root) => {
    const form = root.querySelector<HTMLFormElement>('form');
    const errorEl = root.querySelector<HTMLElement>('[data-error]');
    const successEl = root.querySelector<HTMLElement>('[data-success]');
    const submitBtn = root.querySelector<HTMLButtonElement>('button[type="submit"]');
    if (!form || !errorEl || !successEl || !submitBtn) return;

    let state: OptinState = 'idle';

    const setState = (next: OptinState, message?: string) => {
      state = next;
      if (next === 'submitting') {
        submitBtn.disabled = true;
        submitBtn.classList.add('is-loading');
        errorEl.hidden = true;
      } else if (next === 'success') {
        const leadMagnetId = form.dataset.leadMagnet;
        // GTM event si dispo
        const w = window as unknown as { dataLayer?: Array<Record<string, unknown>> };
        if (w.dataLayer) {
          w.dataLayer.push({
            event: 'lead_capture',
            instrument: form.dataset.instrument,
            source: form.dataset.source,
            leadMagnet: leadMagnetId,
          });
        }
        if (leadMagnetId) {
          // Mode lead magnet : redirection vers la page merci avec téléchargement direct du PDF
          window.location.href = `/merci-lead-magnet?lm=${encodeURIComponent(leadMagnetId)}`;
          return;
        }
        form.hidden = true;
        successEl.hidden = false;
      } else if (next === 'error') {
        submitBtn.disabled = false;
        submitBtn.classList.remove('is-loading');
        errorEl.textContent = message ?? 'Une erreur est survenue. Réessaie dans un instant.';
        errorEl.hidden = false;
      } else {
        submitBtn.disabled = false;
        submitBtn.classList.remove('is-loading');
      }
    };

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      if (state === 'submitting') return;

      const emailInput = form.querySelector<HTMLInputElement>('input[type="email"]');
      const consentInput = form.querySelector<HTMLInputElement>('input[type="checkbox"]');
      if (!emailInput || !consentInput) return;

      const email = emailInput.value.trim();
      const consent = consentInput.checked;

      if (!email || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
        setState('error', 'Email invalide.');
        emailInput.focus();
        return;
      }
      if (!consent) {
        setState('error', 'Merci de cocher la case de consentement.');
        consentInput.focus();
        return;
      }

      setState('submitting');

      try {
        const res = await fetch('/api/subscribe', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            email,
            consent,
            instrument: form.dataset.instrument || undefined,
            source: form.dataset.source || undefined,
            leadMagnet: form.dataset.leadMagnet || undefined,
          }),
        });
        const data = await res.json().catch(() => ({}));
        if (res.ok && data.ok) {
          setState('success');
        } else {
          setState('error', data.error || 'Erreur côté serveur.');
        }
      } catch {
        setState('error', 'Connexion impossible. Vérifie ta connexion internet.');
      }
    });
  });
</script>

<style>
  .inline-optin {
    position: relative;
    margin: 3rem 0;
    padding: 2rem 2rem 1.5rem;
    border-radius: var(--border-radius, 12px);
    border: 2px solid rgba(0, 0, 0, 0.08);
    background: linear-gradient(135deg, #ffffff 0%, rgba(250, 250, 250, 0.95) 100%);
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.05);
  }

  .theme-optin-guitar {
    border-color: rgba(231, 76, 60, 0.35);
    background: linear-gradient(135deg, rgba(231, 76, 60, 0.04) 0%, #ffffff 100%);
  }
  .theme-optin-piano {
    border-color: rgba(52, 152, 219, 0.35);
    background: linear-gradient(135deg, rgba(52, 152, 219, 0.04) 0%, #ffffff 100%);
  }
  .theme-optin-ukulele {
    border-color: rgba(46, 204, 113, 0.35);
    background: linear-gradient(135deg, rgba(46, 204, 113, 0.04) 0%, #ffffff 100%);
  }
  .theme-optin-solfege {
    border-color: rgba(155, 89, 182, 0.35);
    background: linear-gradient(135deg, rgba(155, 89, 182, 0.04) 0%, #ffffff 100%);
  }

  .optin__tag {
    position: absolute;
    top: -0.65rem;
    left: 1.25rem;
    background: #fff;
    padding: 0.15rem 0.6rem;
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: rgba(0, 0, 0, 0.5);
    border-radius: 4px;
  }

  .optin__head {
    text-align: center;
    margin-bottom: 1.25rem;
  }

  .optin__hook {
    margin: 0 0 0.5rem;
    font-size: 1.35rem;
    font-weight: 700;
    line-height: 1.3;
    color: var(--color-dark, #1a1a2e);
  }

  .optin__promise {
    margin: 0;
    font-size: 0.95rem;
    line-height: 1.5;
    color: rgba(0, 0, 0, 0.65);
  }

  .optin__row {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 0.5rem;
    margin-bottom: 0.75rem;
  }

  .optin__email {
    padding: 0.85rem 1rem;
    font-size: 1rem;
    border: 1.5px solid rgba(0, 0, 0, 0.15);
    border-radius: 8px;
    background: #fff;
    transition: border-color 0.15s ease, box-shadow 0.15s ease;
  }

  .optin__email:focus {
    outline: none;
    border-color: rgba(0, 0, 0, 0.4);
    box-shadow: 0 0 0 3px rgba(0, 0, 0, 0.06);
  }

  .theme-optin-guitar .optin__email:focus { border-color: var(--theme-guitar); box-shadow: 0 0 0 3px rgba(231,76,60,0.15); }
  .theme-optin-piano .optin__email:focus { border-color: var(--theme-piano); box-shadow: 0 0 0 3px rgba(52,152,219,0.15); }
  .theme-optin-ukulele .optin__email:focus { border-color: var(--theme-ukulele); box-shadow: 0 0 0 3px rgba(46,204,113,0.15); }

  .optin__submit {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.85rem 1.5rem;
    font-size: 0.95rem;
    font-weight: 600;
    color: #fff;
    background: #1a1a2e;
    border: none;
    border-radius: 8px;
    cursor: pointer;
    transition: transform 0.2s ease, box-shadow 0.2s ease, opacity 0.2s ease;
    white-space: nowrap;
  }

  .theme-optin-guitar .optin__submit { background: var(--theme-guitar, #e74c3c); }
  .theme-optin-piano .optin__submit { background: var(--theme-piano, #3498db); }
  .theme-optin-ukulele .optin__submit { background: var(--theme-ukulele, #2ecc71); }
  .theme-optin-solfege .optin__submit { background: #9b59b6; }

  .optin__submit:hover:not(:disabled) {
    transform: translateY(-1px);
    box-shadow: 0 6px 18px rgba(0, 0, 0, 0.18);
  }

  .optin__submit:disabled {
    opacity: 0.7;
    cursor: progress;
  }

  .optin__submit.is-loading .optin__submit-arrow {
    animation: optin-spin 0.6s linear infinite;
    display: inline-block;
  }

  @keyframes optin-spin {
    to { transform: rotate(360deg); }
  }

  .optin__consent {
    display: flex;
    align-items: flex-start;
    gap: 0.5rem;
    font-size: 0.78rem;
    color: rgba(0, 0, 0, 0.55);
    line-height: 1.4;
  }

  .optin__consent input {
    margin-top: 0.2rem;
    flex-shrink: 0;
  }

  .optin__error {
    margin: 0.75rem 0 0;
    padding: 0.6rem 0.85rem;
    background: rgba(231, 76, 60, 0.08);
    border-left: 3px solid #e74c3c;
    border-radius: 4px;
    font-size: 0.85rem;
    color: #c0392b;
  }

  .optin__success {
    text-align: center;
    padding: 0.5rem 0;
  }

  .optin__check {
    width: 48px;
    height: 48px;
    margin: 0 auto 0.75rem;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #2ecc71;
    color: #fff;
    font-size: 1.75rem;
    font-weight: 700;
    border-radius: 50%;
  }

  .optin__success h3 {
    margin: 0 0 0.5rem;
    font-size: 1.25rem;
    color: var(--color-dark, #1a1a2e);
  }

  .optin__success p {
    margin: 0;
    font-size: 0.95rem;
    color: rgba(0, 0, 0, 0.6);
    line-height: 1.5;
  }

  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  @media (max-width: 600px) {
    .inline-optin {
      padding: 1.5rem 1.25rem 1.25rem;
      margin: 2rem 0;
    }

    .optin__hook {
      font-size: 1.15rem;
    }

    .optin__row {
      grid-template-columns: 1fr;
    }

    .optin__submit {
      padding: 0.9rem 1.25rem;
    }
  }
</style>
