---
import { getCollection } from 'astro:content';

/**
 * Composant PillarLink - Bandeau retour vers l'article pilier
 * Affiche un lien discret style breadcrumb vers l'article pilier du silo
 */

interface Props {
  pillarSlug: string;
  instrument?: string;
}

const { pillarSlug, instrument = '' } = Astro.props;

// Recuperer l'article pilier via la collection blog
const allPosts = await getCollection('blog');
const pillarPost = allPosts.find(post => post.slug === pillarSlug && post.data.pillar === true);

// Si l'article pilier n'existe pas, ne rien afficher
if (!pillarPost) return;

const pillarTitle = pillarPost.data.title;
const pillarUrl = `/blog/${pillarSlug}`;

// Determiner la classe de theme instrument
const instrumentThemeMap: Record<string, string> = {
  'guitare': 'guitar',
  'piano': 'piano',
  'ukulele': 'ukulele',
  'solfege': 'solfege',
};
const themeClass = instrumentThemeMap[instrument] || '';
---

<div class={`pillar-link ${themeClass ? `pillar-link--${themeClass}` : ''}`}>
  <a href={pillarUrl} class="pillar-link__anchor">
    <span class="pillar-link__icon" aria-hidden="true">&#x1F4DA;</span>
    <span class="pillar-link__text">
      Guide complet : <strong>{pillarTitle}</strong>
    </span>
    <span class="pillar-link__arrow" aria-hidden="true">&rarr;</span>
  </a>
</div>

<style>
  .pillar-link {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .pillar-link__anchor {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.6rem 1rem;
    background: var(--bg-light, #f5f5f5);
    border-left: 3px solid var(--theme-current, #666);
    border-radius: 0 6px 6px 0;
    text-decoration: none;
    color: var(--gray-700, #444);
    font-size: 0.9rem;
    transition: all 0.2s ease;
  }

  .pillar-link__anchor:hover {
    background: var(--theme-current-light, #e8e8e8);
    color: var(--color-dark, #222);
    border-left-color: var(--theme-current, #666);
  }

  .pillar-link__anchor:hover .pillar-link__arrow {
    transform: translateX(3px);
  }

  .pillar-link__icon {
    font-size: 1.1rem;
    flex-shrink: 0;
  }

  .pillar-link__text {
    flex: 1;
    min-width: 0;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .pillar-link__text strong {
    color: var(--theme-current, #333);
  }

  .pillar-link__arrow {
    flex-shrink: 0;
    transition: transform 0.2s ease;
    color: var(--theme-current, #666);
    font-weight: 600;
  }

  /* Theme variants */
  .pillar-link--guitar .pillar-link__anchor {
    border-left-color: var(--theme-guitar, #e8672c);
  }
  .pillar-link--guitar .pillar-link__text strong,
  .pillar-link--guitar .pillar-link__arrow {
    color: var(--theme-guitar, #e8672c);
  }

  .pillar-link--piano .pillar-link__anchor {
    border-left-color: var(--theme-piano, #3b82f6);
  }
  .pillar-link--piano .pillar-link__text strong,
  .pillar-link--piano .pillar-link__arrow {
    color: var(--theme-piano, #3b82f6);
  }

  .pillar-link--ukulele .pillar-link__anchor {
    border-left-color: var(--theme-ukulele, #10b981);
  }
  .pillar-link--ukulele .pillar-link__text strong,
  .pillar-link--ukulele .pillar-link__arrow {
    color: var(--theme-ukulele, #10b981);
  }

  .pillar-link--solfege .pillar-link__anchor {
    border-left-color: var(--theme-solfege, #8b5cf6);
  }
  .pillar-link--solfege .pillar-link__text strong,
  .pillar-link--solfege .pillar-link__arrow {
    color: var(--theme-solfege, #8b5cf6);
  }

  @media (max-width: 768px) {
    .pillar-link {
      padding: 0 1rem;
    }

    .pillar-link__anchor {
      font-size: 0.85rem;
      padding: 0.5rem 0.8rem;
      gap: 0.4rem;
    }

    .pillar-link__text {
      white-space: normal;
    }
  }
</style>
