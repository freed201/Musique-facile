---
interface Props {
  /** Titre de la section pricing */
  title?: string;
  /** Prix actuel (string, ex: "89.00") */
  price?: string;
  /** Devise */
  currency?: string;
  /** Texte du paiement echelonne (ex: "ou 3x 30EUR sans frais") */
  installment?: string;
  /** Liste des features incluses */
  features?: string[];
  /** Texte de garantie */
  guarantee?: string;
  /** Texte du CTA */
  ctaText?: string;
  /** Lien du CTA */
  ctaLink?: string;
  /** Type d'acces (ex: "Acces a vie") */
  accessLabel?: string;
}

const {
  title = "Investissez dans votre passion",
  price = "79",
  currency = "EUR",
  installment,
  features = [],
  guarantee = "Garantie satisfait ou rembourse 15 jours",
  ctaText = "Je m'inscris maintenant !",
  ctaLink = "#",
  accessLabel = "Paiement unique - Acces a vie",
} = Astro.props;

// Formater le symbole de devise
const currencySymbol = currency === 'EUR' ? '\u20AC' : currency;

// Extraire la partie entiere et decimale du prix
const priceNum = parseFloat(price);
const priceWhole = Math.floor(priceNum);
---

<section class="course-pricing" id="pricing">
  <div class="container">
    <div class="pricing-card-wrapper">
      <div class="pricing-badge">{accessLabel}</div>
      <div class="pricing-card-inner">
        <div class="pricing-header-block">
          <h2 class="pricing-heading">{title}</h2>
          <div class="pricing-price-block">
            <span class="pricing-amount">
              <span class="pricing-currency-sym">{currencySymbol}</span>{priceWhole}
            </span>
          </div>
          {installment && (
            <span class="pricing-installment-tag">{installment}</span>
          )}
        </div>

        <div class="pricing-body-block">
          {features.length > 0 && (
            <ul class="pricing-features-list">
              {features.map((feature) => (
                <li>
                  <svg class="pricing-check-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                    <polyline points="20 6 9 17 4 12"/>
                  </svg>
                  <span>{feature}</span>
                </li>
              ))}
            </ul>
          )}

          <a href={ctaLink} class="pricing-cta-btn pulsing">
            {ctaText}
          </a>

          <div class="pricing-guarantee-block">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
            </svg>
            <span>{guarantee}</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .course-pricing {
    padding: 6rem 0;
    background: linear-gradient(135deg, var(--bg-light, #f8f9fc) 0%, color-mix(in srgb, var(--theme-current) 5%, white) 100%);
  }

  .pricing-card-wrapper {
    max-width: 560px;
    margin: 0 auto;
    position: relative;
  }

  .pricing-badge {
    position: absolute;
    top: -16px;
    left: 50%;
    transform: translateX(-50%);
    background: var(--theme-current);
    color: white;
    padding: 0.5rem 1.5rem;
    border-radius: 50px;
    font-size: 0.85rem;
    font-weight: 600;
    white-space: nowrap;
    z-index: 2;
    box-shadow: 0 4px 15px color-mix(in srgb, var(--theme-current) 30%, transparent);
  }

  .pricing-card-inner {
    background: white;
    border-radius: 20px;
    box-shadow: 0 8px 40px rgba(0, 0, 0, 0.1);
    overflow: hidden;
    border: 2px solid color-mix(in srgb, var(--theme-current) 15%, transparent);
  }

  .pricing-header-block {
    background: linear-gradient(135deg, var(--theme-current), var(--theme-current-dark));
    color: white;
    padding: 3rem 2rem 2rem;
    text-align: center;
  }

  .pricing-heading {
    font-size: 1.6rem;
    margin: 0 0 1.25rem;
    color: white;
    font-weight: 600;
  }

  .pricing-price-block {
    margin-bottom: 0.5rem;
  }

  .pricing-amount {
    font-size: 4rem;
    font-weight: 800;
    line-height: 1;
  }

  .pricing-currency-sym {
    font-size: 1.8rem;
    font-weight: 400;
    vertical-align: super;
    margin-right: 0.15rem;
  }

  .pricing-installment-tag {
    display: inline-block;
    background: rgba(255, 255, 255, 0.2);
    padding: 0.35rem 1.25rem;
    border-radius: 50px;
    font-size: 0.9rem;
    margin-top: 0.75rem;
    backdrop-filter: blur(5px);
  }

  .pricing-body-block {
    padding: 2.5rem 2rem;
  }

  .pricing-features-list {
    list-style: none;
    padding: 0;
    margin: 0 0 2rem;
  }

  .pricing-features-list li {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.85rem 0;
    border-bottom: 1px solid rgba(0, 0, 0, 0.06);
    font-size: 1.05rem;
    color: var(--color-dark, #1a1a2e);
  }

  .pricing-features-list li:last-child {
    border-bottom: none;
  }

  .pricing-check-icon {
    flex-shrink: 0;
    color: var(--theme-current);
  }

  .pricing-cta-btn {
    display: block;
    width: 100%;
    background: var(--theme-current);
    color: white;
    text-decoration: none;
    padding: 1.25rem 2rem;
    border-radius: var(--border-radius, 12px);
    font-size: 1.25rem;
    font-weight: 700;
    text-align: center;
    transition: all 0.3s ease;
    margin-bottom: 1.5rem;
    box-shadow: 0 4px 15px color-mix(in srgb, var(--theme-current) 30%, transparent);
  }

  .pricing-cta-btn:hover {
    transform: translateY(-3px);
    box-shadow: 0 8px 25px color-mix(in srgb, var(--theme-current) 40%, transparent);
  }

  .pricing-guarantee-block {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    font-size: 0.9rem;
    color: #666;
  }

  .pricing-guarantee-block svg {
    color: var(--theme-current);
    flex-shrink: 0;
  }

  @media (prefers-color-scheme: dark) {
    .course-pricing {
      background: linear-gradient(135deg, var(--bg-dark, #12121f) 0%, var(--bg-dark-alt, #1a1a2e) 100%);
    }

    .pricing-card-inner {
      background: var(--bg-dark-alt, #1a1a2e);
      border-color: rgba(255, 255, 255, 0.1);
    }

    .pricing-features-list li {
      color: var(--color-light, #e0e0e0);
      border-bottom-color: rgba(255, 255, 255, 0.08);
    }

    .pricing-guarantee-block {
      color: #aaa;
    }
  }

  @media (max-width: 768px) {
    .course-pricing {
      padding: 4rem 0;
    }

    .pricing-card-wrapper {
      margin: 0 1rem;
    }

    .pricing-heading {
      font-size: 1.4rem;
    }

    .pricing-amount {
      font-size: 3rem;
    }

    .pricing-body-block {
      padding: 2rem 1.5rem;
    }

    .pricing-cta-btn {
      font-size: 1.1rem;
      padding: 1rem 1.5rem;
    }
  }
</style>
