---
/**
 * InstructorHighlight.astro
 * Section "Fred" condensee pour la homepage.
 * Storytelling : musicien pro > pedagogue > 80 000 eleves.
 * Layout 2 colonnes : photo/video + texte + credentials.
 */

interface Props {
  title?: string;
  videoUrl?: string;
  videoThumbnail?: string;
}

const {
  title = "Salut, moi c'est Fred !",
  videoUrl = "",
  videoThumbnail = "/images/prof/fred.webp"
} = Astro.props;
---

<section class="instructor-section" aria-label="Votre professeur Fred Fieffe" data-animate="reveal">
  <div class="instructor-container">
    <div class="instructor-grid">
      <!-- Colonne visuelle : photo ou facade video -->
      <div class="instructor-visual">
        {videoUrl ? (
          <div class="video-facade" data-video-url={videoUrl}>
            <img
              src={videoThumbnail}
              alt="Fred Fieffe, votre professeur de musique"
              loading="lazy"
              width="480"
              height="480"
              class="instructor-photo"
            />
            <button class="play-btn" aria-label="Lire la video de presentation de Fred">
              <svg width="64" height="64" viewBox="0 0 64 64" fill="none">
                <circle cx="32" cy="32" r="32" fill="rgba(108, 63, 160, 0.85)"/>
                <polygon points="26,20 26,44 46,32" fill="white"/>
              </svg>
            </button>
          </div>
        ) : (
          <img
            src={videoThumbnail}
            alt="Fred Fieffe, votre professeur de musique"
            loading="lazy"
            width="480"
            height="480"
            class="instructor-photo"
          />
        )}

        <!-- Credentials / logos -->
        <div class="credentials">
          <div class="credential">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814z"/><polygon points="9.545 15.568 15.818 12 9.545 8.432" fill="#fff"/></svg>
            <span>80K+ abonnes</span>
          </div>
          <div class="credential">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12.525.02c1.31-.02 2.61-.01 3.91-.02.08 1.53.63 3.09 1.75 4.17 1.12 1.11 2.7 1.62 4.24 1.79v4.03c-1.44-.05-2.89-.35-4.2-.97-.57-.26-1.1-.59-1.62-.93-.01 2.92.01 5.84-.02 8.75-.08 1.4-.54 2.79-1.35 3.94-1.31 1.92-3.58 3.17-5.91 3.21-1.43.08-2.86-.31-4.08-1.03-2.02-1.19-3.44-3.37-3.65-5.71-.02-.5-.03-1-.01-1.49.18-1.9 1.12-3.72 2.58-4.96 1.66-1.44 3.98-2.13 6.15-1.72.02 1.48-.04 2.96-.04 4.44-.99-.32-2.15-.23-3.02.37-.63.41-1.11 1.04-1.36 1.75-.21.51-.15 1.07-.14 1.61.24 1.64 1.82 3.02 3.5 2.87 1.12-.01 2.19-.66 2.77-1.61.19-.33.4-.67.41-1.06.1-1.79.06-3.57.07-5.36.01-4.03-.01-8.05.02-12.07z"/></svg>
            <span>105K+ abonnes</span>
          </div>
          <div class="credential">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
            <span>LinkedIn Learning</span>
          </div>
          <div class="credential">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/></svg>
            <span>Auteur Hal Leonard</span>
          </div>
        </div>
      </div>

      <!-- Colonne texte -->
      <div class="instructor-content">
        <h2 class="instructor-title">{title}</h2>

        <div class="instructor-story">
          <p>
            Musicien professionnel depuis plus de <strong>35 ans</strong>, j'enseigne la musique en ligne depuis <strong>2015</strong>. Ma mission : vous prouver que <strong>tout le monde peut jouer</strong>, quel que soit son age ou son niveau de depart.
          </p>
          <p>
            J'ai developpe une methode progressive basee sur la <strong>pratique immediate</strong> : pas de mois de theorie avant de toucher votre instrument. Des la premiere lecon, vous jouez.
          </p>
          <p>
            Aujourd'hui, plus de <strong>80 000 eleves</strong> m'ont fait confiance sur Musique Facile, LinkedIn Learning et Skilleos. Elu <strong>Meilleur formateur Skilleos 2023/2024</strong>.
          </p>
        </div>

        <div class="instructor-stats" data-stagger-group=".stat">
          <div class="stat">
            <span class="stat-number" data-counter="80000" data-counter-suffix="+" data-duration="2000">0</span>
            <span class="stat-label">eleves formes</span>
          </div>
          <div class="stat">
            <span class="stat-number" data-counter="4" data-counter-suffix=".7/5" data-duration="1500">0</span>
            <span class="stat-label">note moyenne</span>
          </div>
          <div class="stat">
            <span class="stat-number" data-counter="1400" data-counter-suffix="+" data-duration="2000">0</span>
            <span class="stat-label">videos</span>
          </div>
          <div class="stat">
            <span class="stat-number" data-counter="15" data-counter-suffix=" ans" data-duration="1500">0</span>
            <span class="stat-label">d'experience</span>
          </div>
        </div>

        <a href="/a-propos/" class="instructor-link">
          En savoir plus sur mon parcours
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
            <path d="M3 8h10m0 0L9 4m4 4l-4 4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  .instructor-section {
    padding: var(--space-20) var(--space-4);
    background: var(--bg-page);
  }

  .instructor-container {
    max-width: 1100px;
    margin: 0 auto;
  }

  .instructor-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-10);
    align-items: center;
  }

  @media (min-width: 768px) {
    .instructor-grid {
      grid-template-columns: 1fr 1.2fr;
      gap: var(--space-16);
    }
  }

  /* Visual column */
  .instructor-visual {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }

  .instructor-photo {
    width: 100%;
    max-width: 400px;
    height: auto;
    border-radius: var(--radius-2xl);
    object-fit: cover;
    margin: 0 auto;
    display: block;
    box-shadow: var(--shadow-xl);
  }

  .video-facade {
    position: relative;
    cursor: pointer;
    border-radius: var(--radius-2xl);
    overflow: hidden;
  }

  .video-facade .instructor-photo {
    border-radius: 0;
    box-shadow: none;
  }

  .play-btn {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    background: none;
    border: none;
    cursor: pointer;
    transition: transform 0.3s ease;
    padding: 0;
  }

  .play-btn:hover {
    transform: translate(-50%, -50%) scale(1.1);
  }

  /* Credentials */
  .credentials {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    justify-content: center;
  }

  @media (min-width: 768px) {
    .credentials {
      justify-content: flex-start;
    }
  }

  .credential {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-2) var(--space-3);
    background: var(--bg-alt);
    border-radius: var(--radius-full);
    font-size: var(--text-xs);
    font-weight: var(--font-semibold);
    color: var(--text-secondary);
  }

  .credential svg {
    color: var(--brand-500);
    flex-shrink: 0;
  }

  /* Content column */
  .instructor-content {
    display: flex;
    flex-direction: column;
  }

  .instructor-title {
    font-family: var(--font-heading);
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: var(--font-bold);
    color: var(--text-primary);
    margin-bottom: var(--space-6);
  }

  .instructor-story p {
    font-size: var(--text-base);
    color: var(--text-secondary);
    line-height: var(--leading-relaxed);
    margin-bottom: var(--space-4);
  }

  .instructor-story strong {
    color: var(--text-primary);
    font-weight: var(--font-semibold);
  }

  /* Stats */
  .instructor-stats {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-4);
    margin: var(--space-6) 0;
    padding: var(--space-6);
    background: var(--bg-alt);
    border-radius: var(--radius-xl);
  }

  @media (min-width: 480px) {
    .instructor-stats {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  .stat {
    text-align: center;
  }

  .stat-number {
    display: block;
    font-family: var(--font-heading);
    font-size: var(--text-xl);
    font-weight: var(--font-bold);
    color: var(--brand-600);
  }

  .stat-label {
    display: block;
    font-size: var(--text-xs);
    color: var(--text-secondary);
    margin-top: var(--space-1);
  }

  /* Link */
  .instructor-link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-base);
    font-weight: var(--font-semibold);
    color: var(--brand-500);
    text-decoration: none;
    transition: gap 0.3s ease, color 0.3s ease;
  }

  .instructor-link:hover {
    color: var(--brand-600);
    gap: var(--space-3);
  }

  /* Dark mode — system */
  @media (prefers-color-scheme: dark) {
    .instructor-section {
      background: #0f172a;
    }

    .instructor-stats {
      background: #1e293b;
    }

    .credential {
      background: #1e293b;
      color: #cbd5e1;
    }

    .instructor-story strong {
      color: #f1f5f9;
    }
  }

  /* Dark mode — manual toggle */
  :global([data-theme="dark"]) .instructor-section {
    background: #0f172a;
  }

  :global([data-theme="dark"]) .instructor-stats {
    background: #1e293b;
  }

  :global([data-theme="dark"]) .credential {
    background: #1e293b;
    color: #cbd5e1;
  }

  :global([data-theme="dark"]) .instructor-story strong {
    color: #f1f5f9;
  }
</style>
