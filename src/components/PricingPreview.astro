---
/**
 * Pricing Preview Section - Transparence des prix
 * Affiche les formations disponibles à l'achat par instrument
 * Modèle : Achat unique avec accès à vie
 */
import Icon from './Icon.astro';
---

<section class="pricing-preview" data-animate="reveal">
  <div class="container">
    <div class="pricing-header">
      <h2 class="pricing-title">Combien ça coûte ?</h2>
      <p class="pricing-subtitle">Transparence totale sur nos tarifs. Achetez la formation qui vous intéresse et gardez l'accès à vie.</p>
    </div>

    <div class="pricing-grid" data-stagger-group=".pricing-card">
      <!-- Formation Guitare -->
      <div class="pricing-card">
        <div class="card-header">
          <span class="instrument-icon"><Icon name="guitar" size={32} /></span>
          <h3 class="card-title">Formation Guitare</h3>
          <p class="card-subtitle">Accès à vie</p>
        </div>
        <div class="card-price">
          <span class="price-amount">99€</span>
          <span class="price-period">paiement unique</span>
        </div>
        <ul class="card-features">
          <li><span class="feature-icon">✓</span> 82 chapitres (4h de cours)</li>
          <li><span class="feature-icon">✓</span> Accès illimité à vie</li>
          <li><span class="feature-icon">✓</span> Mises à jour gratuites</li>
          <li><span class="feature-icon">✓</span> Support par email</li>
          <li><span class="feature-icon">✓</span> Certificat de réussite</li>
        </ul>
        <a href="/cours/cours-de-guitare" class="pricing-cta">
          Découvrir la formation
          <span class="cta-arrow">→</span>
        </a>
      </div>

      <!-- Formation Piano -->
      <div class="pricing-card popular">
        <div class="popular-badge">
          <span><Icon name="star" size={16} /> PLUS POPULAIRE</span>
        </div>
        <div class="card-header">
          <span class="instrument-icon"><Icon name="piano" size={32} /></span>
          <h3 class="card-title">Formation Piano</h3>
          <p class="card-subtitle">Accès à vie</p>
        </div>
        <div class="card-price">
          <span class="price-amount">299€</span>
          <span class="price-period">paiement unique</span>
        </div>
        <ul class="card-features">
          <li><span class="feature-icon">✓</span> 148 leçons (10h de cours)</li>
          <li><span class="feature-icon">✓</span> Accès illimité à vie</li>
          <li><span class="feature-icon">✓</span> Mises à jour gratuites</li>
          <li><span class="feature-icon">✓</span> Support prioritaire</li>
          <li><span class="feature-icon">✓</span> Certificat de réussite</li>
          <li><span class="feature-icon">✓</span> Partitions téléchargeables</li>
        </ul>
        <a href="/cours/cours-de-piano" class="pricing-cta">
          Découvrir la formation
          <span class="cta-arrow">→</span>
        </a>
      </div>

      <!-- Formation Ukulélé -->
      <div class="pricing-card">
        <div class="card-header">
          <span class="instrument-icon"><Icon name="ukulele" size={32} /></span>
          <h3 class="card-title">Formation Ukulélé</h3>
          <p class="card-subtitle">Accès à vie</p>
        </div>
        <div class="card-price">
          <span class="price-amount">79€</span>
          <span class="price-period">paiement unique</span>
        </div>
        <ul class="card-features">
          <li><span class="feature-icon">✓</span> 41 vidéos (2h30 de cours)</li>
          <li><span class="feature-icon">✓</span> Accès illimité à vie</li>
          <li><span class="feature-icon">✓</span> Mises à jour gratuites</li>
          <li><span class="feature-icon">✓</span> Support par email</li>
          <li><span class="feature-icon">✓</span> Certificat de réussite</li>
        </ul>
        <a href="/cours/cours-de-ukulele" class="pricing-cta">
          Découvrir la formation
          <span class="cta-arrow">→</span>
        </a>
      </div>

      <!-- Formation Solfège -->
      <div class="pricing-card">
        <div class="card-header">
          <span class="instrument-icon"><Icon name="solfege" size={32} /></span>
          <h3 class="card-title">Formation Solfège</h3>
          <p class="card-subtitle">Accès à vie</p>
        </div>
        <div class="card-price">
          <span class="price-amount">79€</span>
          <span class="price-period">paiement unique</span>
        </div>
        <ul class="card-features">
          <li><span class="feature-icon">✓</span> 91 vidéos (4h20 de cours)</li>
          <li><span class="feature-icon">✓</span> Accès illimité à vie</li>
          <li><span class="feature-icon">✓</span> Mises à jour gratuites</li>
          <li><span class="feature-icon">✓</span> Support par email</li>
          <li><span class="feature-icon">✓</span> Certificat de réussite</li>
        </ul>
        <a href="/cours/cours-de-solfege" class="pricing-cta">
          Découvrir la formation
          <span class="cta-arrow">→</span>
        </a>
      </div>
    </div>

    <!-- Trust Elements -->
    <div class="pricing-trust">
      <div class="trust-item">
        <span class="trust-icon"><Icon name="credit-card" size={24} /></span>
        <div class="trust-content">
          <strong>Paiement 100% sécurisé</strong>
          <p>Cryptage SSL et conformité PCI</p>
        </div>
      </div>
      <div class="trust-item">
        <span class="trust-icon"><Icon name="undo" size={24} /></span>
        <div class="trust-content">
          <strong>Garantie 15 jours satisfait ou remboursé</strong>
          <p>Sans condition ni question</p>
        </div>
      </div>
      <div class="trust-item">
        <span class="trust-icon"><Icon name="gift" size={24} /></span>
        <div class="trust-content">
          <strong>Offres spéciales disponibles</strong>
          <p>Consultez notre page /offre</p>
        </div>
      </div>
    </div>

    <!-- FAQ Pricing -->
    <div class="pricing-faq">
      <h3 class="faq-title">Questions fréquentes sur les tarifs</h3>
      <div class="faq-grid">
        <div class="faq-item">
          <h4>Puis-je acheter plusieurs formations ?</h4>
          <p>Oui, vous pouvez acheter autant de formations que vous le souhaitez. Chaque formation est indépendante avec un accès à vie.</p>
        </div>
        <div class="faq-item">
          <h4>Y a-t-il des frais cachés ?</h4>
          <p>Non, le prix affiché est le prix final. Aucun frais supplémentaire, ni coût caché. Accès à vie inclus.</p>
        </div>
        <div class="faq-item">
          <h4>Comment accéder aux cours après l'achat ?</h4>
          <p>Dès votre achat validé, vous recevez vos identifiants par email. Connexion immédiate à votre espace de formation.</p>
        </div>
        <div class="faq-item">
          <h4>Les mises à jour sont-elles payantes ?</h4>
          <p>Non, toutes les mises à jour et nouveaux cours ajoutés à votre formation sont gratuits à vie. Vous ne payez qu'une seule fois.</p>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .pricing-preview {
    padding: var(--section-padding);
    background: var(--bg-page);
  }

  .pricing-header {
    text-align: center;
    margin-bottom: 4rem;
  }

  .pricing-title {
    font-size: 3rem;
    color: var(--theme-current);
    margin-bottom: 1rem;
    background: linear-gradient(135deg, var(--theme-current) 0%, var(--theme-current-light) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .pricing-subtitle {
    font-size: 1.3rem;
    color: var(--text-secondary);
  }

  /* Pricing Grid */
  .pricing-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 2rem;
    max-width: 1400px;
    margin: 0 auto 4rem;
  }

  .pricing-card {
    position: relative;
    background: var(--bg-card);
    border-radius: var(--border-radius-lg);
    padding: 2.5rem 2rem;
    box-shadow:
      8px 8px 16px rgba(60, 65, 124, 0.07),
      -4px -4px 12px rgba(255, 255, 255, 0.5);
    transition: all 0.3s ease;
    border: 2px solid var(--border-default);
    display: flex;
    flex-direction: column;
  }

  .pricing-card:hover {
    transform: translateY(-10px);
    box-shadow:
      12px 12px 24px rgba(60, 65, 124, 0.12),
      -6px -6px 16px rgba(255, 255, 255, 0.7);
  }

  .pricing-card.popular {
    border-color: var(--theme-current);
    box-shadow:
      0 20px 40px rgba(108, 63, 160, 0.25),
      8px 8px 16px rgba(60, 65, 124, 0.08);
    transform: scale(1.03);
  }

  .pricing-card.popular:hover {
    transform: scale(1.03) translateY(-10px);
  }

  .popular-badge {
    position: absolute;
    top: -15px;
    left: 50%;
    transform: translateX(-50%);
    background: linear-gradient(135deg, var(--theme-current) 0%, var(--theme-current-light) 100%);
    color: white;
    padding: 0.5rem 1.5rem;
    border-radius: 50px;
    font-weight: 700;
    font-size: 0.85rem;
    box-shadow: 0 4px 12px rgba(108, 63, 160, 0.4);
    white-space: nowrap;
  }

  .card-header {
    text-align: center;
    margin-bottom: 1.5rem;
  }

  .instrument-icon {
    font-size: 3rem;
    display: block;
    margin-bottom: 1rem;
  }

  .card-title {
    font-size: 1.5rem;
    color: var(--text-primary);
    margin-bottom: 0.5rem;
    font-weight: 700;
  }

  .card-subtitle {
    font-size: 0.9rem;
    color: var(--text-muted);
  }

  .card-price {
    text-align: center;
    margin-bottom: 1.5rem;
    padding-bottom: 1.5rem;
    border-bottom: 2px solid var(--border-default);
  }

  .price-amount {
    font-size: 3rem;
    font-weight: 700;
    color: var(--theme-current);
    line-height: 1;
    display: block;
  }

  .price-period {
    font-size: 0.95rem;
    color: var(--text-muted);
    display: block;
    margin-top: 0.5rem;
  }

  .card-features {
    list-style: none;
    padding: 0;
    margin: 0 0 2rem 0;
    flex: 1;
  }

  .card-features li {
    display: flex;
    align-items: flex-start;
    gap: 0.8rem;
    padding: 0.7rem 0;
    font-size: 0.95rem;
    color: var(--text-secondary);
    border-bottom: 1px solid var(--border-default);
  }

  .card-features li:last-child {
    border-bottom: none;
  }

  .feature-icon {
    color: var(--theme-current);
    font-weight: 700;
    font-size: 1.1rem;
    flex-shrink: 0;
  }

  .pricing-cta {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.8rem;
    background: var(--theme-current);
    color: white;
    padding: 1rem 1.5rem;
    border-radius: var(--border-radius-lg);
    text-decoration: none;
    font-weight: 700;
    font-size: 1rem;
    transition: all 0.3s ease;
    box-shadow: 0 4px 12px rgba(108, 63, 160, 0.3);
  }

  .pricing-cta:hover {
    background: var(--theme-current-dark);
    transform: translateY(-3px);
    box-shadow: 0 8px 20px rgba(108, 63, 160, 0.4);
  }

  .cta-arrow {
    font-size: 1.3rem;
    transition: transform 0.3s ease;
  }

  .pricing-cta:hover .cta-arrow {
    transform: translateX(5px);
  }

  .pricing-card.popular .pricing-cta {
    background: linear-gradient(135deg, var(--theme-current) 0%, var(--theme-current-light) 100%);
    box-shadow: 0 8px 20px rgba(108, 63, 160, 0.4);
  }

  /* Trust Elements */
  .pricing-trust {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
    max-width: 1200px;
    margin: 0 auto 4rem;
    padding: 3rem 2rem;
    background: var(--bg-card);
    border-radius: var(--border-radius-lg);
    box-shadow: var(--box-shadow);
  }

  .trust-item {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    text-align: left;
  }

  .trust-icon {
    font-size: 2.5rem;
    flex-shrink: 0;
  }

  .trust-content strong {
    display: block;
    color: var(--text-primary);
    font-size: 1.1rem;
    margin-bottom: 0.3rem;
  }

  .trust-content p {
    color: var(--text-muted);
    font-size: 0.95rem;
    margin: 0;
  }

  /* FAQ */
  .pricing-faq {
    max-width: 1200px;
    margin: 0 auto;
  }

  .faq-title {
    font-size: 2rem;
    color: var(--text-primary);
    text-align: center;
    margin-bottom: 2rem;
  }

  .faq-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 2rem;
  }

  .faq-item {
    background: var(--bg-card);
    padding: 2rem;
    border-radius: var(--border-radius-lg);
    box-shadow: var(--box-shadow);
  }

  .faq-item h4 {
    color: var(--theme-current);
    font-size: 1.2rem;
    margin-bottom: 1rem;
  }

  .faq-item p {
    color: var(--text-secondary);
    line-height: 1.6;
    margin: 0;
  }

  /* Responsive */
  @media (max-width: 1200px) {
    .pricing-grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .pricing-card.popular {
      transform: scale(1);
    }

    .pricing-card.popular:hover {
      transform: translateY(-10px);
    }
  }

  @media (max-width: 1024px) {
    .pricing-trust {
      grid-template-columns: 1fr;
    }

    .faq-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 768px) {
    .pricing-grid {
      grid-template-columns: 1fr;
    }

    .pricing-title {
      font-size: 2.2rem;
    }

    .pricing-subtitle {
      font-size: 1.1rem;
    }

    .pricing-card {
      padding: 2rem 1.5rem;
    }

    .price-amount {
      font-size: 2.5rem;
    }

    .pricing-trust {
      padding: 2rem 1rem;
    }

    .trust-item {
      flex-direction: column;
      align-items: center;
      text-align: center;
    }
  }

  /* ========================================
     DARK MODE - System preference
     ======================================== */
  @media (prefers-color-scheme: dark) {
    .pricing-preview {
      background: #0f172a;
    }

    .pricing-card {
      background: #1e293b;
      border-color: rgba(255, 255, 255, 0.1);
    }

    .card-title {
      color: #f1f5f9;
    }

    .card-subtitle {
      color: #94a3b8;
    }

    .card-price {
      border-color: rgba(255, 255, 255, 0.1);
    }

    .card-features li {
      color: #cbd5e1;
      border-color: rgba(255, 255, 255, 0.05);
    }

    .pricing-subtitle {
      color: #cbd5e1;
    }

    .price-period {
      color: #94a3b8;
    }

    .pricing-trust {
      background: #1e293b;
    }

    .trust-content strong {
      color: #f1f5f9;
    }

    .trust-content p {
      color: #94a3b8;
    }

    .faq-title {
      color: #f1f5f9;
    }

    .faq-item {
      background: #1e293b;
    }

    .faq-item p {
      color: #cbd5e1;
    }
  }

  /* ========================================
     DARK MODE - Manual toggle (data-theme)
     ======================================== */
  :global([data-theme="dark"]) .pricing-preview {
    background: #0f172a;
  }

  :global([data-theme="dark"]) .pricing-card {
    background: #1e293b;
    border-color: rgba(255, 255, 255, 0.1);
  }

  :global([data-theme="dark"]) .card-title {
    color: #f1f5f9;
  }

  :global([data-theme="dark"]) .card-subtitle {
    color: #94a3b8;
  }

  :global([data-theme="dark"]) .card-price {
    border-color: rgba(255, 255, 255, 0.1);
  }

  :global([data-theme="dark"]) .card-features li {
    color: #cbd5e1;
    border-color: rgba(255, 255, 255, 0.05);
  }

  :global([data-theme="dark"]) .pricing-subtitle {
    color: #cbd5e1;
  }

  :global([data-theme="dark"]) .price-period {
    color: #94a3b8;
  }

  :global([data-theme="dark"]) .pricing-trust {
    background: #1e293b;
  }

  :global([data-theme="dark"]) .trust-content strong {
    color: #f1f5f9;
  }

  :global([data-theme="dark"]) .trust-content p {
    color: #94a3b8;
  }

  :global([data-theme="dark"]) .faq-title {
    color: #f1f5f9;
  }

  :global([data-theme="dark"]) .faq-item {
    background: #1e293b;
  }

  :global([data-theme="dark"]) .faq-item p {
    color: #cbd5e1;
  }
</style>

<!-- Animations gerees par animations.js via data-stagger-group -->
