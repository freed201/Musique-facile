---
/**
 * CoursGrid.astro
 * Grille de cours moderne avec cards colorées par instrument
 */
import Icon from './Icon.astro';

interface Course {
  id: string;
  iconName: string;
  title: string;
  promise: string;
  description: string;
  features: string[];
  url: string;
  theme: 'guitar' | 'piano' | 'ukulele' | 'solfege';
  image: string;
  imageAlt: string;
  ctaText: string;
  stats?: {
    videos: number;
    hours: string;
  };
}

interface Props {
  title?: string;
  subtitle?: string;
  courses?: Course[];
}

const defaultCourses: Course[] = [
  {
    id: 'guitar',
    iconName: 'guitar',
    title: 'Guitare',
    promise: 'Jouez vos chansons preferees',
    description: 'Methode progressive de la premiere note a l\'autonomie complete.',
    features: ['Accords de base', 'Techniques avancees', 'Tablatures & partitions'],
    url: '/cours/cours-de-guitare',
    theme: 'guitar',
    image: '/images/cours/cours-de-guitare.webp',
    imageAlt: 'Cours de guitare en ligne avec Fred Fieffe',
    ctaText: 'Je commence la guitare',
    stats: { videos: 82, hours: '4h' }
  },
  {
    id: 'piano',
    iconName: 'piano',
    title: 'Piano',
    promise: 'Decouvrez le piano sans solfege',
    description: 'Du debutant a l\'intermediaire, apprenez en jouant des le premier cours.',
    features: ['Lecture de notes', 'Coordination mains', 'Morceaux classiques'],
    url: '/cours/cours-de-piano',
    theme: 'piano',
    image: '/images/cours/cours-de-piano.webp',
    imageAlt: 'Cours de piano en ligne avec Fred Fieffe',
    ctaText: 'Je commence le piano',
    stats: { videos: 148, hours: '10h' }
  },
  {
    id: 'ukulele',
    iconName: 'ukulele',
    title: 'Ukulele',
    promise: 'L\'instrument le plus facile. Jouez en 1 semaine',
    description: 'L\'instrument ideal pour debuter la musique en s\'amusant.',
    features: ['Accords simples', 'Rythmiques', 'Chansons populaires'],
    url: '/cours/cours-de-ukulele',
    theme: 'ukulele',
    image: '/images/cours/cours-de-ukulele.webp',
    imageAlt: 'Cours de ukulele en ligne avec Fred Fieffe',
    ctaText: 'Je commence le ukulele',
    stats: { videos: 41, hours: '2h30' }
  },
  {
    id: 'solfege',
    iconName: 'solfege',
    title: 'Solfège & Théorie Musicale',
    promise: 'Comprenez la musique, progressez 2x plus vite',
    description: 'Lecture de notes, rythme, harmonie et ear training : la théorie musicale expliquée simplement pour progresser 2x plus vite.',
    features: ['Lecture de notes & rythmes', 'Harmonie & ear training', 'Cycle des quintes'],
    url: '/cours/cours-de-solfege',
    theme: 'solfege',
    image: '/images/cours/cours-de-solfege.webp',
    imageAlt: 'Cours de solfège et théorie musicale en ligne',
    ctaText: 'Je commence le solfège',
    stats: { videos: 91, hours: '4h20' }
  }
];

const {
  title = "Choisissez votre instrument",
  subtitle = "Des cours structures pour progresser a votre rythme, du debutant a l'intermediaire.",
  courses = defaultCourses
} = Astro.props;
---

<section class="cours-section" data-animate="reveal">
  <div class="cours-container">
    <!-- Header -->
    <div class="cours-header">
      <h2 class="cours-title">{title}</h2>
      <p class="cours-subtitle">{subtitle}</p>
    </div>

    <!-- Grid -->
    <div class="cours-grid" data-stagger-group=".cours-card">
      {courses.map((course) => (
        <a href={course.url} class={`cours-card theme-${course.theme}`}>
          <div class="card-image">
            <img src={course.image} alt={course.imageAlt} loading="lazy" width="400" height="400" />
            <div class="card-image-overlay"></div>
            {course.stats && (
              <span class="card-badge">{course.stats.videos} videos</span>
            )}
          </div>

          <div class="card-body">
            <h3 class="card-title">{course.title}</h3>
            <p class="card-promise">{course.promise}</p>
            <p class="card-description">{course.description}</p>

            <div class="card-footer">
              <span class="card-cta">
                {course.ctaText}
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
                  <path d="M3 8h10m0 0L9 4m4 4l-4 4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </span>
            </div>
          </div>

          <!-- Effet de brillance au hover -->
          <div class="card-shine"></div>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .cours-section {
    padding: var(--space-20) var(--space-4);
    background: var(--bg-page);
  }

  .cours-container {
    max-width: 1200px;
    margin: 0 auto;
  }

  /* Header */
  .cours-header {
    text-align: center;
    margin-bottom: var(--space-12);
  }

  .cours-title {
    font-family: var(--font-heading);
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: var(--font-bold);
    color: var(--text-primary);
    margin-bottom: var(--space-4);
  }

  .cours-subtitle {
    font-size: var(--text-lg);
    color: var(--text-secondary);
    max-width: 600px;
    margin: 0 auto;
  }

  /* Grid */
  .cours-grid {
    display: grid;
    grid-template-columns: repeat(1, 1fr);
    gap: var(--space-6);
  }

  @media (min-width: 640px) {
    .cours-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .cours-grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  /* Card */
  .cours-card {
    position: relative;
    display: flex;
    flex-direction: column;
    background: var(--bg-card);
    border-radius: var(--radius-xl);
    text-decoration: none;
    color: inherit;
    overflow: hidden;
    transition: all 0.3s ease;
    border: 1px solid var(--border-default);
    box-shadow:
      6px 6px 14px rgba(60, 65, 124, 0.06),
      -3px -3px 10px rgba(255, 255, 255, 0.5);
  }

  .cours-card::before {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 4px;
    background: var(--card-color);
    border-radius: var(--radius-xl) var(--radius-xl) 0 0;
    z-index: 1;
  }

  .cours-card:hover {
    box-shadow:
      10px 10px 20px rgba(60, 65, 124, 0.1),
      -5px -5px 14px rgba(255, 255, 255, 0.7);
  }

  /* Card Image */
  .card-image {
    position: relative;
    aspect-ratio: 16/10;
    overflow: hidden;
  }

  .card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transform: scale(1.08);
    will-change: transform;
  }

  .cours-card:hover .card-image img {
    transition: none;
  }

  .card-image-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(0,0,0,0.4) 0%, transparent 50%);
    pointer-events: none;
  }

  .card-badge {
    position: absolute;
    top: var(--space-3);
    right: var(--space-3);
    font-size: var(--text-xs);
    font-weight: var(--font-semibold);
    color: white;
    background: var(--card-color);
    padding: var(--space-1) var(--space-3);
    border-radius: var(--radius-full);
    white-space: nowrap;
    box-shadow: 0 2px 8px rgba(0,0,0,0.2);
    z-index: 1;
  }

  /* Card Body */
  .card-body {
    padding: var(--space-5);
    display: flex;
    flex-direction: column;
    flex-grow: 1;
  }

  /* Thèmes de couleur */
  .cours-card.theme-guitar {
    --card-color: var(--guitar-500);
    --card-bg: var(--guitar-50);
  }

  .cours-card.theme-piano {
    --card-color: var(--piano-500);
    --card-bg: var(--piano-50);
  }

  .cours-card.theme-ukulele {
    --card-color: var(--ukulele-500);
    --card-bg: var(--ukulele-50);
  }

  .cours-card.theme-solfege {
    --card-color: var(--solfege-500);
    --card-bg: var(--solfege-50);
  }

  .cours-card:hover {
    border-color: var(--card-color);
  }

  /* Card Content */
  .card-title {
    font-family: var(--font-heading);
    font-size: var(--text-xl);
    font-weight: var(--font-bold);
    color: var(--text-primary);
    margin: 0 0 var(--space-2) 0;
  }

  .card-promise {
    font-family: var(--font-heading);
    font-size: var(--text-base);
    font-weight: var(--font-semibold);
    color: var(--card-color);
    line-height: var(--leading-snug);
    margin-bottom: var(--space-2);
  }

  .card-description {
    font-size: var(--text-sm);
    color: var(--text-secondary);
    line-height: var(--leading-relaxed);
    margin-bottom: var(--space-3);
    flex-grow: 1;
  }

  /* Footer */
  .card-footer {
    margin-top: auto;
    padding-top: var(--space-3);
    border-top: 1px solid var(--border-default);
  }

  .card-cta {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    width: 100%;
    justify-content: center;
    padding: var(--space-3) var(--space-4);
    font-size: var(--text-sm);
    font-weight: var(--font-semibold);
    color: white;
    background: var(--card-color);
    border-radius: var(--radius-lg);
    transition: all 0.3s ease;
  }

  .cours-card:hover .card-cta {
    gap: var(--space-3);
    filter: brightness(1.1);
  }

  /* Effet shine */
  .card-shine {
    position: absolute;
    top: 0;
    left: -100%;
    width: 100%;
    height: 100%;
    background: linear-gradient(
      120deg,
      transparent,
      rgba(255, 255, 255, 0.3),
      transparent
    );
    transition: left 0.5s ease;
    pointer-events: none;
  }

  .cours-card:hover .card-shine {
    left: 100%;
  }

  /* Reduced motion */
  @media (prefers-reduced-motion: reduce) {
    .cours-card:hover {
      transform: none;
    }

    .card-shine {
      display: none;
    }
  }

  /* ========================================
     DARK MODE - System preference
     ======================================== */
  @media (prefers-color-scheme: dark) {
    .cours-section {
      background: #0f172a;
    }

    .cours-title {
      color: #f1f5f9;
    }

    .cours-subtitle {
      color: #cbd5e1;
    }

    .cours-card {
      background: #1e293b;
      border-color: rgba(255, 255, 255, 0.1);
    }

    .card-badge {
      background: var(--card-color);
    }

    .card-title {
      color: #f1f5f9;
    }

    .card-description {
      color: #cbd5e1;
    }

    .card-features li {
      color: #cbd5e1;
    }

    .card-footer {
      border-color: rgba(255, 255, 255, 0.1);
    }
  }

  /* ========================================
     DARK MODE - Manual toggle (data-theme)
     ======================================== */
  :global([data-theme="dark"]) .cours-section {
    background: #0f172a;
  }

  :global([data-theme="dark"]) .cours-title {
    color: #f1f5f9;
  }

  :global([data-theme="dark"]) .cours-subtitle {
    color: #cbd5e1;
  }

  :global([data-theme="dark"]) .cours-card {
    background: #1e293b;
    border-color: rgba(255, 255, 255, 0.1);
  }

  :global([data-theme="dark"]) .card-title {
    color: #f1f5f9;
  }

  :global([data-theme="dark"]) .card-description {
    color: #cbd5e1;
  }

  :global([data-theme="dark"]) .card-features li {
    color: #cbd5e1;
  }

  :global([data-theme="dark"]) .card-footer {
    border-color: rgba(255, 255, 255, 0.1);
  }
</style>

<script>
  // Parallax image au scroll + Tilt 3D au hover
  (function() {
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
    if (!window.matchMedia('(hover: hover)').matches) return;

    const cards = document.querySelectorAll('.cours-card');
    if (!cards.length) return;

    // --- Tilt 3D au hover ---
    cards.forEach(card => {
      card.style.transformStyle = 'preserve-3d';
      card.style.perspective = '800px';

      card.addEventListener('mousemove', (e) => {
        const rect = card.getBoundingClientRect();
        const x = (e.clientX - rect.left) / rect.width;
        const y = (e.clientY - rect.top) / rect.height;
        const rotateX = (0.5 - y) * 8;
        const rotateY = (x - 0.5) * 8;
        card.style.transform = `perspective(800px) rotateX(${rotateX}deg) rotateY(${rotateY}deg) translateY(-4px)`;
      });

      card.addEventListener('mouseleave', () => {
        card.style.transform = '';
        card.style.transition = 'transform 0.4s ease';
        setTimeout(() => { card.style.transition = ''; }, 400);
      });
    });

    // --- Parallax image interne au scroll ---
    let ticking = false;
    function updateParallax() {
      cards.forEach(card => {
        const img = card.querySelector('.card-image img');
        if (!img) return;
        const rect = card.getBoundingClientRect();
        const vh = window.innerHeight;
        if (rect.top > vh || rect.bottom < 0) return;
        const progress = (vh - rect.top) / (vh + rect.height);
        const offset = (progress - 0.5) * 20; // ±10px
        img.style.transform = `scale(1.08) translateY(${offset}px)`;
      });
      ticking = false;
    }

    window.addEventListener('scroll', () => {
      if (!ticking) {
        requestAnimationFrame(updateParallax);
        ticking = true;
      }
    }, { passive: true });

    updateParallax();
  })();
</script>
