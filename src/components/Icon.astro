---
/**
 * Icon.astro
 * Composant d'icones SVG inline pour remplacer les emojis.
 * Utilise currentColor pour s'adapter au contexte.
 * Usage : <Icon name="guitar" size={24} />
 */

interface Props {
  name: string;
  size?: number;
  class?: string;
}

const { name, size = 24, class: className = '' } = Astro.props;
