  <svg class={`icon icon-guitar ${className}`} width={size} height={size} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <path d="M19.5 2.5l2 2M19.5 2.5l-1.5 1.5M21.5 4.5L20 6"/>
