---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import FooterModern from '../../components/FooterModern.astro';
import Icon from '../../components/Icon.astro';
import { getCollection } from 'astro:content';
import BreadcrumbNav from '../../components/BreadcrumbNav.astro';

// Récupérer uniquement les cours de ukulélé
const allCourses = await getCollection('courses');
const ukeleleCourses = allCourses
  .filter(course => course.data.theme === 'ukulele' && course.data.affichage === 'Y')
  .sort((a, b) => a.data.classement - b.data.classement);

// Construction de l'URL canonique
const canonicalURL = new URL(Astro.url.pathname, Astro.site || 'https://musique-facile.fr').toString();

// Métadonnées pour la page
const title = "Cours d'Ukulélé en Ligne | Musique Facile";
const description = "Apprends l'ukulélé avec Fred Fieffé : 250+ leçons vidéo HD, méthode progressive, accords simples et rythmiques. 80 000+ élèves formés depuis 2015. L'instrument le plus facile pour débuter. Satisfait ou remboursé sous 15 jours.";

// Schema.org pour le fil d'Ariane
const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Accueil",
      "item": "https://musique-facile.fr/"
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": "Cours",
      "item": "https://musique-facile.fr/cours/"
    },
    {
      "@type": "ListItem",
      "position": 3,
      "name": "Cours d'Ukulélé",
      "item": canonicalURL
    }
  ]
};

// Schema.org pour la liste des cours
const coursesSchema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": "Cours d'Ukulélé en Ligne",
  "description": "Formation complète pour apprendre l'ukulélé, des bases aux techniques avancées",
  "url": canonicalURL,
  "inLanguage": "fr",
  "itemListElement": ukeleleCourses.map((course, index) => ({
    "@type": "ListItem",
    "position": index + 1,
    "item": {
      "@type": "Course",
      "@id": `https://musique-facile.fr/cours/${course.slug}#course`,
      "name": course.data.title,
      "description": course.data.description,
      "provider": {
        "@type": "Organization",
        "name": "Musique Facile",
        "sameAs": "https://musique-facile.fr"
      },
      "offers": {
        "@type": "Offer",
        "price": course.data.hasCourseInstance?.offers?.price || "79.00",
        "priceCurrency": "EUR",
        "availability": "https://schema.org/InStock",
        "url": `https://musique-facile.fr/cours/${course.slug}`
      },
      "hasCourseInstance": {
        "@type": "CourseInstance",
        "courseMode": "online",
        "duration": course.data.hasCourseInstance?.duration || "P3M",
        "offers": {
          "@type": "Offer",
          "price": course.data.hasCourseInstance?.offers?.price || "79.00",
          "priceCurrency": "EUR",
          "availability": "https://schema.org/InStock"
        }
      },
      "inLanguage": "fr",
      "url": `https://musique-facile.fr/cours/${course.slug}`
    }
  }))
};

// JSON-LD pour le cours principal
// Fourchette de prix réelle des cours du hub → AggregateOffer (au lieu d'un prix unique trompeur)
const hubPrices = ukeleleCourses
  .map(c => parseFloat(c.data.hasCourseInstance?.offers?.price || "0"))
  .filter(p => p > 0);
const hubAggregateOffer = {
  "@type": "AggregateOffer",
  "priceCurrency": "EUR",
  "lowPrice": Math.min(...hubPrices).toFixed(2),
  "highPrice": Math.max(...hubPrices).toFixed(2),
  "offerCount": hubPrices.length,
  "availability": "https://schema.org/InStock"
};

const courseLDSchema = {
  "@context": "https://schema.org",
  "@type": "Course",
  "@id": "https://musique-facile.fr/cours/cours-de-ukulele#course",
  "name": "Cours d'Ukulélé en Ligne",
  "description": "Apprends l'ukulélé en ligne à ton rythme avec des cours clairs et motivants. Idéal pour débuter facilement, où tu veux, quand tu veux, sans aucune pression.",
  "provider": {
    "@type": "Organization",
    "name": "Musique Facile",
    "url": "https://musique-facile.fr"
  },
  "offers": hubAggregateOffer,
  "hasCourseInstance": {
    "@type": "CourseInstance",
    "courseMode": "online",
    "startDate": new Date().toISOString().split('T')[0],
    "endDate": new Date(new Date().setFullYear(new Date().getFullYear() + 1)).toISOString().split('T')[0],
    "location": {
      "@type": "VirtualLocation",
      "url": canonicalURL
    },
    "offers": hubAggregateOffer
  },
  "inLanguage": "fr",
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": canonicalURL
  }
};

// FAQ Schema pour la page de cours d'ukulélé
const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "L'ukulélé est-il facile à apprendre pour un adulte débutant ?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Absolument ! L'ukulélé est considéré comme l'un des instruments les plus faciles à apprendre, même pour un adulte n'ayant jamais pratiqué de musique. Son manche étroit, ses 4 cordes douces et ses accords simples permettent de jouer des chansons dès les premières semaines d'apprentissage."
      }
    },
    {
      "@type": "Question",
      "name": "Faut-il connaître le solfège pour suivre les cours ?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Non, aucune connaissance en solfège n'est nécessaire. Nos cours sont conçus pour être accessibles à tous, avec des diagrammes d'accords visuels et des tablatures intuitives. Vous apprendrez à jouer sans avoir besoin de lire une partition traditionnelle."
      }
    },
    {
      "@type": "Question",
      "name": "Quel type d'ukulélé dois-je acheter pour commencer ?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Pour débuter, nous recommandons un ukulélé soprano ou concert de qualité moyenne (entre 40€ et 80€). Ces formats sont les plus courants et parfaits pour apprendre. Nous donnons des conseils d'achat détaillés dans le premier module de notre formation pour vous aider à choisir l'instrument qui vous convient."
      }
    },
    {
      "@type": "Question",
      "name": "Combien de temps faut-il pour jouer une chanson simple ?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Avec seulement 15 minutes de pratique quotidienne, vous pourrez jouer votre première chanson complète en 1 à 2 semaines. L'ukulélé permet un apprentissage rapide et gratifiant, c'est pourquoi il est si apprécié des débutants."
      }
    },
    {
      "@type": "Question",
      "name": "Les cours sont-ils adaptés aux enfants ?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Oui, nos cours conviennent aux enfants à partir de 8 ans environ. L'ukulélé est parfait pour les jeunes grâce à sa petite taille et ses cordes douces. Nous proposons également des parcours spécifiques pour les enfants avec une pédagogie ludique et adaptée."
      }
    },
    {
      "@type": "Question",
      "name": "Puis-je suivre les leçons depuis mon téléphone ?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Tout à fait ! Notre plateforme est entièrement responsive et optimisée pour tous les appareils. Vous pouvez suivre les cours depuis votre smartphone, tablette ou ordinateur, où que vous soyez."
      }
    },
    {
      "@type": "Question",
      "name": "Y a-t-il un suivi de progression ?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Oui, notre plateforme inclut un système de suivi qui vous permet de marquer les leçons comme complétées et de visualiser votre progression. Des quiz réguliers vous aident également à vérifier vos acquis tout au long de votre parcours d'apprentissage."
      }
    },
    {
      "@type": "Question",
      "name": "Quels styles musicaux peut-on jouer à l'ukulélé ?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "L'ukulélé est extrêmement polyvalent ! Vous pourrez jouer du hawaiien bien sûr, mais aussi du pop, rock, folk, jazz, et même des morceaux classiques. Nos cours explorent différents styles pour enrichir votre répertoire et votre technique."
      }
    },
    {
      "@type": "Question",
      "name": "Les accords sont-ils expliqués pas à pas ?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Absolument ! Chaque accord est décomposé en détail, avec des gros plans sur le placement des doigts et des astuces pour faciliter la transition entre les positions. Nous avons développé une méthode progressive où chaque nouvel accord s'appuie sur ce que vous maîtrisez déjà."
      }
    },
    {
      "@type": "Question",
      "name": "Est-ce que je peux apprendre seul sans professeur ?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Oui, nos cours en ligne sont conçus pour un apprentissage autonome réussi. Les explications sont détaillées et visuelles, et vous pouvez revoir chaque leçon autant de fois que nécessaire. De plus, notre équipe est disponible par email pour répondre à vos questions si vous rencontrez des difficultés."
      }
    }
  ]
};
---

<Layout title={title} description={description} canonicalUrl={canonicalURL} robots="index, follow">
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(coursesSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(courseLDSchema)} />
  </Fragment>

  <Header />
  
    <!-- Fil d'Ariane -->
    <BreadcrumbNav 
      items={[
        { name: "Accueil", url: "/" },
        { name: "Cours", url: "/cours" },
        { name: "Cours d'Ukulélé", url: "/cours/cours-de-ukulele" }
      ]}
    />
    
    <section class="courses-hero theme-ukulele">
      <div class="hero-background" style="background-image: url('/images/cours/hero-ukulele.webp')"></div>
      <div class="hero-overlay"></div>
      <div class="container">
        <h1>Cours d'Ukulélé en Ligne</h1>
        <p class="subtitle">Apprends l'ukulélé en ligne à ton rythme avec des cours clairs et motivants. Idéal pour débuter facilement, où tu veux, quand tu veux, sans aucune pression.</p>
        <div class="hero-cta">
          <a href="#courses-list" class="cta-button">
            Découvrir nos formations
            <span class="cta-arrow">↓</span>
          </a>
        </div>
      </div>
    </section>

    <section class="courses-grid" id="courses-list">
      <div class="container">
        <h2 class="section-title">Nos Cours d'Ukulélé</h2>
        <p class="section-subtitle">Du débutant à l'expert, nous t'accompagnons à chaque étape de ton apprentissage</p>
        
        <div class="courses-wrapper">
          {ukeleleCourses.map((course, index) => (
            <article class="course-card" id={`course-${index + 1}`}>
              <a href={`/cours/${course.slug}`} class="course-link">
                <div class="course-image" style={`background-image: url(${course.data.ogImage})`}>
                  <div class="course-meta">
                    {course.data.bestSeller && (
                      <span class="best-seller-tag">
                        <span class="best-seller-icon"><Icon name="trophy" size={16} /></span>
                        Meilleure vente
                      </span>
                    )}
                  </div>
                </div>
                <div class="course-content">
                  <h2>{course.data.title}</h2>
                  <p>{course.data.description}</p>
                  <div class="course-details">
                    <span class="course-price">{course.data.hasCourseInstance?.offers?.price || "79 €"}</span>
                    <span class="course-duration">{course.data.hasCourseInstance?.duration ? `Durée: ${course.data.hasCourseInstance.duration}` : "Accès illimité"}</span>
                  </div>
                  <span class="cta-button">
                    Découvrir le cours
                    <span class="arrow">→</span>
                  </span>
                </div>
              </a>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- Section Pourquoi Apprendre l'Ukulélé en Ligne -->
    <section class="why-online">
      <div class="container">
        <h2 class="section-title">Pourquoi apprendre l'ukulélé en ligne ?</h2>
        
        <div class="benefits-grid">
          <div class="benefit-card">
            <div class="benefit-icon">🌈</div>
            <h3>Simple et joyeux</h3>
            <p>L'ukulélé est l'un des instruments les plus faciles à apprendre, avec des résultats rapides et gratifiants.</p>
          </div>
          
          <div class="benefit-card">
            <div class="benefit-icon"><Icon name="lightning" size={24} /></div>
            <h3>À ton rythme</h3>
            <p>Progresse quand tu le souhaites, revois les leçons autant que nécessaire, sans stress ni pression.</p>
          </div>
          
          <div class="benefit-card">
            <div class="benefit-icon"><Icon name="note" size={24} /></div>
            <h3>Cours visuels</h3>
            <p>Des vidéos claires qui montrent précisément le placement des doigts et les techniques de jeu.</p>
          </div>
          
          <div class="benefit-card">
            <div class="benefit-icon"><Icon name="note" size={24} /></div>
            <h3>Résultats rapides</h3>
            <p>Joue tes premières mélodies en quelques jours seulement, même sans connaissance musicale préalable.</p>
          </div>
        </div>
        
        <div class="online-learning-description">
          <p>L'ukulélé est un instrument simple, joyeux et parfait pour commencer la musique. Grâce aux cours en ligne, tu avances à ton rythme, sans stress, avec des vidéos courtes, des diagrammes clairs et des exercices faciles à suivre. Tu peux rejouer les leçons autant que tu veux et progresser quand tu as le temps. Pas besoin de lire la musique, tout est pensé pour les débutants. L'apprentissage est ludique, rapide, et te permet de jouer tes premières mélodies dès les premières sessions. C'est l'instrument idéal pour se faire plaisir et se détendre.</p>
        </div>
      </div>
    </section>

    <!-- Section FAQ -->
    <section class="faq-section">
      <div class="container">
        <h2 class="section-title">Questions fréquentes</h2>
        
        <div class="faq-grid">
          <div class="faq-item">
            <div class="question-wrapper">
              <h3>L'ukulélé est-il facile à apprendre pour un adulte débutant ?</h3>
              <div class="toggle-icon">
                <span class="plus-minus"></span>
              </div>
            </div>
            <div class="answer">
              <p>Absolument ! L'ukulélé est considéré comme l'un des instruments les plus faciles à apprendre, même pour un adulte n'ayant jamais pratiqué de musique. Son manche étroit, ses 4 cordes douces et ses accords simples permettent de jouer des chansons dès les premières semaines d'apprentissage.</p>
            </div>
          </div>
          
          <div class="faq-item">
            <div class="question-wrapper">
              <h3>Faut-il connaître le solfège pour suivre les cours ?</h3>
              <div class="toggle-icon">
                <span class="plus-minus"></span>
              </div>
            </div>
            <div class="answer">
              <p>Non, aucune connaissance en solfège n'est nécessaire. Nos cours sont conçus pour être accessibles à tous, avec des diagrammes d'accords visuels et des tablatures intuitives. Vous apprendrez à jouer sans avoir besoin de lire une partition traditionnelle.</p>
            </div>
          </div>
          
          <div class="faq-item">
            <div class="question-wrapper">
              <h3>Quel type d'ukulélé dois-je acheter pour commencer ?</h3>
              <div class="toggle-icon">
                <span class="plus-minus"></span>
              </div>
            </div>
            <div class="answer">
              <p>Pour débuter, nous recommandons un ukulélé soprano ou concert de qualité moyenne (entre 40€ et 80€). Ces formats sont les plus courants et parfaits pour apprendre. Nous donnons des conseils d'achat détaillés dans le premier module de notre formation pour vous aider à choisir l'instrument qui vous convient.</p>
            </div>
          </div>
          
          <div class="faq-item">
            <div class="question-wrapper">
              <h3>Combien de temps faut-il pour jouer une chanson simple ?</h3>
              <div class="toggle-icon">
                <span class="plus-minus"></span>
              </div>
            </div>
            <div class="answer">
              <p>Avec seulement 15 minutes de pratique quotidienne, vous pourrez jouer votre première chanson complète en 1 à 2 semaines. L'ukulélé permet un apprentissage rapide et gratifiant, c'est pourquoi il est si apprécié des débutants.</p>
            </div>
          </div>
          
          <div class="faq-item">
            <div class="question-wrapper">
              <h3>Les cours sont-ils adaptés aux enfants ?</h3>
              <div class="toggle-icon">
                <span class="plus-minus"></span>
              </div>
            </div>
            <div class="answer">
              <p>Oui, nos cours conviennent aux enfants à partir de 8 ans environ. L'ukulélé est parfait pour les jeunes grâce à sa petite taille et ses cordes douces. Nous proposons également des parcours spécifiques pour les enfants avec une pédagogie ludique et adaptée.</p>
            </div>
          </div>
          
          <div class="faq-item">
            <div class="question-wrapper">
              <h3>Puis-je suivre les leçons depuis mon téléphone ?</h3>
              <div class="toggle-icon">
                <span class="plus-minus"></span>
              </div>
            </div>
            <div class="answer">
              <p>Tout à fait ! Notre plateforme est entièrement responsive et optimisée pour tous les appareils. Vous pouvez suivre les cours depuis votre smartphone, tablette ou ordinateur, où que vous soyez.</p>
            </div>
          </div>
          
          <div class="faq-item">
            <div class="question-wrapper">
              <h3>Y a-t-il un suivi de progression ?</h3>
              <div class="toggle-icon">
                <span class="plus-minus"></span>
              </div>
            </div>
            <div class="answer">
              <p>Oui, notre plateforme inclut un système de suivi qui vous permet de marquer les leçons comme complétées et de visualiser votre progression. Des quiz réguliers vous aident également à vérifier vos acquis tout au long de votre parcours d'apprentissage.</p>
            </div>
          </div>
          
          <div class="faq-item">
            <div class="question-wrapper">
              <h3>Quels styles musicaux peut-on jouer à l'ukulélé ?</h3>
              <div class="toggle-icon">
                <span class="plus-minus"></span>
              </div>
            </div>
            <div class="answer">
              <p>L'ukulélé est extrêmement polyvalent ! Vous pourrez jouer du hawaiien bien sûr, mais aussi du pop, rock, folk, jazz, et même des morceaux classiques. Nos cours explorent différents styles pour enrichir votre répertoire et votre technique.</p>
            </div>
          </div>
          
          <div class="faq-item">
            <div class="question-wrapper">
              <h3>Les accords sont-ils expliqués pas à pas ?</h3>
              <div class="toggle-icon">
                <span class="plus-minus"></span>
              </div>
            </div>
            <div class="answer">
              <p>Absolument ! Chaque accord est décomposé en détail, avec des gros plans sur le placement des doigts et des astuces pour faciliter la transition entre les positions. Nous avons développé une méthode progressive où chaque nouvel accord s'appuie sur ce que vous maîtrisez déjà.</p>
            </div>
          </div>
          
          <div class="faq-item">
            <div class="question-wrapper">
              <h3>Est-ce que je peux apprendre seul sans professeur ?</h3>
              <div class="toggle-icon">
                <span class="plus-minus"></span>
              </div>
            </div>
            <div class="answer">
              <p>Oui, nos cours en ligne sont conçus pour un apprentissage autonome réussi. Les explications sont détaillées et visuelles, et vous pouvez revoir chaque leçon autant de fois que nécessaire. De plus, notre équipe est disponible par email pour répondre à vos questions si vous rencontrez des difficultés.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="cta-section">
      <div class="container">
        <div class="cta-content">
          <h2>Prêt à découvrir le plaisir de jouer de l'ukulélé ?</h2>
          <p>Rejoins des milliers d'élèves qui apprennent l'ukulélé avec nos cours en ligne</p>
          <a href="#courses-list" class="btn-all-courses">
            Voir nos formations d'ukulélé
            <span class="arrow">→</span>
          </a>
        </div>
      </div>
    </section>

  <FooterModern />
</Layout>

<style>
  /* Hero Section */
  .courses-hero {
    padding: 8rem 0 4rem;
    background: linear-gradient(135deg, var(--theme-ukulele) 0%, var(--theme-ukulele-dark) 100%);
    color: white;
    text-align: center;
    position: relative;
    overflow: hidden;
  }

  .hero-background {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center;
    opacity: 0.2;
    z-index: 0;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(0,0,0,0.7) 0%, rgba(0,0,0,0.5) 100%);
    z-index: 1;
  }

  .courses-hero .container {
    position: relative;
    z-index: 2;
  }

  .courses-hero h1 {
    font-size: 3.5rem;
    margin-bottom: 1rem;
    color: white;
  }

  .subtitle {
    font-size: 1.2rem;
    color: rgba(255, 255, 255, 0.9);
    max-width: 800px;
    margin: 0 auto 2rem;
    line-height: 1.6;
  }

  .hero-cta {
    margin-top: 2rem;
  }

  .cta-button {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: white;
    color: var(--theme-ukulele);
    padding: 1rem 2rem;
    border-radius: var(--border-radius);
    text-decoration: none;
    font-weight: 600;
    transition: all 0.3s ease;
    font-size: 1.1rem;
  }

  .cta-button:hover {
    transform: translateY(-3px);
    box-shadow: 0 10px 20px rgba(0, 0, 0, 0.2);
  }

  .cta-arrow {
    transition: transform 0.3s ease;
  }

  .cta-button:hover .cta-arrow {
    transform: translateY(3px);
  }

  /* Courses Section */
  .courses-grid {
    padding: 6rem 0;
    background: var(--bg-light);
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .section-title {
    text-align: center;
    font-size: 2.5rem;
    margin-bottom: 1rem;
    color: var(--theme-ukulele);
  }

  .section-subtitle {
    text-align: center;
    font-size: 1.2rem;
    color: var(--color-dark);
    opacity: 0.8;
    max-width: 800px;
    margin: 0 auto 4rem;
    line-height: 1.6;
  }

  .courses-wrapper {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
    margin-bottom: 4rem;
  }

  .course-card {
    background: #ffffff !important;
    border-radius: var(--border-radius);
    overflow: hidden;
    box-shadow: 0 4px 10px rgba(0, 0, 0, 0.1);
