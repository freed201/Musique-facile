---
import { getCollection } from 'astro:content';
import CourseLayout from '../../layouts/CourseLayout.astro';
import BreadcrumbNav from '../../components/BreadcrumbNav.astro';
import RelatedCourses from '../../components/RelatedCourses.astro';
import StickyCTAMobile from '../../components/StickyCTAMobile.astro';
import CourseTargetAudience from '../../components/CourseTargetAudience.astro';
import CourseIncludes from '../../components/CourseIncludes.astro';
import CoursePricing from '../../components/CoursePricing.astro';

export async function getStaticPaths() {
  const courses = await getCollection('courses');
  return courses.map(course => ({
    params: { slug: course.slug },
    props: { course },
  }));
}

const { course } = Astro.props;
// Récupération du slug dès le début (utilisé dans les schemas)
const { slug } = Astro.params;

// Corps markdown optionnel : rendu en section « Programme détaillé » sous la
// timeline. Les fiches sans corps (la majorité) ne rendent rien de plus.
const { Content } = await course.render();
const hasDetailedProgram = course.body.trim().length > 0;

const {
  title,
  description,
  ogImage,
  theme,
  hero,
  timeline,
  teachers,
  frustrations,
  valeurUnique,
  preuveSociale,
  benefices,
  cta,
  faq,
  ratingValue,
  reviewCount,
  transformation,
  pricing,
  targetAudience,
  courseIncludes
} = course.data;

// Schema.org Review pour les témoignages du cours
const reviewSchemas = preuveSociale.testimonials.map((testimonial, index) => ({
  "@context": "https://schema.org",
  "@type": "Review",
  "author": {
    "@type": "Person",
    "name": testimonial.author
  },
  "reviewRating": {
    "@type": "Rating",
    "ratingValue": "5",
    "bestRating": "5",
    "worstRating": "1"
  },
  "reviewBody": testimonial.text,
  "itemReviewed": {
    "@type": "Course",
    "name": title,
    "provider": {
      "@type": "Organization",
      "name": "Musique Facile"
    }
  },
  "datePublished": course.data.datePublished
}));

// Schema.org HowTo pour le programme de la formation (timeline)
const howToSchema = {
  "@context": "https://schema.org",
  "@type": "HowTo",
  "name": `Programme de la formation ${title}`,
  "description": `Découvrez le programme complet de la formation ${title} étape par étape`,
  "image": ogImage,
  "totalTime": course.data.hasCourseInstance?.duration || "PT2H",
  "step": timeline.map((item, index) => ({
    "@type": "HowToStep",
    "position": item.number,
    "name": item.title,
    "text": item.objective,
    "image": `/images/cours/${slug}/timeline-${item.number}.webp`,
    "url": `${Astro.url.toString()}#step-${item.number}`,
    "itemListElement": item.details.map((detail, detailIndex) => ({
      "@type": "HowToDirection",
      "text": detail,
      "position": detailIndex + 1
    }))
  }))
};

// Schema.org FAQPage pour les questions fréquentes du cours
const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faq.questions.map(item => ({
    "@type": "Question",
    "name": item.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": item.answer
    }
  }))
};

const offerSchema = {
  "@context": "https://schema.org",
  "@type": "Offer",
  "price": course.data.hasCourseInstance?.offers?.price || "79.00",
  "priceCurrency": course.data.hasCourseInstance?.offers?.priceCurrency || "EUR",
  "availability": course.data.hasCourseInstance?.offers?.availability || "https://schema.org/InStock",
  "url": Astro.url.toString(),
  "itemOffered": {
    "@type": "Course",
    "name": title,
    "url": Astro.url.toString()
  }
};

// Fonction utilitaire pour convertir une durée ISO 8601 en format lisible
function parseDuration(iso: string): string {
  const match = iso.match(/PT(?:(\d+)H)?(?:(\d+)M)?/);
  if (!match) return '';
  const hours = match[1] ? parseInt(match[1]) : 0;
  const minutes = match[2] ? parseInt(match[2]) : 0;
  if (hours && minutes) return `${hours}h${minutes.toString().padStart(2, '0')}`;
  if (hours) return `${hours}h`;
  if (minutes) return `${minutes}min`;
  return '';
}

const courseDuration = course.data.hasCourseInstance?.duration ? parseDuration(course.data.hasCourseInstance.duration) : '';

// Fonction utilitaire pour construire les chemins d'images
function getCoursePaths(slug: string) {
  return {
    hero: `/images/cours/${slug}/hero.webp`,
    timeline: (index: number) => `/images/cours/${slug}/timeline-${index}.webp`,
    testimonial: (index: number) => `/images/cours/${slug}/testimonial-${index}.webp`
  };
}

// Obtention des chemins d'images pour ce cours
const imagePaths = getCoursePaths(slug);

// Splitter les temoignages : premier temoignage apres le curriculum, reste apres pricing
const allTestimonials = preuveSociale.testimonials;
const firstTestimonial = allTestimonials.length > 0 ? allTestimonials[0] : null;
const remainingTestimonials = allTestimonials.length > 1 ? allTestimonials.slice(1) : [];

// Extraire le nombre de chapitres depuis hero.stats pour CourseIncludes
const chaptersFromStats = hero.stats.find(s => s.label.includes('chapitre'))?.value;

// Construire les features pour CoursePricing
const pricingFeatures = pricing?.features || cta.features.map(f => f.text);
---

<!-- Schema.org Review pour les témoignages -->
{reviewSchemas.map(schema => (
  <script type="application/ld+json" set:html={JSON.stringify(schema)} />
))}

<!-- Schema.org HowTo pour le programme -->
<script type="application/ld+json" set:html={JSON.stringify(howToSchema)} />

<!-- Schema.org FAQPage pour les questions du cours -->
<script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

<!-- Schema.org Offer pour le cours -->
<script type="application/ld+json" set:html={JSON.stringify(offerSchema)} />

<CourseLayout
  title={title}
  description={description}
  ogImage={ogImage}
  theme={theme}
  hero={hero}
  teachers={teachers}
  datePublished={course.data.datePublished}
  dateModified={course.data.dateModified}
  educationalLevel={course.data.educationalLevel}
  courseMode={course.data.courseMode}
  hasCourseInstance={course.data.hasCourseInstance}
  ratingValue={ratingValue}
  reviewCount={reviewCount}
>
  <BreadcrumbNav
    items={[
      { name: "Accueil", url: "/" },
      { name: "Cours", url: "/cours/" },
      { name: title, url: Astro.url.pathname }
    ]}
  />

<section class="hero">
<div class="hero-background" style={`background-image: url('${imagePaths.hero}')`}>
    <div class="gradient-overlay"></div>
  </div>
    <div class="container">
      <div class="hero-content">
        <div class="hero-text">
          <span class="hero-badge">{hero.badge}</span>
          <h1>
            <span class="visually-hidden"></span>
            {hero.title}
          </h1>
          <p class="hero-subtitle">
            {hero.subtitle}
          </p>
          <div class="cta-group">
            <a href={cta.buttonLink} class="btn btn-primary btn-lg pulsing">
              {hero.cta.text}
              <span class="price-tag">{hero.cta.price}</span>
            </a>
            <div class="hero-guarantee">
              <span class="guarantee-icon">🛡️</span>
              <span class="guarantee-text">Satisfait ou remboursé 15 jours</span>
            </div>
          </div>
        </div>
        <div class="hero-video">
<div class="video-wrapper">
  <div style="padding:56.25% 0 0 0;position:relative;">
    <iframe 
      src={`https://player.vimeo.com/video/${hero.video.id}?title=0&byline=0&portrait=0&badge=0&autopause=0&player_id=0&app_id=58479`}
      frameborder="0" 
      allow="autoplay; fullscreen; picture-in-picture; clipboard-write; encrypted-media" 
      style="position:absolute;top:0;left:0;width:100%;height:100%;"
      title={title}
    ></iframe>
  </div>
  <script src="https://player.vimeo.com/api/player.js"></script>
</div>
          <div class="course-stats">
            {hero.stats.map(stat => (
              <div class="stat-item">
                <span class="stat-icon">{stat.icon}</span>
                <div class="stat-content">
                  <span class="stat-value">{stat.value}</span>
                  <span class="stat-label">{stat.label}</span>
                </div>
              </div>
            ))}
            {courseDuration && (
              <div class="stat-item">
                <span class="stat-icon">🕐</span>
                <div class="stat-content">
                  <span class="stat-value">{courseDuration}</span>
                  <span class="stat-label">de contenu</span>
                </div>
              </div>
            )}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- SECTION 2 : Pour qui (decision-first) -->
  <CourseTargetAudience items={targetAudience} theme={theme} />

  <!-- SECTION 3 : Frustrations (pain points) -->
  <section class="frustrations">
    <div class="container">
      <h2 class="frustrations-title">{frustrations.title}</h2>

      <div class="frustrations-grid">
        {frustrations.items.map(item => (
          <div class="frustration-card">
            <span class="frustration-icon">{item.icon}</span>
            <p class="frustration-text">{item.text}</p>
          </div>
        ))}
      </div>

      <div class="solution-banner">
        <p class="solution-text">{frustrations.solution}</p>
      </div>
    </div>
  </section>

  <!-- SECTION 4 : Valeur Unique -->
  <section class="valeur-unique">
    <div class="container">
      <div class="valeur-unique-content">
        <h2>{valeurUnique.title}</h2>
        <p class="description">{valeurUnique.description}</p>

        <div class="avantages-grid">
          {valeurUnique.avantages.map(avantage => (
            <div class="avantage-card">
              <span class="avantage-icon">{avantage.icon}</span>
              <p class="avantage-text">{avantage.text}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

<section class="timeline">
  <div class="container">
    <h2 class="timeline-title">Programme de la formation</h2>
    <div class="timeline-wrapper">
      {timeline.map((item) => {
        // Construire le chemin de l'image de timeline de manière dynamique
        const timelineImagePath = `/images/cours/${Astro.params.slug}/timeline-${item.number}.webp`;
        
        return (
          <div class="timeline-item" data-timeline-index={item.number}>
            <div class="timeline-number">{item.number}</div>
            <div class="timeline-content">
              <div class="timeline-header">
                <h3>{item.title}</h3>
                <p class="timeline-objective">{item.objective}</p>
              </div>
              <div class="timeline-body">
                <div class="timeline-image-wrapper">
                  <img 
                    src={timelineImagePath}
                    alt={`${item.title} - ${item.objective}`}
                    class="timeline-image"
                    data-modal={`modal-${item.number}`}
                    loading="lazy"
                  />
                </div>
                <ul class="timeline-details">
                  {item.details.map((detail) => (
                    <li>{detail}</li>
                  ))}
                </ul>
              </div>
            </div>
          </div>
        );
      })}
    </div>
    <div class="program-button-wrapper">
      <a href={`/cours/programme/${Astro.params.slug}/`} class="btn btn-program">
        Découvre le programme complet de la formation !
        <span class="arrow">→</span>
      </a>
    </div>
  </div>
</section>

{hasDetailedProgram && (
  <section class="course-detail">
    <div class="container">
      <div class="course-detail-content">
        <Content />
      </div>
    </div>
  </section>
)}

<section class="mid-cta">
  <div class="container">
    <div class="mid-cta-content">
      <p class="mid-cta-text">Prêt à vous lancer ? Rejoignez les {preuveSociale.stats.students} élèves qui ont franchi le pas.</p>
      <a href={cta.buttonLink} class="btn btn-primary btn-lg pulsing">
        {cta.buttonText}
      </a>
      <span class="mid-cta-guarantee">🛡️ Satisfait ou remboursé 15 jours</span>
    </div>
  </div>
</section>

<!-- Modals pour les images -->
{timeline.map((item) => {
  const timelineImagePath = `/images/cours/${Astro.params.slug}/timeline-${item.number}.webp`;
  
  return (
    <div id={`modal-${item.number}`} class="modal">
      <div class="modal-content">
        <span class="close-modal">&times;</span>
        <img 
          src={timelineImagePath} 
          alt={`${item.title} - Vue détaillée`}
          loading="lazy"
        />
      </div>
    </div>
  );
})}

<!-- SECTION 6 : Temoignage #1 (preuve sociale precoce) -->
{firstTestimonial && (
  <section class="testimonial-highlight">
    <div class="container">
      <div class="testimonial-highlight-card">
        <div class="quote-icon">&#10077;</div>
        <p class="testimonial-highlight-text">{firstTestimonial.text}</p>
        <div class="testimonial-highlight-author">
          <img
            src={`/images/cours/${Astro.params.slug}/testimonial-1.webp`}
            alt={`Photo de ${firstTestimonial.author}`}
            loading="lazy"
            width="56"
            height="56"
          />
          <span>{firstTestimonial.author}</span>
        </div>
      </div>
    </div>
  </section>
)}

<!-- SECTION 7 : Ce que vous obtenez -->
<CourseIncludes
  courseIncludes={courseIncludes}
  chapters={chaptersFromStats}
  duration={courseDuration}
  pricingFeatures={pricingFeatures}
/>

<!-- SECTION 8 : Prix + Garantie (composant dedie) -->
<CoursePricing
  title={pricing?.title || "Investissez dans votre passion"}
  price={course.data.hasCourseInstance?.offers?.price || "79"}
  currency={course.data.hasCourseInstance?.offers?.priceCurrency || "EUR"}
  installment={hero.cta.price}
  features={pricingFeatures}
  guarantee={pricing?.guarantee || "Garantie satisfait ou rembourse 15 jours"}
  ctaText={cta.buttonText}
  ctaLink={cta.buttonLink}
  accessLabel="Paiement unique - Acces a vie"
/>

<!-- SECTION 9 : Professeur -->
<section class="teachers-section">
  <div class="container">
    <div class="section-title-wrapper">
      <h2 class="teachers-title">
        {teachers.mainTeachers.length === 1 && (!teachers.guests || teachers.guests.length === 0) ?
          "Votre professeur" :
          "L'equipe pedagogique"
        }
      </h2>
    </div>

    <div class="main-teachers">
      {teachers.mainTeachers.map(teacher => (
        <div class="teacher-card">
          <div class="teacher-header">
            <div class="teacher-photo">
              <img
                src={`/images/prof/${teacher.photo}`}
                alt={`${teacher.firstName} ${teacher.lastName}`}
                loading="lazy"
              />
            </div>
            <div class="teacher-identity">
              <h3>{teacher.firstName} <span class="last-name">{teacher.lastName}</span></h3>
              <p class="teacher-role">{teacher.subtitle}</p>
            </div>
          </div>
          <p class="teacher-description">{teacher.description}</p>
          {teacher.credentials && teacher.credentials.length > 0 && (
            <div class="teacher-credentials">
              {teacher.credentials.map(credential => (
                <span class="credential-badge">{credential}</span>
              ))}
            </div>
          )}
          {teacher.website && (
            <a href={teacher.website} class="teacher-website" target="_blank" rel="noopener noreferrer">
              Voir le site web &rarr;
            </a>
          )}
        </div>
      ))}
    </div>

    {teachers.guests && teachers.guests.length > 0 && (
      <div class="guest-teachers">
        <h3 class="guests-title">Professeurs invites</h3>
        <div class="guests-grid">
          {teachers.guests.map(guest => (
            <div class="guest-card">
              <div class="guest-photo">
                <img
                  src={`/images/prof/${guest.photo}`}
                  alt={guest.name}
                  loading="lazy"
                />
              </div>
              <h4>{guest.name}</h4>
              <p class="guest-role">{guest.subtitle}</p>
              {guest.website && (
                <a href={guest.website} class="guest-link" target="_blank" rel="noopener noreferrer">
                  En savoir plus &rarr;
                </a>
              )}
            </div>
          ))}
        </div>
      </div>
    )}
  </div>
</section>

<!-- SECTION 10 : Transformation Avant/Apres -->
{transformation && (
<section class="transformation-section">
  <div class="container">
    <h2 class="transformation-title">{transformation.title}</h2>
    <div class="transformation-grid">
      {transformation.items.map(item => (
        <div class="transformation-card">
          <div class="transformation-before">
            <span class="transformation-label transformation-label-before">Avant</span>
            <p>{item.before}</p>
          </div>
          <div class="transformation-arrow">
            <span class="arrow-desktop">&rarr;</span>
            <span class="arrow-mobile">&darr;</span>
          </div>
          <div class="transformation-after">
            <span class="transformation-label transformation-label-after">Apres</span>
            <p>{item.after}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
)}

<!-- SECTION 11 : Temoignages restants + stats + partenaires -->
{remainingTestimonials.length > 0 && (
<section class="preuve-sociale">
  <div class="container">
    <div class="testimonials-wrapper" role="region" aria-label="Temoignages">
      {remainingTestimonials.map((testimonial, index) => {
        const testimonialImagePath = `/images/cours/${Astro.params.slug}/testimonial-${index + 2}.webp`;

        return (
          <div class="testimonial">
            <div class="quote-icon">&#10077;</div>
            <p class="testimonial-text">{testimonial.text}</p>
            <div class="testimonial-author">
              <img
                src={testimonialImagePath}
                alt={`Photo de ${testimonial.author}`}
                loading="lazy"
                width="50"
                height="50"
              />
              <span>{testimonial.author}</span>
            </div>
          </div>
        );
      })}
    </div>

    <div class="stats-banner">
      <div class="stat">
        <span class="stat-number">{preuveSociale.stats.students}</span>
        <span class="stat-label">élèves satisfaits</span>
      </div>
      <div class="stat-divider"></div>
      <div class="stat">
        <span class="stat-number">{preuveSociale.stats.successRate}</span>
        <span class="stat-label">{preuveSociale.stats.timeframe}</span>
      </div>
    </div>

    <div class="partners">
      <h3>Ils nous font confiance</h3>
      <div class="partners-grid">
        {preuveSociale.partners.map(partner => (
          <div class="partner">
            <a
              href={partner.buttonLink}
              target="_blank"
              rel="noopener noreferrer"
              class="partner-link"
            >
              <img
                src={`/images/logo/${partner.logo}`}
                alt={`Logo de ${partner.name}`}
                loading="lazy"
              />
            </a>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
)}

<!-- SECTION 12 : Benefices -->
  <section class="benefices">
    <div class="container">
      <h2 class="benefices-title">{benefices.title}</h2>

      <div class="benefices-grid">
        {benefices.items.map((benefice, index) => (
          <div class="benefice-card" style={`--delay: ${index * 0.2}s`}>
            <div class="benefice-icon-wrapper">
              <span class="benefice-icon">{benefice.icon}</span>
            </div>
            <h3>{benefice.title}</h3>
            <p>{benefice.description}</p>
            <div class="card-decoration"></div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="cta-final">
    <div class="cta-background"></div>
    <div class="container">
      <div class="cta-content">
        <h2 class="cta-title">{cta.title}</h2>
        <p class="cta-subtitle">{cta.subtitle}</p>
        
        <div class="cta-features">
          {cta.features.map(feature => (
            <div class="cta-feature">
              <span class="feature-icon">{feature.icon}</span>
              <span class="feature-text">{feature.text}</span>
            </div>
          ))}
        </div>

        <a href={cta.buttonLink} class="cta-button">
          {cta.buttonText}
          <span class="button-shine"></span>
        </a>
      </div>
    </div>
  </section>

  <section class="faq-section">
    <div class="faq-background"></div>
    <div class="container">
      <div class="faq-header">
        <h2>{faq.title}</h2>
        <p>{faq.subtitle}</p>
      </div>

      <div class="faq-grid">
        {faq.questions.map((item, index) => (
          <div class={`faq-item cours-faq-slide cours-faq-slide--${index % 2 === 0 ? 'right' : 'left'}`} style={`--delay: ${index * 0.2}s`}>
            <div class="faq-question-wrapper">
              <h3>{item.question}</h3>
              <div class="faq-icon">
                <span class="icon-line"></span>
                <span class="icon-line"></span>
              </div>
            </div>
            <div class="faq-answer">
              <p>{item.answer}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <RelatedCourses
    currentSlug={slug}
    currentTheme={theme}
    maxCourses={3}
  />

  <StickyCTAMobile
    ctaLink={cta.buttonLink}
    ctaText={cta.buttonText}
    title="Prêt à vous lancer ?"
    subtitle="Satisfait ou remboursé 15 jours"
  />
</CourseLayout>

<style>
  .teachers-section {
    padding: 6rem 0;
    background: var(--theme-current);
    color: white;
    position: relative;
    overflow: hidden;
  }

  .teachers-section::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23ffffff' fill-opacity='0.05'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");
    opacity: 0.1;
  }

  .section-title-wrapper {
    text-align: center;
    margin-bottom: 3rem;
  }

  .teachers-title {
    font-size: 2.5rem;
    color: white;
    margin-bottom: 1rem;
    text-shadow: 0 2px 4px rgba(0, 0, 0, 0.2);
  }

  .main-teachers {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 2rem;
    max-width: 1000px;
    margin: 0 auto;
  }

  .teacher-card {
    background: rgba(255, 255, 255, 0.1);
    border-radius: var(--border-radius);
    padding: 1.5rem;
    backdrop-filter: blur(10px);
    border: 1px solid rgba(255, 255, 255, 0.2);
