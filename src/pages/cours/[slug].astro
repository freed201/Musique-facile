/* Timeline parallax horizontal */
.timeline-item {
  transition: opacity 0.6s ease, transform 0.6s ease;
}

.timeline-item.tl-hidden {
  opacity: 0;
}

.timeline-item.tl-hidden[data-timeline-index="1"],
.timeline-item.tl-hidden[data-timeline-index="3"] {
  transform: translateX(-40px);
}

.timeline-item.tl-hidden[data-timeline-index="2"],
.timeline-item.tl-hidden[data-timeline-index="4"] {
  transform: translateX(40px);
}

.timeline-item.tl-visible {
  opacity: 1;
  transform: translateX(0);
}

@media (prefers-reduced-motion: reduce) {
  .timeline-item.tl-hidden {
    opacity: 1;
    transform: none;
  }
}

@media (max-width: 768px) {
  .timeline-item.tl-hidden[data-timeline-index="1"],
  .timeline-item.tl-hidden[data-timeline-index="3"] {
    transform: translateX(-20px);
  }
  .timeline-item.tl-hidden[data-timeline-index="2"],
  .timeline-item.tl-hidden[data-timeline-index="4"] {
    transform: translateX(20px);
  }
}

</style>

<script>
  // Parallax gauche-droite sur les étapes du programme
  (function() {
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

    const items = document.querySelectorAll('.timeline-item[data-timeline-index]');
    if (!items.length) return;

    // Cacher initialement
    items.forEach(item => item.classList.add('tl-hidden'));

    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          const idx = parseInt(entry.target.dataset.timelineIndex) || 1;
          // Délai stagger basé sur l'index
          setTimeout(() => {
            entry.target.classList.remove('tl-hidden');
            entry.target.classList.add('tl-visible');
          }, (idx - 1) * 150);
          observer.unobserve(entry.target);
        }
      });
    }, {
      threshold: 0.15,
      rootMargin: '0px 0px -50px 0px'
    });

    items.forEach(item => observer.observe(item));
  })();

  // Animation droite-gauche sur la FAQ cours
  (function() {
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

    const items = document.querySelectorAll('.cours-faq-slide');
    if (!items.length) return;

    items.forEach(item => {
      item.style.opacity = '0';
      item.style.transition = 'opacity 0.6s ease, transform 0.6s ease';
      if (item.classList.contains('cours-faq-slide--left')) {
        item.style.transform = 'translateX(-40px)';
      } else {
        item.style.transform = 'translateX(40px)';
      }
    });

    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (!entry.isIntersecting) return;
        const siblings = Array.from(entry.target.parentElement.querySelectorAll('.cours-faq-slide'));
        const idx = siblings.indexOf(entry.target);
        setTimeout(() => {
          entry.target.style.opacity = '1';
          entry.target.style.transform = 'translateX(0)';
        }, idx * 120);
        observer.unobserve(entry.target);
      });
    }, { threshold: 0.1, rootMargin: '0px 0px -40px 0px' });

    items.forEach(item => observer.observe(item));
  })();

  // Animation slide-in sur toutes les cards des pages cours
  (function() {
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

    const cardSelectors = [
      '.frustration-card',
      '.avantage-card',
      '.include-card',
      '.transformation-card',
      '.teacher-card',
      '.guest-card',
      '.testimonial-card',
      '.related-card',
      '.faq-item'
    ];

    const allCards = document.querySelectorAll(cardSelectors.join(','));
    if (!allCards.length) return;

    // Préparer : cacher + position initiale
    allCards.forEach((card, i) => {
      card.style.opacity = '0';
      card.style.transition = 'opacity 0.5s ease, transform 0.5s ease';
      card.style.transitionDelay = '0ms';
      // Alterner gauche/droite
      if (i % 2 === 0) {
        card.style.transform = 'translateX(-30px)';
      } else {
        card.style.transform = 'translateX(30px)';
      }
    });

    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (!entry.isIntersecting) return;

        const card = entry.target;
        // Trouver les siblings dans le même parent pour le stagger
        const parent = card.parentElement;
        const siblings = parent ? Array.from(parent.querySelectorAll(cardSelectors.join(','))) : [card];
        const indexInParent = siblings.indexOf(card);
        const delay = Math.max(0, indexInParent) * 100;

        card.style.transitionDelay = `${delay}ms`;
        card.style.opacity = '1';
        card.style.transform = 'translateX(0)';
        observer.unobserve(card);
      });
    }, {
      threshold: 0.08,
      rootMargin: '0px 0px -30px 0px'
    });

    allCards.forEach(card => observer.observe(card));
  })();
</script>
