---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import FooterModern from '../../components/FooterModern.astro';
import Icon from '../../components/Icon.astro';
import { getCollection } from 'astro:content';
import CoursesComparison from '../../components/CoursesComparison.astro';
import AuthorBio from '../../components/AuthorBio.astro';
import BreadcrumbNav from '../../components/BreadcrumbNav.astro';

// Récupérer uniquement les cours de piano
const allCourses = await getCollection('courses');
const pianoCourses = allCourses
  .filter(course => course.data.theme === 'piano' && course.data.affichage === 'Y')
  .sort((a, b) => a.data.classement - b.data.classement);

// Construction de l'URL canonique
const canonicalURL = new URL(Astro.url.pathname, Astro.site || 'https://musique-facile.fr').toString();

// Métadonnées pour la page
const title = "Cours de Piano en Ligne | Musique Facile";
const description = "Maîtrisez le piano avec Fred Fieffé : 350+ leçons vidéo HD, méthode progressive, accords, lecture de partitions et techniques. 80 000+ élèves formés depuis 2015. Satisfait ou remboursé sous 15 jours.";

// Schema.org pour le fil d'Ariane
const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Accueil",
      "item": "https://musique-facile.fr/"
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": "Cours",
      "item": "https://musique-facile.fr/cours/"
    },
    {
      "@type": "ListItem",
      "position": 3,
      "name": "Cours de Piano",
      "item": canonicalURL
    }
  ]
};

// Schema.org pour la liste des cours
const coursesSchema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": "Cours de Piano en Ligne",
  "description": "Formation complète pour apprendre le piano, des bases aux techniques avancées",
  "url": canonicalURL,
  "inLanguage": "fr",
  "itemListElement": pianoCourses.map((course, index) => ({
    "@type": "ListItem",
    "position": index + 1,
    "item": {
      "@type": "Course",
      "@id": `https://musique-facile.fr/cours/${course.slug}#course`,
      "name": course.data.title,
      "description": course.data.description,
      "provider": {
        "@type": "Organization",
        "name": "Musique Facile",
        "sameAs": "https://musique-facile.fr"
      },
      "offers": {
        "category": course.data.category || "Cours de musique",
        "@type": "Offer",
        "price": course.data.hasCourseInstance?.offers?.price || "79.00",
        "priceCurrency": "EUR",
        "availability": "https://schema.org/InStock",
        "url": `https://musique-facile.fr/cours/${course.slug}`
      },
      "hasCourseInstance": {
        "@type": "CourseInstance",
        "courseMode": "online",
        "duration": course.data.hasCourseInstance?.duration || "P3M",
        "courseWorkload": course.data.hasCourseInstance?.courseWorkload || "PT2H",  // <= nouvelle ligne
        "offers": {
          "@type": "Offer",
          "category": course.data.category || "Cours de musique",  // <= nouvelle ligne
          "price": course.data.hasCourseInstance?.offers?.price || "79.00",
          "priceCurrency": "EUR",
          "availability": "https://schema.org/InStock"
        }
      },
      "inLanguage": "fr",
      "url": `https://musique-facile.fr/cours/${course.slug}`
    }
  }))
};

// JSON-LD pour le cours principal
// Fourchette de prix réelle des cours du hub → AggregateOffer (au lieu d'un prix unique trompeur)
const hubPrices = pianoCourses
  .map(c => parseFloat(c.data.hasCourseInstance?.offers?.price || "0"))
  .filter(p => p > 0);
const hubAggregateOffer = {
  "@type": "AggregateOffer",
  "priceCurrency": "EUR",
  "lowPrice": Math.min(...hubPrices).toFixed(2),
  "highPrice": Math.max(...hubPrices).toFixed(2),
  "offerCount": hubPrices.length,
  "availability": "https://schema.org/InStock"
};

const courseLDSchema = {
  "@context": "https://schema.org",
  "@type": "Course",
  "@id": "https://musique-facile.fr/cours/cours-de-piano/#course",
  "name": "Cours de Piano en Ligne",
  "description": "Maîtrisez le piano grâce à nos cours en ligne accessibles à tous. Apprenez à jouer vos morceaux préférés avec des leçons claires et des exercices adaptés à votre niveau.",
  "provider": {
    "@type": "Organization",
    "name": "Musique Facile",
    "url": "https://musique-facile.fr"
  },
  "offers": hubAggregateOffer,
  "hasCourseInstance": {
    "@type": "CourseInstance",
    "courseMode": "online",
    "startDate": new Date().toISOString().split('T')[0],
    "endDate": new Date(new Date().setFullYear(new Date().getFullYear() + 1)).toISOString().split('T')[0],
    "courseWorkload": "PT2H",  // ou mets un planning complet avec courseSchedule
    "location": {
      "@type": "VirtualLocation",
      "url": canonicalURL
    },
    "offers": hubAggregateOffer
  },
  "inLanguage": "fr",
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": canonicalURL
  }
};

// FAQ Schema pour la page de cours de piano
const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Les cours de piano en ligne sont-ils adaptés aux débutants ?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Tout à fait ! Nos cours commencent au niveau débutant complet. Nous expliquons chaque notion clairement : position des mains, notes sur le clavier, premiers exercices... Vous n'avez besoin d'aucune connaissance préalable pour débuter."
      }
    },
    {
      "@type": "Question",
      "name": "Ai-je besoin d'un piano acoustique ou un clavier suffit-il ?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Un clavier numérique de 61 touches minimum est suffisant pour commencer. L'idéal est d'avoir un piano numérique avec 88 touches et des touches lestées, mais ce n'est pas indispensable pour débuter. Nous donnons des conseils pour choisir le bon instrument selon votre budget et vos objectifs."
      }
    },
    {
      "@type": "Question",
      "name": "Comment sont structurées les leçons ?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Nos leçons sont organisées par modules progressifs avec des vidéos explicatives filmées sous plusieurs angles pour voir clairement les mouvements des mains. Chaque concept est décomposé pas à pas, suivi d'exercices pratiques et de morceaux adaptés pour appliquer les techniques apprises."
      }
    },
    {
      "@type": "Question",
      "name": "Puis-je apprendre à lire des partitions ?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Oui, nous proposons un apprentissage progressif de la lecture de partitions. Mais rassurez-vous : nos méthodes permettent aussi de jouer rapidement sans nécessairement maîtriser le solfège dès le départ. Vous apprendrez la lecture au fur et à mesure de votre progression."
      }
    },
    {
      "@type": "Question",
      "name": "Y a-t-il des exercices pour améliorer la coordination des mains ?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Absolument ! Nous proposons de nombreux exercices spécifiques pour développer la coordination des deux mains, l'indépendance des doigts et la fluidité de jeu. Ces exercices sont présentés de façon progressive pour vous permettre de gagner en aisance étape par étape."
      }
    },
    {
      "@type": "Question",
      "name": "Les cours couvrent-ils différents styles musicaux ?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Oui, nos formations abordent une variété de styles : classique, pop, jazz, blues... Vous découvrirez différentes techniques d'interprétation et d'improvisation adaptées à chaque genre musical. Cela vous permet de développer une palette d'expression riche et variée."
      }
    },
    {
      "@type": "Question",
      "name": "Puis-je suivre les cours sur mobile ou tablette ?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Oui, notre plateforme est entièrement responsive. Vous pouvez accéder à vos cours depuis n'importe quel appareil : ordinateur, tablette ou smartphone. Idéal pour pratiquer où que vous soyez, directement à côté de votre piano."
      }
    },
    {
      "@type": "Question",
      "name": "Combien de temps faut-il pour jouer une chanson complète ?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Dès les premières semaines de pratique, vous serez capable de jouer des versions simplifiées de morceaux connus. Avec 15-20 minutes de pratique quotidienne, la plupart des élèves parviennent à jouer leur première chanson complète en 3 à 4 semaines."
      }
    },
    {
      "@type": "Question",
      "name": "Y a-t-il un support en cas de questions ?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Oui, vous pouvez envoyer vos questions par email et recevoir une réponse personnalisée de nos professeurs dans un délai de 24 à 48h. Certaines formations incluent également l'accès à un groupe privé où vous pouvez échanger avec d'autres élèves et nos formateurs."
      }
    },
    {
      "@type": "Question",
      "name": "Les cours incluent-ils des morceaux célèbres à apprendre ?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Bien sûr ! Nos cours intègrent des arrangements adaptés de morceaux connus, classiques et modernes. Ces morceaux sont proposés avec différents niveaux de difficulté pour que vous puissiez progresser tout en prenant du plaisir à jouer des mélodies que vous aimez."
      }
    }
  ]
};
---

<Layout title={title} description={description} canonicalUrl={canonicalURL} robots="index, follow">
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(coursesSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(courseLDSchema)} />
  </Fragment>

  <Header />
  
    <!-- Fil d'Ariane -->
    <BreadcrumbNav 
      items={[
        { name: "Accueil", url: "/" },
        { name: "Cours", url: "/cours/" },
        { name: "Cours de Piano", url: "/cours/cours-de-piano/" }
      ]}
    />
    
    <section class="courses-hero theme-piano">
      <div class="hero-background" style="background-image: url('/images/cours/hero-piano.webp')"></div>
      <div class="hero-overlay"></div>
      <div class="container">
        <h1>Cours de Piano en Ligne</h1>
        <p class="subtitle">Maîtrisez le piano grâce à nos cours en ligne accessibles à tous. Apprenez à jouer vos morceaux préférés avec des leçons claires et des exercices adaptés à votre niveau.</p>
        <div class="hero-cta">
          <a href="#courses-list" class="cta-button">
            Découvrir nos formations
            <span class="cta-arrow">↓</span>
          </a>
        </div>
      </div>
    </section>

    <CoursesComparison courses={pianoCourses} instrument="piano" />

    <section class="courses-grid" id="courses-list">
      <div class="container">
        <h2 class="section-title">Nos Cours de Piano</h2>
        <p class="section-subtitle">Du débutant à l'expert, nous vous accompagnons à chaque étape de votre apprentissage</p>
        
        <div class="courses-wrapper">
          {pianoCourses.map((course, index) => (
            <article class="course-card" id={`course-${index + 1}`}>
              <a href={`/cours/${course.slug}/`} class="course-link">
                <div class="course-image" style={`background-image: url(${course.data.ogImage})`}>
                  <div class="course-meta">
                    {course.data.bestSeller && (
                      <span class="best-seller-tag">
                        <span class="best-seller-icon"><Icon name="trophy" size={16} /></span>
                        Meilleure vente
                      </span>
                    )}
                  </div>
                </div>
                <div class="course-content">
                  <h2>{course.data.title}</h2>
                  <p>{course.data.description}</p>
                  <div class="course-details">
                    <span class="course-price">{course.data.hasCourseInstance?.offers?.price || "79 €"}</span>
                    <span class="course-duration">{course.data.hasCourseInstance?.duration ? `Durée: ${course.data.hasCourseInstance.duration}` : "Accès illimité"}</span>
                  </div>
                  <span class="cta-button">
                    Découvrir le cours
                    <span class="arrow">→</span>
                  </span>
                </div>
              </a>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- Section Pourquoi Apprendre le Piano en Ligne -->
    <section class="why-online">
      <div class="container">
        <h2 class="section-title">Pourquoi apprendre le piano en ligne ?</h2>
        
        <div class="benefits-grid">
          <div class="benefit-card">
            <div class="benefit-icon"><Icon name="lightning" size={24} /></div>
            <h3>Flexibilité d'apprentissage</h3>
            <p>Apprenez à votre rythme, quand vous le souhaitez, sans contraintes d'horaires ni de déplacements.</p>
          </div>
          
          <div class="benefit-card">
            <div class="benefit-icon"><Icon name="target" size={24} /></div>
            <h3>Progression personnalisée</h3>
            <p>Suivez un parcours adapté à votre niveau, des bases aux techniques avancées, avec des objectifs clairs.</p>
          </div>
          
          <div class="benefit-card">
            <div class="benefit-icon"><Icon name="note" size={24} /></div>
            <h3>Vidéos multi-angles</h3>
            <p>Visualisez clairement le jeu des deux mains grâce à nos vidéos filmées sous différentes perspectives.</p>
          </div>
          
          <div class="benefit-card">
            <div class="benefit-icon">📝</div>
            <h3>Ressources complètes</h3>
            <p>Accédez à des partitions, exercices interactifs et morceaux adaptés pour consolider chaque notion.</p>
          </div>
        </div>
        
        <div class="online-learning-description">
          <p>Apprendre le piano en ligne vous permet de progresser à votre rythme, sans contrainte d'horaire ou de déplacement. Nos cours sont conçus pour les débutants comme pour les pianistes avancés, avec des vidéos explicatives, des partitions et des exercices interactifs. Vous bénéficiez d'un accompagnement personnalisé et de ressources variées pour améliorer votre technique et votre musicalité. Rejoignez notre plateforme et découvrez le plaisir de jouer du piano depuis chez vous.</p>
        </div>
      </div>
    </section>

    <!-- Section des exercices populaires -->
    <section class="popular-exercises">
      <div class="container">
        <h2 class="section-title">Exercices et techniques pour piano</h2>
        <p class="section-subtitle">Améliorez votre technique pianistique avec nos exercices spécialisés</p>
        
        <div class="exercises-grid">
          <div class="exercise-card">
            <h3>Maîtrise Digitale</h3>
            <p>Renforcez le contrôle et l'agilité de vos doigts avec nos 5 exercices essentiels.</p>
            <a href="/cours/cours-exercices-techniques-piano/" class="exercise-link">
              Découvrir les exercices <span>→</span>
            </a>
          </div>
          
          <div class="exercise-card">
            <h3>L'Art des Accords</h3>
            <p>Apprenez à jouer, comprendre et utiliser les accords au piano efficacement.</p>
            <a href="/cours/apprendre-les-accords-piano/" class="exercise-link">
              Explorer les accords <span>→</span>
            </a>
          </div>
          
          <div class="exercise-card">
            <h3>Oreille Musicale</h3>
            <p>Développez votre écoute pour enrichir votre jeu et votre expression musicale.</p>
            <a href="/cours/ameliorer-oreille-piano/" class="exercise-link">
              Améliorer votre oreille <span>→</span>
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- Section FAQ -->
    <section class="faq-section">
      <div class="container">
        <h2 class="section-title">Questions fréquentes</h2>
        
        <div class="faq-grid">
          <div class="faq-item">
            <div class="question-wrapper">
              <h3>Les cours de piano en ligne sont-ils adaptés aux débutants ?</h3>
              <div class="toggle-icon">
                <span class="plus-minus"></span>
              </div>
            </div>
            <div class="answer">
              <p>Tout à fait ! Nos cours commencent au niveau débutant complet. Nous expliquons chaque notion clairement : position des mains, notes sur le clavier, premiers exercices... Vous n'avez besoin d'aucune connaissance préalable pour débuter.</p>
            </div>
          </div>
          
          <div class="faq-item">
            <div class="question-wrapper">
              <h3>Ai-je besoin d'un piano acoustique ou un clavier suffit-il ?</h3>
              <div class="toggle-icon">
                <span class="plus-minus"></span>
              </div>
            </div>
            <div class="answer">
              <p>Un clavier numérique de 61 touches minimum est suffisant pour commencer. L'idéal est d'avoir un piano numérique avec 88 touches et des touches lestées, mais ce n'est pas indispensable pour débuter. Nous donnons des conseils pour choisir le bon instrument selon votre budget et vos objectifs.</p>
            </div>
          </div>
          
          <div class="faq-item">
            <div class="question-wrapper">
              <h3>Comment sont structurées les leçons ?</h3>
              <div class="toggle-icon">
                <span class="plus-minus"></span>
              </div>
            </div>
            <div class="answer">
              <p>Nos leçons sont organisées par modules progressifs avec des vidéos explicatives filmées sous plusieurs angles pour voir clairement les mouvements des mains. Chaque concept est décomposé pas à pas, suivi d'exercices pratiques et de morceaux adaptés pour appliquer les techniques apprises.</p>
            </div>
          </div>
          
          <div class="faq-item">
            <div class="question-wrapper">
              <h3>Puis-je apprendre à lire des partitions ?</h3>
              <div class="toggle-icon">
                <span class="plus-minus"></span>
              </div>
            </div>
            <div class="answer">
              <p>Oui, nous proposons un apprentissage progressif de la lecture de partitions. Mais rassurez-vous : nos méthodes permettent aussi de jouer rapidement sans nécessairement maîtriser le solfège dès le départ. Vous apprendrez la lecture au fur et à mesure de votre progression.</p>
            </div>
          </div>
          
          <div class="faq-item">
            <div class="question-wrapper">
              <h3>Y a-t-il des exercices pour améliorer la coordination des mains ?</h3>
              <div class="toggle-icon">
                <span class="plus-minus"></span>
              </div>
            </div>
            <div class="answer">
              <p>Absolument ! Nous proposons de nombreux exercices spécifiques pour développer la coordination des deux mains, l'indépendance des doigts et la fluidité de jeu. Ces exercices sont présentés de façon progressive pour vous permettre de gagner en aisance étape par étape.</p>
            </div>
          </div>
          
          <div class="faq-item">
            <div class="question-wrapper">
              <h3>Les cours couvrent-ils différents styles musicaux ?</h3>
              <div class="toggle-icon">
                <span class="plus-minus"></span>
              </div>
            </div>
            <div class="answer">
              <p>Oui, nos formations abordent une variété de styles : classique, pop, jazz, blues... Vous découvrirez différentes techniques d'interprétation et d'improvisation adaptées à chaque genre musical. Cela vous permet de développer une palette d'expression riche et variée.</p>
            </div>
          </div>
          
          <div class="faq-item">
            <div class="question-wrapper">
              <h3>Puis-je suivre les cours sur mobile ou tablette ?</h3>
              <div class="toggle-icon">
                <span class="plus-minus"></span>
              </div>
            </div>
            <div class="answer">
              <p>Oui, notre plateforme est entièrement responsive. Vous pouvez accéder à vos cours depuis n'importe quel appareil : ordinateur, tablette ou smartphone. Idéal pour pratiquer où que vous soyez, directement à côté de votre piano.</p>
            </div>
          </div>
          
          <div class="faq-item">
            <div class="question-wrapper">
              <h3>Combien de temps faut-il pour jouer une chanson complète ?</h3>
              <div class="toggle-icon">
                <span class="plus-minus"></span>
              </div>
            </div>
            <div class="answer">
              <p>Dès les premières semaines de pratique, vous serez capable de jouer des versions simplifiées de morceaux connus. Avec 15-20 minutes de pratique quotidienne, la plupart des élèves parviennent à jouer leur première chanson complète en 3 à 4 semaines.</p>
            </div>
          </div>
          
          <div class="faq-item">
            <div class="question-wrapper">
              <h3>Y a-t-il un support en cas de questions ?</h3>
              <div class="toggle-icon">
                <span class="plus-minus"></span>
              </div>
            </div>
            <div class="answer">
              <p>Oui, vous pouvez envoyer vos questions par email et recevoir une réponse personnalisée de nos professeurs dans un délai de 24 à 48h. Certaines formations incluent également l'accès à un groupe privé où vous pouvez échanger avec d'autres élèves et nos formateurs.</p>
            </div>
          </div>
          
          <div class="faq-item">
            <div class="question-wrapper">
              <h3>Les cours incluent-ils des morceaux célèbres à apprendre ?</h3>
              <div class="toggle-icon">
                <span class="plus-minus"></span>
              </div>
            </div>
            <div class="answer">
              <p>Bien sûr ! Nos cours intègrent des arrangements adaptés de morceaux connus, classiques et modernes. Ces morceaux sont proposés avec différents niveaux de difficulté pour que vous puissiez progresser tout en prenant du plaisir à jouer des mélodies que vous aimez.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <AuthorBio />

    <section class="cta-section">
      <div class="container">
        <div class="cta-content">
          <h2>Prêt à découvrir votre talent musical ?</h2>
          <p>Rejoignez des milliers d'élèves qui apprennent le piano avec nos cours en ligne</p>
          <a href="#courses-list" class="btn-all-courses">
            Voir nos formations de piano
            <span class="arrow">→</span>
          </a>
        </div>
      </div>
    </section>

  <FooterModern />
</Layout>

<style>
  /* Hero Section */
  .courses-hero {
    padding: 8rem 0 4rem;
    background: linear-gradient(135deg, var(--theme-piano) 0%, var(--theme-piano-dark) 100%);
    color: white;
    text-align: center;
    position: relative;
    overflow: hidden;
  }

  .hero-background {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center;
    opacity: 0.2;
    z-index: 0;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(0,0,0,0.7) 0%, rgba(0,0,0,0.5) 100%);
    z-index: 1;
  }

  .courses-hero .container {
    position: relative;
    z-index: 2;
  }

  .courses-hero h1 {
    font-size: 3.5rem;
    margin-bottom: 1rem;
    color: white;
  }

  .subtitle {
    font-size: 1.2rem;
    color: rgba(255, 255, 255, 0.9);
    max-width: 800px;
    margin: 0 auto 2rem;
    line-height: 1.6;
  }

  .hero-cta {
    margin-top: 2rem;
  }

  .cta-button {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: white;
    color: var(--theme-piano);
    padding: 1rem 2rem;
    border-radius: var(--border-radius);
    text-decoration: none;
