---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import FooterModern from '../../components/FooterModern.astro';
import Icon from '../../components/Icon.astro';
import { getCollection } from 'astro:content';
import CoursesComparison from '../../components/CoursesComparison.astro';
import AuthorBio from '../../components/AuthorBio.astro';
import BreadcrumbNav from '../../components/BreadcrumbNav.astro';

// Récupérer uniquement les cours de solfège
const allCourses = await getCollection('courses');
const solfegeCourses = allCourses
  .filter(course => course.data.theme === 'solfege' && course.data.affichage === 'Y')
  .sort((a, b) => a.data.classement - b.data.classement);

// Construction de l'URL canonique
const canonicalURL = new URL(Astro.url.pathname, Astro.site || 'https://musique-facile.fr').toString();

// Métadonnées pour la page
const title = "Cours de Solfège en Ligne | Musique Facile";
const description = "Apprends le solfège avec Fred Fieffé : 200+ leçons vidéo HD, lecture de partitions, rythmes, théorie musicale. Méthode progressive sans pré-requis. 80 000+ élèves formés depuis 2015. Satisfait ou remboursé sous 15 jours.";

// Schema.org pour le fil d'Ariane
const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Accueil",
      "item": "https://musique-facile.fr/"
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": "Cours",
      "item": "https://musique-facile.fr/cours/"
    },
    {
      "@type": "ListItem",
      "position": 3,
      "name": "Cours de Solfège",
      "item": canonicalURL
    }
  ]
};

// Schema.org pour la liste des cours
const coursesSchema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": "Cours de Solfège en Ligne",
  "description": "Formation complète pour apprendre le solfège et la théorie musicale",
  "url": canonicalURL,
  "inLanguage": "fr",
  "itemListElement": solfegeCourses.map((course, index) => ({
    "@type": "ListItem",
    "position": index + 1,
    "item": {
      "@type": "Course",
      "@id": `https://musique-facile.fr/cours/${course.slug}#course`,
      "name": course.data.title,
      "description": course.data.description,
      "provider": {
        "@type": "Organization",
        "name": "Musique Facile",
        "sameAs": "https://musique-facile.fr"
      },
      "offers": {
        "@type": "Offer",
        "price": course.data.hasCourseInstance?.offers?.price || "69.00",
        "priceCurrency": "EUR",
        "availability": "https://schema.org/InStock",
        "url": `https://musique-facile.fr/cours/${course.slug}`
      },
      "hasCourseInstance": {
        "@type": "CourseInstance",
        "courseMode": "online",
        "duration": course.data.hasCourseInstance?.duration || "P3M",
        "offers": {
          "@type": "Offer",
          "price": course.data.hasCourseInstance?.offers?.price || "69.00",
          "priceCurrency": "EUR",
          "availability": "https://schema.org/InStock"
        }
      },
      "inLanguage": "fr",
      "url": `https://musique-facile.fr/cours/${course.slug}`
    }
  }))
};

// JSON-LD pour le cours principal
// Fourchette de prix réelle des cours du hub → AggregateOffer (au lieu d'un prix unique trompeur)
const hubPrices = solfegeCourses
  .map(c => parseFloat(c.data.hasCourseInstance?.offers?.price || "0"))
  .filter(p => p > 0);
const hubAggregateOffer = {
  "@type": "AggregateOffer",
  "priceCurrency": "EUR",
  "lowPrice": Math.min(...hubPrices).toFixed(2),
  "highPrice": Math.max(...hubPrices).toFixed(2),
  "offerCount": hubPrices.length,
  "availability": "https://schema.org/InStock"
};

const courseLDSchema = {
  "@context": "https://schema.org",
  "@type": "Course",
  "@id": "https://musique-facile.fr/cours/cours-de-solfege/#course",
  "name": "Cours de Solfège en Ligne",
  "description": "Apprends le solfège en ligne en toute simplicité. Des cours clairs, progressifs et concrets pour comprendre la musique, lire une partition et développer ton oreille musicale efficacement.",
  "provider": {
    "@type": "Organization",
    "name": "Musique Facile",
    "url": "https://musique-facile.fr"
  },
  "offers": hubAggregateOffer,
  "hasCourseInstance": {
    "@type": "CourseInstance",
    "courseMode": "online",
    "startDate": new Date().toISOString().split('T')[0],
    "endDate": new Date(new Date().setFullYear(new Date().getFullYear() + 1)).toISOString().split('T')[0],
    "location": {
      "@type": "VirtualLocation",
      "url": canonicalURL
    },
    "offers": hubAggregateOffer
  },
  "inLanguage": "fr",
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": canonicalURL
  }
};

// FAQ Schema pour la page de cours de solfège
const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Le solfège est-il indispensable pour faire de la musique ?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Non, il est possible de faire de la musique sans connaître le solfège, mais l'apprendre facilite considérablement l'apprentissage de tout instrument. C'est un langage universel qui permet de lire, comprendre et communiquer la musique plus efficacement. Notre méthode propose une approche progressive qui démystifie le solfège et le rend accessible à tous."
      }
    },
    {
      "@type": "Question",
      "name": "À quel âge peut-on commencer à apprendre le solfège ?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "On peut commencer à tout âge ! Pour les enfants, il est recommandé d'attendre l'âge de 6-7 ans pour une meilleure compréhension des concepts. Pour les adultes, il n'y a absolument aucune limite d'âge : nos cours sont conçus pour s'adapter à tous les niveaux et rythmes d'apprentissage."
      }
    },
    {
      "@type": "Question",
      "name": "Faut-il un instrument pour suivre les cours ?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Non, aucun instrument n'est nécessaire pour apprendre le solfège. En revanche, si vous possédez déjà un instrument, vous pourrez appliquer immédiatement les concepts appris, ce qui peut faciliter l'intégration. Notre formation reste 100% accessible même sans instrument."
      }
    },
    {
      "@type": "Question",
      "name": "Comment sont structurées les leçons de solfège en ligne ?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Nos cours sont organisés en modules progressifs avec des vidéos explicatives, des exercices interactifs et des quiz. Chaque concept est introduit pas à pas avec de nombreux exemples pratiques. Les leçons abordent la lecture de notes, le rythme, les intervalles et tous les éléments essentiels à une compréhension complète du langage musical."
      }
    },
    {
      "@type": "Question",
      "name": "Puis-je apprendre à lire une partition rapidement ?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Oui, notre méthode vous permet d'apprendre à lire les partitions de façon progressive et efficace. La plupart des élèves commencent à déchiffrer des partitions simples après seulement quelques semaines de pratique régulière. Notre approche visuelle et intuitive facilite l'apprentissage rapide de la lecture musicale."
      }
    },
    {
      "@type": "Question",
      "name": "Les exercices sont-ils corrigés ?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Absolument ! Tous nos exercices sont accompagnés de leurs corrections détaillées. De plus, de nombreux quiz interactifs vous permettent d'obtenir un retour immédiat sur vos réponses, vous aidant ainsi à identifier rapidement vos points forts et les aspects à améliorer."
      }
    },
    {
      "@type": "Question",
      "name": "Quelle est la différence entre théorie et solfège ?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "La théorie musicale englobe l'ensemble des connaissances qui expliquent les principes fondamentaux de la musique, tandis que le solfège est la mise en pratique de cette théorie, notamment via la lecture et l'écriture musicale. Notre formation couvre ces deux aspects de manière équilibrée pour une compréhension complète du langage musical."
      }
    },
    {
      "@type": "Question",
      "name": "Le solfège aide-t-il à mieux jouer d'un instrument ?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Oui, absolument ! Le solfège vous permet de comprendre la structure des morceaux, de lire des partitions, d'améliorer votre oreille musicale et de communiquer plus facilement avec d'autres musiciens. Ces compétences sont précieuses quel que soit votre instrument et votre niveau."
      }
    },
    {
      "@type": "Question",
      "name": "Y a-t-il un certificat à la fin de la formation ?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Oui, un certificat d'accomplissement est délivré à la fin de nos formations complètes. Ce document atteste des compétences acquises et peut être utile pour valoriser votre parcours musical, notamment si vous envisagez de rejoindre un groupe ou de poursuivre d'autres formations."
      }
    },
    {
      "@type": "Question",
      "name": "Peut-on suivre les cours sans connexion permanente ?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Une connexion internet est nécessaire pour accéder aux vidéos de cours. Cependant, tous les supports PDF sont téléchargeables et peuvent être consultés hors ligne. Il est donc possible de télécharger les ressources puis de travailler sans connexion pour une partie de votre apprentissage."
      }
    }
  ]
};
---

<Layout title={title} description={description} canonicalUrl={canonicalURL} robots="index, follow">
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(coursesSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(courseLDSchema)} />
  </Fragment>

  <Header />
  
    <!-- Fil d'Ariane -->
    <BreadcrumbNav 
      items={[
        { name: "Accueil", url: "/" },
        { name: "Cours", url: "/cours/" },
        { name: "Cours de Solfège", url: "/cours/cours-de-solfege/" }
      ]}
    />
    
    <section class="courses-hero theme-solfege">
      <div class="hero-background" style="background-image: url('/images/cours/hero-solfege.webp')"></div>
      <div class="hero-overlay"></div>
      <div class="container">
        <h1>Cours de Solfège en Ligne</h1>
        <p class="subtitle">Apprends le solfège en ligne en toute simplicité. Des cours clairs, progressifs et concrets pour comprendre la musique, lire une partition et développer ton oreille musicale efficacement.</p>
        <div class="hero-cta">
          <a href="#courses-list" class="cta-button">
            Découvrir nos formations
            <span class="cta-arrow">↓</span>
          </a>
        </div>
      </div>
    </section>

    <CoursesComparison courses={solfegeCourses} instrument="solfège" />

    <section class="courses-grid" id="courses-list">
      <div class="container">
        <h2 class="section-title">Nos Cours de Solfège</h2>
        <p class="section-subtitle">Du débutant à l'expert, nous vous accompagnons à chaque étape de votre apprentissage</p>
        
        <div class="courses-wrapper">
          {solfegeCourses.map((course, index) => (
            <article class="course-card" id={`course-${index + 1}`}>
              <a href={`/cours/${course.slug}/`} class="course-link">
                <div class="course-image" style={`background-image: url(${course.data.ogImage})`}>
                  <div class="course-meta">
                    {course.data.bestSeller && (
                      <span class="best-seller-tag">
                        <span class="best-seller-icon"><Icon name="trophy" size={16} /></span>
                        Meilleure vente
                      </span>
                    )}
                  </div>
                </div>
                <div class="course-content">
                  <h2>{course.data.title}</h2>
                  <p>{course.data.description}</p>
                  <div class="course-details">
                    <span class="course-price">{course.data.hasCourseInstance?.offers?.price || "69 €"}</span>
                    <span class="course-duration">{course.data.hasCourseInstance?.duration ? `Durée: ${course.data.hasCourseInstance.duration}` : "Accès illimité"}</span>
                  </div>
                  <span class="cta-button">
                    Découvrir le cours
                    <span class="arrow">→</span>
                  </span>
                </div>
              </a>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- Section Pourquoi Apprendre le Solfège en Ligne -->
    <section class="why-online">
      <div class="container">
        <h2 class="section-title">Pourquoi apprendre le solfège en ligne ?</h2>
        
        <div class="benefits-grid">
          <div class="benefit-card">
            <div class="benefit-icon">🧠</div>
            <h3>Une base essentielle</h3>
            <p>Comprendre le langage musical et les partitions pour progresser plus rapidement sur tout instrument.</p>
          </div>
          
          <div class="benefit-card">
            <div class="benefit-icon"><Icon name="lightning" size={24} /></div>
            <h3>À votre rythme</h3>
            <p>Apprenez sans pression, avec des leçons accessibles 24h/24 et visionnables autant de fois que nécessaire.</p>
          </div>
          
          <div class="benefit-card">
            <div class="benefit-icon"><Icon name="target" size={24} /></div>
            <h3>Méthode progressive</h3>
            <p>Des explications simples et concrètes, adaptées aux débutants comme aux musiciens autodidactes.</p>
          </div>
          
          <div class="benefit-card">
            <div class="benefit-icon">👂</div>
            <h3>Développez votre oreille</h3>
            <p>Exercices pratiques pour affiner votre perception musicale et gagner en précision.</p>
          </div>
        </div>
        
        <div class="online-learning-description">
          <p>Le solfège, c'est la base pour comprendre et lire la musique. En ligne, tu progresses à ton rythme, sans pression. Les vidéos sont simples, bien expliquées, et illustrées avec des exemples concrets. Tu vas enfin comprendre les rythmes, les notes, les clés, et comment fonctionnent les partitions. C'est idéal pour les autodidactes, les débutants ou les musiciens qui veulent combler des lacunes. Grâce aux cours en ligne, tu développes ton oreille, tu gagnes en confiance, et tu deviens plus à l'aise avec ton instrument. C'est une compétence qui change tout.</p>
        </div>
      </div>
    </section>

    <!-- Section FAQ -->
    <section class="faq-section">
      <div class="container">
        <h2 class="section-title">Questions fréquentes</h2>
        
        <div class="faq-grid">
          <div class="faq-item">
            <div class="question-wrapper">
              <h3>Le solfège est-il indispensable pour faire de la musique ?</h3>
              <div class="toggle-icon">
                <span class="plus-minus"></span>
              </div>
            </div>
            <div class="answer">
              <p>Non, il est possible de faire de la musique sans connaître le solfège, mais l'apprendre facilite considérablement l'apprentissage de tout instrument. C'est un langage universel qui permet de lire, comprendre et communiquer la musique plus efficacement. Notre méthode propose une approche progressive qui démystifie le solfège et le rend accessible à tous.</p>
            </div>
          </div>
          
          <div class="faq-item">
            <div class="question-wrapper">
              <h3>À quel âge peut-on commencer à apprendre le solfège ?</h3>
              <div class="toggle-icon">
                <span class="plus-minus"></span>
              </div>
            </div>
            <div class="answer">
              <p>On peut commencer à tout âge ! Pour les enfants, il est recommandé d'attendre l'âge de 6-7 ans pour une meilleure compréhension des concepts. Pour les adultes, il n'y a absolument aucune limite d'âge : nos cours sont conçus pour s'adapter à tous les niveaux et rythmes d'apprentissage.</p>
            </div>
          </div>
          
          <div class="faq-item">
            <div class="question-wrapper">
              <h3>Faut-il un instrument pour suivre les cours ?</h3>
              <div class="toggle-icon">
                <span class="plus-minus"></span>
              </div>
            </div>
            <div class="answer">
              <p>Non, aucun instrument n'est nécessaire pour apprendre le solfège. En revanche, si vous possédez déjà un instrument, vous pourrez appliquer immédiatement les concepts appris, ce qui peut faciliter l'intégration. Notre formation reste 100% accessible même sans instrument.</p>
            </div>
          </div>
          
          <div class="faq-item">
            <div class="question-wrapper">
              <h3>Comment sont structurées les leçons de solfège en ligne ?</h3>
              <div class="toggle-icon">
                <span class="plus-minus"></span>
              </div>
            </div>
            <div class="answer">
              <p>Nos cours sont organisés en modules progressifs avec des vidéos explicatives, des exercices interactifs et des quiz. Chaque concept est introduit pas à pas avec de nombreux exemples pratiques. Les leçons abordent la lecture de notes, le rythme, les intervalles et tous les éléments essentiels à une compréhension complète du langage musical.</p>
            </div>
          </div>
          
          <div class="faq-item">
            <div class="question-wrapper">
              <h3>Puis-je apprendre à lire une partition rapidement ?</h3>
              <div class="toggle-icon">
                <span class="plus-minus"></span>
              </div>
            </div>
            <div class="answer">
              <p>Oui, notre méthode vous permet d'apprendre à lire les partitions de façon progressive et efficace. La plupart des élèves commencent à déchiffrer des partitions simples après seulement quelques semaines de pratique régulière. Notre approche visuelle et intuitive facilite l'apprentissage rapide de la lecture musicale.</p>
            </div>
          </div>
          
          <div class="faq-item">
            <div class="question-wrapper">
              <h3>Les exercices sont-ils corrigés ?</h3>
              <div class="toggle-icon">
                <span class="plus-minus"></span>
              </div>
            </div>
            <div class="answer">
              <p>Absolument ! Tous nos exercices sont accompagnés de leurs corrections détaillées. De plus, de nombreux quiz interactifs vous permettent d'obtenir un retour immédiat sur vos réponses, vous aidant ainsi à identifier rapidement vos points forts et les aspects à améliorer.</p>
            </div>
          </div>
          
          <div class="faq-item">
            <div class="question-wrapper">
              <h3>Quelle est la différence entre théorie et solfège ?</h3>
              <div class="toggle-icon">
                <span class="plus-minus"></span>
              </div>
            </div>
            <div class="answer">
              <p>La théorie musicale englobe l'ensemble des connaissances qui expliquent les principes fondamentaux de la musique, tandis que le solfège est la mise en pratique de cette théorie, notamment via la lecture et l'écriture musicale. Notre formation couvre ces deux aspects de manière équilibrée pour une compréhension complète du langage musical.</p>
            </div>
          </div>
          
          <div class="faq-item">
            <div class="question-wrapper">
              <h3>Le solfège aide-t-il à mieux jouer d'un instrument ?</h3>
              <div class="toggle-icon">
                <span class="plus-minus"></span>
              </div>
            </div>
            <div class="answer">
              <p>Oui, absolument ! Le solfège vous permet de comprendre la structure des morceaux, de lire des partitions, d'améliorer votre oreille musicale et de communiquer plus facilement avec d'autres musiciens. Ces compétences sont précieuses quel que soit votre instrument et votre niveau.</p>
            </div>
          </div>
          
          <div class="faq-item">
            <div class="question-wrapper">
              <h3>Y a-t-il un certificat à la fin de la formation ?</h3>
              <div class="toggle-icon">
                <span class="plus-minus"></span>
              </div>
            </div>
            <div class="answer">
              <p>Oui, un certificat d'accomplissement est délivré à la fin de nos formations complètes. Ce document atteste des compétences acquises et peut être utile pour valoriser votre parcours musical, notamment si vous envisagez de rejoindre un groupe ou de poursuivre d'autres formations.</p>
            </div>
          </div>
          
          <div class="faq-item">
            <div class="question-wrapper">
              <h3>Peut-on suivre les cours sans connexion permanente ?</h3>
              <div class="toggle-icon">
                <span class="plus-minus"></span>
              </div>
            </div>
            <div class="answer">
              <p>Une connexion internet est nécessaire pour accéder aux vidéos de cours. Cependant, tous les supports PDF sont téléchargeables et peuvent être consultés hors ligne. Il est donc possible de télécharger les ressources puis de travailler sans connexion pour une partie de votre apprentissage.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <AuthorBio />

    <section class="cta-section">
      <div class="container">
        <div class="cta-content">
          <h2>Prêt à démystifier la musique ?</h2>
          <p>Rejoignez plus de 80 000 élèves formés d'apprenants et maîtrisez le langage musical à votre rythme</p>
          <a href="#courses-list" class="btn-all-courses">
            Découvrir nos formations de solfège
            <span class="arrow">→</span>
          </a>
        </div>
      </div>
    </section>

  <FooterModern />
</Layout>

<style>
  /* Hero Section */
  .courses-hero {
    padding: 8rem 0 4rem;
    background: linear-gradient(135deg, var(--theme-solfege) 0%, var(--theme-solfege-dark) 100%);
    color: white;
    text-align: center;
    position: relative;
    overflow: hidden;
  }

  .hero-background {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center;
    opacity: 0.2;
    z-index: 0;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(0,0,0,0.7) 0%, rgba(0,0,0,0.5) 100%);
    z-index: 1;
  }

  .courses-hero .container {
    position: relative;
    z-index: 2;
  }

  .courses-hero h1 {
    font-size: 3.5rem;
    margin-bottom: 1rem;
    color: white;
  }

  .subtitle {
    font-size: 1.2rem;
    color: rgba(255, 255, 255, 0.9);
    max-width: 800px;
    margin: 0 auto 2rem;
    line-height: 1.6;
  }

  .hero-cta {
    margin-top: 2rem;
  }

  .cta-button {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: white;
    color: var(--theme-solfege);
    padding: 1rem 2rem;
    border-radius: var(--border-radius);
    text-decoration: none;
    font-weight: 600;
    transition: all 0.3s ease;
    font-size: 1.1rem;
  }

  .cta-button:hover {
    transform: translateY(-3px);
    box-shadow: 0 10px 20px rgba(0, 0, 0, 0.2);
  }

  .cta-arrow {
    transition: transform 0.3s ease;
  }

  .cta-button:hover .cta-arrow {
    transform: translateY(3px);
  }

  /* Courses Section */
  .courses-grid {
    padding: 6rem 0;
    background: var(--bg-light);
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .section-title {
    text-align: center;
    font-size: 2.5rem;
    margin-bottom: 1rem;
    color: var(--theme-solfege);
  }

  .section-subtitle {
    text-align: center;
