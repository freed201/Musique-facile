---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import FooterModern from '../components/FooterModern.astro';
import OptimizedImage from '../components/OptimizedImage.astro';
import StageInscriptionForm from '../components/StageInscriptionForm.astro';

const title = "Stage Ukulélé Été 2026 à Grasse — 6 au 10 juillet | Musique Facile";
const description = "Stage d'ukulélé à Grasse du 6 au 10 juillet 2026 à la Happiness School. Du débutant complet au joueur confirmé, ado, adulte ou retraité — 5 jours pour jouer tes premières chansons. Animé par Fred, Christophe et Lydie. Formules 3 ou 5 jours, dès 100€. 12 places par stage.";
const canonicalUrl = new URL('/stage2026/', Astro.site || 'https://musique-facile.fr').toString();
const ogImage = "https://musique-facile.fr/images/stage-ukulele-juillet-2026-groupe.webp";

const eventSchema = {
  "@context": "https://schema.org",
  "@type": "Event",
  "name": "Stage d'ukulélé à Grasse — Été 2026",
  "description": "Stage d'ukulélé à Grasse pendant les vacances scolaires d'été. Deux niveaux (Débutant ou Initié), deux formats au choix (3 jours ou 5 jours), atelier chant avec Lydie à mi-parcours. Animé par Fred Fieffé et Christophe Damay. Ouvert dès 12 ans, ados, adultes, retraités.",
  "startDate": "2026-07-06T09:30:00+02:00",
  "endDate": "2026-07-10T16:00:00+02:00",
  "eventAttendanceMode": "https://schema.org/OfflineEventAttendanceMode",
  "eventStatus": "https://schema.org/EventScheduled",
  "location": {
    "@type": "Place",
    "name": "Happiness School",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "95 Av. de la Libération",
      "addressLocality": "Grasse",
      "postalCode": "06130",
      "addressCountry": "FR"
    }
  },
  "image": ogImage,
  "offers": [
    { "@type": "Offer", "name": "Stage 3 jours (Lundi au Mercredi)", "price": "100", "priceCurrency": "EUR", "url": canonicalUrl, "availability": "https://schema.org/LimitedAvailability", "validFrom": "2026-05-01T00:00:00+02:00" },
    { "@type": "Offer", "name": "Stage 5 jours (Lundi au Vendredi)", "price": "150", "priceCurrency": "EUR", "url": canonicalUrl, "availability": "https://schema.org/LimitedAvailability", "validFrom": "2026-05-01T00:00:00+02:00" }
  ],
  "performer": [
    { "@type": "Person", "name": "Fred Fieffé" },
    { "@type": "Person", "name": "Christophe Damay" },
    { "@type": "Person", "name": "Lydie" }
  ],
  "organizer": { "@type": "Organization", "name": "Musique Facile", "url": "https://musique-facile.fr" }
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    { "@type": "Question", "name": "Combien de participants par stage ?", "acceptedAnswer": { "@type": "Answer", "text": "Chaque stage compte environ 12 personnes maximum. Et pour aller encore plus loin, on travaille très souvent en demi-groupes (Fred avec une moitié, Christophe avec l'autre), selon les niveaux et les envies du moment. Tu n'es jamais perdu(e) dans la masse." } },
    { "@type": "Question", "name": "Je suis débutant complet, c'est ok ?", "acceptedAnswer": { "@type": "Answer", "text": "Oui, c'est parfait. Le stage Débutant (13h30 – 16h) est conçu pour partir de zéro : tu n'as besoin d'aucune base musicale. Si tu n'as jamais touché un instrument de ta vie, c'est exactement pour toi." } },
    { "@type": "Question", "name": "À partir de quel âge peut-on s'inscrire ?", "acceptedAnswer": { "@type": "Answer", "text": "Le stage est ouvert dès 12 ans. On a l'habitude d'accueillir des enfants, des ados, des adultes et des retraités — c'est un public mixte qui fait la richesse de l'expérience. Les ados sont encadrés dans un groupe à taille humaine de 12 personnes maximum." } },
    { "@type": "Question", "name": "Je suis senior, je ne vais pas être largué ?", "acceptedAnswer": { "@type": "Answer", "text": "Pas du tout. Beaucoup de nos stagiaires reprennent la musique après 60 ans. Le rythme s'adapte au groupe, pas l'inverse. L'ukulélé est l'instrument le plus accessible qui soit." } },
    { "@type": "Question", "name": "Je n'ai aucune oreille, c'est éliminatoire ?", "acceptedAnswer": { "@type": "Answer", "text": "Non. L'oreille musicale, ça se travaille — et tu vas voir, c'est plus rapide que tu ne le crois. On part toujours du concret : un accord, un rythme, une chanson. La théorie vient après si elle vient." } },
    { "@type": "Question", "name": "C'est quoi exactement le niveau Initié ?", "acceptedAnswer": { "@type": "Answer", "text": "Tu as déjà fait le stage débutant ou tu joues un peu. Pas besoin d'être un pro. Chaque jour, on te propose plusieurs ateliers thématiques (rythmique, arpèges, fingerpicking, chant accompagné, blues…) et tu choisis ceux qui t'intéressent." } },
    { "@type": "Question", "name": "Comment se passe l'atelier chant du jeudi ?", "acceptedAnswer": { "@type": "Answer", "text": "Lydie, prof de chant, propose son atelier le jeudi — un atelier le matin pour les Initiés (9h30 – 12h) et un autre l'après-midi pour les Débutants (13h30 – 16h). Pas de regroupement, chaque niveau reste dans son créneau. C'est totalement facultatif : ceux qui préfèrent continuer l'ukulélé avec Fred et Christophe peuvent rester sur l'instrument, l'atelier chant n'est pas imposé. L'objectif est très concret : apprendre à oser chanter, poser sa voix, gagner en justesse et en aisance — pour qu'au prochain BBQ ou à la kermesse de l'école, tu sortes une chanson sans rougir. Compris dans le prix, conçu pour les novices en chant, aucune expérience requise." } },
    { "@type": "Question", "name": "Puis-je commencer en 3 jours et prolonger sur 5 jours ?", "acceptedAnswer": { "@type": "Answer", "text": "Oui, c'est possible si des places restent disponibles à mi-stage. Tu démarres en 3 jours et tu décides sur place de continuer jeudi et vendredi en réglant le complément." } },
    { "@type": "Question", "name": "Et après le stage, je continue comment ?", "acceptedAnswer": { "@type": "Answer", "text": "On te donne une feuille de route claire (chansons à travailler, astuces, ressources). Et tu peux poursuivre avec le cours d'ukulélé en ligne de Musique Facile si tu veux garder cette dynamique." } },
    { "@type": "Question", "name": "Comment je paie ?", "acceptedAnswer": { "@type": "Answer", "text": "Une fois ton inscription validée par notre retour, on t'envoie les modalités de paiement. Le règlement complet est demandé pour confirmer ta place." } }
  ]
};
---

<Layout title={title} description={description} canonicalUrl={canonicalUrl} ogImage={ogImage}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(eventSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  </Fragment>
  <Header />

  <!-- Bannière d'ouverture des inscriptions -->
  <div class="open-banner">
    <div class="container">
      <div class="open-content">
        <span class="open-icon">🌺</span>
        <div class="open-text">
          <strong>Inscriptions ouvertes pour juillet 2026</strong> · 12 places par stage · Le précédent stage a fait salle comble
        </div>
        <a href="#inscription" class="open-cta">Je réserve</a>
      </div>
    </div>
  </div>

  <main>
    <section class="hero" id="hero">
      <div class="hero-background">
        <div class="gradient-overlay"></div>
      </div>
      <div class="container">
        <div class="hero-content">
          <p class="hero-eyebrow">🌺 Stage d'ukulélé d'été · 6 au 10 juillet 2026 · Grasse</p>
          <h1>L'été où tu te mets à l'ukulélé.</h1>
          <p class="hero-subtitle">
            5 jours du <strong>6 au 10 juillet 2026</strong> à la <strong>Happiness School</strong>, 95 Av. de la Libération · 06130 Grasse.<br>
            <span class="hero-tagline">Tu repars en jouant tes premières chansons — et tu n'oublieras pas la semaine de sitôt.</span>
          </p>
          <div class="hero-highlights">
            <span class="highlight-pill">📅 Lun → Ven · 2h30/jour</span>
            <span class="highlight-pill">🎯 Débutant ou Initié</span>
            <span class="highlight-pill">🎤 Atelier chant inclus</span>
            <span class="highlight-pill">👥 12 places max</span>
            <span class="highlight-pill">💶 Dès 100€</span>
          </div>
          <p class="hero-audience">Ados (dès 12 ans), adultes, retraités, en famille — <strong>tous les âges sont les bienvenus</strong>.</p>
          <div class="hero-cta">
            <a href="#inscription" class="btn btn-primary btn-lg">Je réserve ma place</a>
            <a href="#journee-type" class="btn btn-secondary btn-lg">Comment ça se passe ?</a>
          </div>
        </div>
      </div>
    </section>

    <!-- Bandeau preuve sociale -->
    <section class="proof-strip">
      <div class="container">
        <div class="proof-items">
          <div class="proof-item">
            <strong>80 000+</strong>
            <span>élèves accompagnés</span>
          </div>
          <div class="proof-divider"></div>
          <div class="proof-item">
            <strong>15 ans</strong>
            <span>d'enseignement musical</span>
          </div>
          <div class="proof-divider"></div>
          <div class="proof-item">
            <strong>3<sup>e</sup></strong>
            <span>édition du stage à Grasse</span>
          </div>
          <div class="proof-divider"></div>
          <div class="proof-item">
            <strong>4,9 / 5</strong>
            <span>satisfaction stagiaires</span>
          </div>
        </div>
      </div>
    </section>

    <section class="stages section" id="stages">
      <div class="container">
        <div class="section-header">
          <p class="section-eyebrow">🎯 Deux stages, un même esprit</p>
          <h2 class="section-title">Choisis ton créneau, on s'occupe du reste</h2>
          <p class="section-subtitle">Chaque stage dure 2h30 par jour, du lundi au vendredi. Tu suis un seul stage sur la semaine — soit l'Initié le matin, soit le Débutant l'après-midi.</p>
        </div>
        <div class="stage-grid">
          <div class="card card-ukulele stage-card">
            <div class="stage-card-header">
              <h3>Débutant</h3>
              <span class="stage-time">13h30 – 16h</span>
            </div>
            <p class="stage-tagline">Tu n'as jamais touché un ukulélé ? Parfait.</p>
            <p>On part vraiment de zéro. Les premiers accords, le rythme de base, et très vite la magie : <strong>tes premières chansons jouées en entier</strong>. Tu arrives intimidé(e) le lundi, tu repars fier(e) le vendredi.</p>
            <ul class="stage-bullets">
              <li>4 à 5 accords essentiels et leurs enchaînements</li>
              <li>La rythmique main droite qui marche pour 80% des chansons</li>
              <li>2 à 3 morceaux complets joués en fin de stage</li>
              <li>Le plaisir de jouer en groupe dès le mardi</li>
            </ul>
          </div>
          <div class="card card-ukulele stage-card stage-card-featured">
            <div class="stage-badge">Au choix chaque jour</div>
            <div class="stage-card-header">
              <h3>Initié</h3>
              <span class="stage-time">9h30 – 12h</span>
            </div>
            <p class="stage-tagline">Tu joues déjà un peu et tu veux passer un cap ?</p>
            <p>Chaque jour, plusieurs ateliers thématiques te sont proposés (rythmique, fingerpicking, chant, blues…) et tu choisis selon ton humeur. Une partie commune en groupe + un atelier au choix : <strong>la formule sur-mesure</strong>.</p>
            <ul class="stage-bullets">
              <li>Une partie commune chaque matin (répertoire, échauffement)</li>
              <li>Un atelier au choix selon tes envies du jour</li>
              <li>Approfondissement personnalisé avec Fred ou Christophe</li>
              <li>Jeu en groupe et confrontation des styles</li>
            </ul>
          </div>
        </div>

        <div class="formats-section">
          <h3 class="formats-title">Deux formats au choix</h3>
          <div class="formats-grid">
            <div class="format-card">
              <h4>3 jours</h4>
              <p class="format-dates">Lundi → Mercredi</p>
              <p class="format-price">100€</p>
              <p>Une initiation intensive ou un rappel des bases. Tu repars avec un premier morceau et l'envie de continuer.</p>
            </div>
            <div class="format-card format-card-highlight">
              <div class="format-badge">Le plus complet</div>
              <h4>5 jours</h4>
              <p class="format-dates">Lundi → Vendredi</p>
              <p class="format-price">150€</p>
              <p>L'immersion complète, <strong>atelier chant Lydie inclus le jeudi</strong> dans ton créneau habituel. Vraie progression jusqu'au vendredi.</p>
            </div>
          </div>
          <p class="formats-note">💡 <strong>Tu hésites ?</strong> Démarre en 3 jours et prolonge sur place jusqu'au vendredi si des places sont encore disponibles.</p>
        </div>
      </div>
    </section>

    <!-- Pour qui c'est fait -->
    <section class="for-who section section-light" id="pour-qui">
      <div class="container">
        <div class="section-header">
          <p class="section-eyebrow">👥 Pour qui c'est fait</p>
          <h2 class="section-title">Tu te reconnais ? Alors c'est pour toi.</h2>
          <p class="section-subtitle">On accueille ado, adulte, retraité, en famille — la mixité d'âges fait la magie du stage.</p>
        </div>
        <div class="profiles-grid">
          <div class="profile-card">
            <div class="profile-icon">🎓</div>
            <h3>Tu es ado (12-17 ans)</h3>
            <p>Tu veux apprendre un vrai instrument cet été, sans cours barbants. L'ukulélé est l'instrument le plus rapide à prendre en main — et l'ambiance est <em>franchement cool</em>.</p>
            <p class="profile-note"><strong>Pour les parents :</strong> groupe de 12 max, encadrement bienveillant, on connaît le métier.</p>
          </div>
          <div class="profile-card">
            <div class="profile-icon">💼</div>
            <h3>Tu es adulte et tu débutes</h3>
            <p>Tu rêves de jouer d'un instrument depuis longtemps mais tu n'as jamais osé. C'est exactement ici que ça commence. Pas de pression, pas de jugement — juste du plaisir et de la progression.</p>
            <p class="profile-note"><strong>Notre promesse :</strong> tu joues une chanson en entier d'ici la fin de la semaine.</p>
          </div>
          <div class="profile-card">
            <div class="profile-icon">🌿</div>
            <h3>Tu es retraité(e), tu reprends</h3>
            <p>L'ukulélé n'a pas d'âge. Beaucoup de nos stagiaires ont entre 55 et 75 ans — c'est même le profil dominant. Le rythme s'adapte à toi, et tu repars avec du concret.</p>
            <p class="profile-note"><strong>Bonus :</strong> tu rencontres des gens qui partagent la même envie.</p>
          </div>
          <div class="profile-card">
            <div class="profile-icon">👨‍👩‍👧</div>
            <h3>Vous voulez venir en famille</h3>
            <p>Un parent + un ado, deux parents qui partagent la même envie, un grand-parent qui veut transmettre… Vous pouvez vous inscrire ensemble, sur le même stage ou des stages différents.</p>
            <p class="profile-note"><strong>Tarif famille :</strong> écris-nous, on s'arrange.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Une journée-type -->
    <section class="day-type section" id="journee-type">
      <div class="container">
        <div class="section-header">
          <p class="section-eyebrow">⏰ Une journée-type</p>
          <h2 class="section-title">Une seule routine, déclinée pour chaque groupe</h2>
          <p class="section-subtitle">
            Les Initiés vivent leur journée le matin (9h30 – 12h), les Débutants l'après-midi (13h30 – 16h).
            <strong>Même structure pour les deux</strong> : un temps commun, puis un split en deux salles où
            Fred et Christophe accompagnent chacun la moitié du groupe en parallèle.
          </p>
        </div>

        <div class="timeline-wrapper">
          <div class="timeline-creneaux">
            <div class="creneau-pill creneau-morning">🌅 Matin · Stage Initié · 9h30 – 12h</div>
            <div class="creneau-pill creneau-afternoon">🌇 Après-midi · Stage Débutant · 13h30 – 16h</div>
          </div>

          <div class="timeline">
            <div class="timeline-item">
              <div class="timeline-time">
                <span>9h15</span>
                <span class="time-alt">13h15</span>
              </div>
              <div class="timeline-content">
                <h3>Accueil café <span class="timeline-tag-neutral">Tous</span></h3>
                <p>Tu arrives, tu poses ton ukulélé, tu dis bonjour. On démarre dans la bonne humeur — café, jus, on se chauffe.</p>
              </div>
            </div>

            <div class="timeline-item">
              <div class="timeline-time">
                <span>9h30</span>
                <span class="time-alt">13h30</span>
              </div>
              <div class="timeline-content">
                <h3>Échauffement &amp; temps commun <span class="timeline-tag-neutral">Groupe entier</span></h3>
                <p>15 à 20 minutes pour réveiller les doigts, accorder les ukulélés, et lancer la journée ensemble — un morceau collectif, une rythmique partagée.</p>
              </div>
            </div>

            <div class="timeline-item">
              <div class="timeline-time">
                <span>9h50</span>
                <span class="time-alt">13h50</span>
              </div>
              <div class="timeline-content">
                <h3>Premier bloc — Travail collectif <span class="timeline-tag-neutral">Groupe entier</span></h3>
                <p>Fred et Christophe travaillent ensemble avec tout le groupe. On pose les bases du jour, on découvre le thème, on joue tous au même rythme.</p>
              </div>
            </div>

            <div class="timeline-item timeline-item-split">
              <div class="timeline-time">
                <span>10h40</span>
                <span class="time-alt">14h40</span>
              </div>
              <div class="timeline-content">
                <h3>🔀 Split en deux salles <span class="timeline-tag-split">Le cœur de la journée</span></h3>
                <p>
                  Le groupe se sépare en deux. <strong>Fred prend la première salle</strong>, <strong>Christophe prend la seconde</strong>.
                  Chacun aborde le sujet avec son angle, son style, sa pédagogie. Tu as littéralement <strong>deux profs pour le prix d'un</strong>,
                  et un format intimiste à 5-6 personnes par salle.
                </p>
                <div class="split-rooms">
                  <div class="split-room">
                    <strong>🎸 Salle 1 · avec Fred</strong>
                    <span>Approche structurée, focus sur la main droite, le placement et le groove.</span>
                  </div>
                  <div class="split-room">
                    <strong>🎼 Salle 2 · avec Christophe</strong>
                    <span>Approche complémentaire — souvent sur l'harmonie, l'accompagnement et le ressenti.</span>
                  </div>
                </div>
              </div>
            </div>

            <div class="timeline-item">
              <div class="timeline-time">
                <span>11h40</span>
                <span class="time-alt">15h40</span>
              </div>
              <div class="timeline-content">
                <h3>Retour ensemble <span class="timeline-tag-neutral">Groupe entier</span></h3>
                <p>On se retrouve tous, on partage ce qu'on a travaillé, on joue ensemble. C'est souvent le moment le plus magique de la matinée (ou de l'après-midi).</p>
              </div>
            </div>

            <div class="timeline-item timeline-item-special">
              <div class="timeline-time">
                <span>12h00</span>
                <span class="time-alt">16h00</span>
              </div>
              <div class="timeline-content">
                <h3>☕ 5 à 10 minutes pour traîner <span class="timeline-tag-warm">Le moment qu'on adore</span></h3>
                <p>
                  Officiellement, c'est terminé. Officieusement, il y a toujours <strong>du monde qui reste 5 ou 10 minutes</strong> pour
                  discuter, demander un truc, échanger avec Fred ou Christophe. C'est souvent là que naissent les plus belles complicités du stage.
                </p>
              </div>
            </div>

            <div class="timeline-item timeline-item-special">
              <div class="timeline-time"><span class="time-icon">🥖</span></div>
              <div class="timeline-content">
                <h3>Le midi · Gamelle sur place avec vue <span class="timeline-tag-warm">Facultatif</span></h3>
                <p>
                  Entre les deux créneaux, ceux qui veulent restent déjeuner <strong>sur place avec leur gamelle</strong>
                  (ou des trucs à partager, on adore ça). On mange dehors et on profite de la vue.
                  <strong>Les stagiaires du matin qui veulent prolonger sont les bienvenus à notre table</strong>.
                  Aucune obligation : tu peux aussi rentrer chez toi entre les deux créneaux si tu préfères.
                </p>
              </div>
            </div>

            <div class="timeline-item timeline-item-special">
              <div class="timeline-time"><span class="time-icon">🎤</span></div>
              <div class="timeline-content">
                <h3>Jeudi · Atelier chant Lydie <span class="timeline-tag-pink">Au choix · inclus</span></h3>
                <p>
                  Le jeudi, Lydie te propose son atelier chant — <strong>le matin pour les Initiés, l'après-midi pour les Débutants</strong>,
                  toujours dans ton créneau habituel. Tu choisis : participer à l'atelier chant avec Lydie,
                  ou continuer l'ukulélé avec Fred et Christophe. Objectif chant : oser, poser sa voix,
                  être à l'aise quand on te tendra un ukulélé au prochain BBQ.
                </p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Ce que tu repars avec -->
    <section class="results section section-light" id="resultats">
      <div class="container">
        <div class="section-header">
          <p class="section-eyebrow">🎁 Ce que tu repars avec</p>
          <h2 class="section-title">À la fin du vendredi, tu sais faire ça</h2>
          <p class="section-subtitle">Pas de promesse en l'air. Voici les résultats concrets que nos stagiaires ramènent à la maison.</p>
        </div>
        <div class="results-grid">
          <div class="result-card">
            <div class="result-num">01</div>
            <h3>Tu joues 2 à 3 chansons en entier</h3>
            <p>Sans tricher, du début à la fin. Tu peux les rejouer chez toi, à tes proches, sur la plage. Une vraie autonomie.</p>
          </div>
          <div class="result-card">
            <div class="result-num">02</div>
            <h3>Tu maîtrises 4 à 5 accords ouverts</h3>
            <p>Les accords qui débloquent la majorité du répertoire pop, folk et chanson française. Tu en feras des dizaines d'autres ensuite.</p>
          </div>
          <div class="result-card">
            <div class="result-num">03</div>
            <h3>Tu as une rythmique solide</h3>
            <p>Un pattern main droite qui marche sur 80% des chansons. Plus de "j'arrive pas à enchaîner" — tu sens le tempo.</p>
          </div>
          <div class="result-card">
            <div class="result-num">04</div>
            <h3>Tu sais comment continuer seul(e)</h3>
            <p>On te donne une feuille de route claire : quelles chansons travailler, comment progresser, où trouver les ressources. Tu n'es jamais lâché(e) après le stage.</p>
          </div>
          <div class="result-card">
            <div class="result-num">05</div>
            <h3>Tu as gagné en confiance</h3>
            <p>Tu sais que tu <strong>peux</strong> apprendre un instrument. C'est souvent le déclic le plus précieux de la semaine.</p>
          </div>
