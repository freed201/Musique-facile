---
/**
 * index.astro
 * Page d'accueil principale de Musique Facile
 *
 * Structure optimisée (8 sections):
 * 1. Hero - Accroche principale avec CTA
 * 2. Avantages - 3 bénéfices clés
 * 3. Cours - Grille des 4 instruments
 * 4. Lead Capture - Formulaire email (guide gratuit)
 * 5. Témoignages - Carousel social proof
 * 6. Pricing - Transparence des prix
 * 7. CTA Final - Dernier appel à l'action
 * 8. Footer
 */

import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';

// Composants modernises
import HeroModern from '../components/HeroModern.astro';
import PainPoints from '../components/PainPoints.astro';
import CoursGrid from '../components/CoursGrid.astro';
import MethodRoadmap from '../components/MethodRoadmap.astro';
import InstructorHighlight from '../components/InstructorHighlight.astro';
import QuizTeaser from '../components/QuizTeaser.astro';
import TemoignagesModern from '../components/TemoignagesModern.astro';
import LeadCaptureForm from '../components/LeadCaptureForm.astro';
import FooterModern from '../components/FooterModern.astro';

// Composants conserves
import PricingPreview from '../components/PricingPreview.astro';
import StickyCTAMobile from '../components/StickyCTAMobile.astro';

// Composants animations / parallax
import MarqueeBar from '../components/MarqueeBar.astro';
import ParallaxDecor from '../components/ParallaxDecor.astro';

// Composant GEO / social proof
import AuthorityBar from '../components/AuthorityBar.astro';
import TrustSignals from '../components/TrustSignals.astro';

// Construction de l'URL canonique
const canonicalURL = new URL(Astro.url.pathname, 'https://musique-facile.fr').toString();

// Métadonnées SEO (conservées de l'original)
const title = "École de Musique en Ligne | Cours Guitare, Piano, Ukulélé & Solfège | Musique Facile";
const description = "École de musique en ligne : apprenez la guitare, le piano, l'ukulélé et le solfège avec Fred Fieffé. 80 000+ élèves formés, 4.7/5, accès à vie, paiement unique. Commencez dès aujourd'hui !";
const keywords = "école de musique en ligne, cours guitare en ligne, apprendre piano, formation ukulélé débutant, solfège facile, cours musique en ligne, Fred Fieffé";
const ogImage = "https://musique-facile.fr/images/og-home.webp";

// Schémas JSON-LD (conservés de l'original)
const organizationSchema = {
  "@context": "https://schema.org",
  "@type": "EducationalOrganization",
  "name": "Musique Facile",
  "url": "https://musique-facile.fr",
  "logo": "https://musique-facile.fr/logo.webp",
  "description": "École de musique en ligne spécialisée dans l'enseignement de la guitare, du piano, de l'ukulélé et du solfège pour tous niveaux.",
  "foundingDate": "2015",
  "founder": {
    "@type": "Person",
    "name": "Fred Fieffé",
    "jobTitle": "Professeur de Musique Certifié"
  },
  "sameAs": [
    "https://www.youtube.com/@Musique-Facile",
    "https://www.tiktok.com/@musique_facile",
    "https://instagram.com/guitare_et_ukulele_facile/?hl=fr",
    "https://facebook.com/MusiqueFacileFacebook",
    "https://www.ukulele-facile.fr",
    "https://kidetzic.fr"
  ],
  "aggregateRating": {
    "@type": "AggregateRating",
    "ratingValue": "4.7",
    "reviewCount": "929",
    "bestRating": "5"
  }
};

const websiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "Musique Facile",
  "url": "https://musique-facile.fr",
  "description": "Formations en ligne pour apprendre la guitare, le piano, l'ukulélé et le solfège"
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Combien de temps faut-il pour apprendre la guitare en ligne ?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Avec la méthode Musique Facile, vous jouez vos premiers morceaux dès les premières semaines. En pratiquant 15 minutes par jour, vous maîtrisez progressivement les accords de base."
      }
    },
    {
      "@type": "Question",
      "name": "Les cours sont-ils adaptés aux débutants complets ?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Oui, tous nos cours commencent au niveau zéro. Aucune connaissance musicale préalable n'est requise. Les leçons sont progressives avec des exercices pratiques."
      }
    },
    {
      "@type": "Question",
      "name": "Quel est le prix des formations ?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Nos formations sont disponibles à l'achat individuel par instrument. Chaque formation donne un accès à vie avec garantie satisfait ou remboursé de 15 jours."
      }
    },
    {
      "@type": "Question",
      "name": "Peut-on apprendre la musique à 40, 50 ou 60 ans ?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Absolument ! La majorité de nos élèves sont des adultes. Notre méthode est spécialement conçue pour les adultes qui reprennent ou débutent la musique. L'âge n'est pas un frein, au contraire : les adultes progressent souvent plus vite car ils sont plus motivés."
      }
    },
    {
      "@type": "Question",
      "name": "Faut-il connaître le solfège pour commencer ?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Non, le solfège n'est pas obligatoire pour débuter la guitare, le piano ou l'ukulélé. Nos cours utilisent des tablatures, des diagrammes d'accords et des vidéos pas-à-pas. Vous pouvez apprendre le solfège en parallèle si vous le souhaitez."
      }
    },
    {
      "@type": "Question",
      "name": "Qui est Fred Fieffé, le formateur ?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Fred Fieffé est musicien professionnel avec 40 ans de pratique et 15 ans d'expérience dans l'enseignement. Il a formé plus de 80 000 élèves en ligne via Musique Facile, LinkedIn Learning et Skilleos. Il est également auteur de méthodes chez Hal Leonard."
      }
    },
    {
      "@type": "Question",
      "name": "Combien de temps par jour faut-il pratiquer ?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "15 minutes par jour suffisent pour progresser régulièrement. Notre méthode est conçue pour les adultes actifs avec peu de temps disponible. La régularité compte plus que la durée des sessions."
      }
    },
    {
      "@type": "Question",
      "name": "Les cours sont-ils accessibles à vie ?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Oui, une fois votre formation achetée, vous y avez accès à vie. Vous pouvez revenir sur les leçons autant de fois que nécessaire, à votre rythme, sans limite de temps."
      }
    },
    {
      "@type": "Question",
      "name": "Quel est le meilleur site pour apprendre la musique en ligne en France ?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Musique Facile est l'une des principales écoles de musique en ligne en France, avec plus de 80 000 élèves formés depuis 2015. Le site propose des cours de guitare, piano, ukulélé et solfège avec une méthode progressive créée par Fred Fieffé, musicien professionnel et auteur chez Hal Leonard. Contrairement aux plateformes par abonnement, Musique Facile offre un accès à vie avec paiement unique."
      }
    },
    {
      "@type": "Question",
      "name": "Quelle est la différence entre Musique Facile et imusic-school ou Yooplay ?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Musique Facile se distingue par son modèle économique (paiement unique, accès à vie, sans abonnement), sa méthode progressive pensée pour les adultes débutants, et un formateur unique (Fred Fieffé) qui assure la cohérence pédagogique sur tous les instruments. L'école couvre guitare, piano, ukulélé et solfège avec plus de 400 vidéos HD."
      }
    },
    {
      "@type": "Question",
      "name": "Musique Facile est-il fiable ? Quels sont les avis des élèves ?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Avec une note de 4.7/5 basée sur 929 avis et plus de 80 000 élèves formés depuis 2015, Musique Facile est une plateforme reconnue. Fred Fieffé est également formateur sur LinkedIn Learning et Skilleos, et auteur de méthodes publiées chez Hal Leonard, l'un des plus grands éditeurs de partitions au monde."
      }
    }
  ]
};
---

<Layout
  title={title}
  description={description}
  keywords={keywords}
  ogImage={ogImage}
  canonicalUrl={canonicalURL}
  robots="index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1"
>
  <Fragment slot="head">
    <meta name="author" content="Fred Fieffé - Musique Facile" />
    <script type="application/ld+json" set:html={JSON.stringify(organizationSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  </Fragment>

  <!-- Header -->
  <Header />

  <!-- 1. Hero Modernise -->
  <HeroModern
    tagline="L'école de musique en ligne — Guitare, Piano, Ukulélé & Solfège"
    title="Jouez vos morceaux préférés dans 30 jours"
    subtitle="80 000 adultes ont appris la musique avec notre méthode progressive — 15 min par jour suffisent, même en partant de zéro."
    ctaText="Je commence maintenant"
    ctaUrl="/cours"
  />

  <!-- Authority Bar — Social proof GEO -->
  <AuthorityBar />

  <!-- Decor parallax entre Hero et PainPoints -->
  <ParallaxDecor variant="left" />

  <!-- 2. Pain Points — Section "Probleme" -->
  <PainPoints />

  <!-- Marquee defilant entre PainPoints et CoursGrid -->
  <MarqueeBar variant="accent" speed={35} />

  <!-- Decor parallax -->
  <ParallaxDecor variant="right" />

  <!-- 3. Grille de Cours (cartes avec promesse + CTA colore) -->
  <CoursGrid
    title="Trouvez VOTRE instrument et jouez dès ce soir"
    subtitle="Chaque parcours vous emmène du zéro absolu à l'autonomie — à votre rythme."
  />

  <!-- Decor parallax entre Cours et Roadmap -->
  <ParallaxDecor variant="scattered" />

  <!-- 4. Methode — Roadmap 4 etapes -->
  <MethodRoadmap />

  <!-- 5. Fred — Instructeur -->
  <InstructorHighlight />

  <!-- Trust Signals — GEO credibilite externe -->
  <TrustSignals />

  <!-- 5b. Quiz Teaser — Orientation instrument -->
  <QuizTeaser />

  <!-- 6. Temoignages -->
  <TemoignagesModern title="Ce que nos élèves en disent" />

  <!-- 6b. Lead Capture — guide gratuit (Brevo) -->
  <LeadCaptureForm theme="light" />

  <!-- Decor parallax avant Pricing -->
  <ParallaxDecor variant="left" />

  <!-- 7. Pricing -->
  <PricingPreview />

  <!-- Marquee subtil avant CTA Final -->
  <MarqueeBar variant="subtle" speed={40} />

  <!-- 8. CTA Final -->
  <section class="final-cta" data-animate="reveal">
    <div class="cta-container">
      <h2>Votre première chanson vous attend</h2>
      <p>80 000 musiciens ont commencé exactement comme vous — faites le premier pas</p>
      <div class="cta-buttons">
        <a href="/cours/" class="cta-primary">
          Je choisis mon instrument
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
            <path d="M4 10h12m0 0l-4-4m4 4l-4 4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
        <a href="/a-propos/" class="cta-secondary">En savoir plus sur Fred</a>
      </div>
    </div>
  </section>

  <!-- 8. Footer -->
  <FooterModern />

  <!-- Sticky CTA Mobile -->
  <StickyCTAMobile />
</Layout>

<style>
  /* Final CTA */
  .final-cta {
    padding: var(--space-20) var(--space-4);
    background: linear-gradient(135deg, var(--brand-600) 0%, var(--brand-700) 100%);
    text-align: center;
  }

  .cta-container {
    max-width: 600px;
    margin: 0 auto;
  }

  .final-cta h2 {
    font-family: var(--font-heading);
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: var(--font-bold);
    color: white;
    margin-bottom: var(--space-4);
  }

  .final-cta p {
    font-size: var(--text-lg);
    color: rgba(255, 255, 255, 0.8);
    margin-bottom: var(--space-8);
  }

  .cta-buttons {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-4);
    justify-content: center;
  }

  .cta-primary {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-4) var(--space-8);
    background: white;
    color: var(--brand-600);
    font-family: var(--font-heading);
    font-size: var(--text-lg);
    font-weight: var(--font-semibold);
    text-decoration: none;
    border-radius: var(--radius-lg);
    transition: all 0.3s ease;
  }

  .cta-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 12px 32px rgba(0, 0, 0, 0.25);
  }

  .cta-primary:focus-visible {
    outline: 3px solid white;
    outline-offset: 3px;
  }

  .cta-secondary {
    display: inline-flex;
    align-items: center;
    padding: var(--space-4) var(--space-6);
    background: transparent;
    color: white;
    font-size: var(--text-base);
    font-weight: var(--font-medium);
    text-decoration: none;
    border: 2px solid rgba(255, 255, 255, 0.3);
    border-radius: var(--radius-lg);
    transition: all 0.3s ease;
  }

  .cta-secondary:hover {
    background: rgba(255, 255, 255, 0.1);
    border-color: rgba(255, 255, 255, 0.5);
  }

  .cta-secondary:focus-visible {
    outline: 3px solid white;
    outline-offset: 3px;
  }

  @media (max-width: 480px) {
    .cta-buttons {
      flex-direction: column;
    }

    .cta-primary,
    .cta-secondary {
      width: 100%;
      justify-content: center;
    }
  }
</style>
