---
/**
 * /liens — Page hub « link in bio » (style Linktree, mais hébergée et propriétaire).
 *
 * Objectif n°1 : faire entrer en contact (bouton « Me contacter » → formulaire Brevo).
 * Objectif n°2 : diffuser les contenus (YouTube / TikTok / Instagram / site) et
 *                orienter les enseignants vers Kid&zic.
 *
 * Mobile-first absolu, branding violet Musique Facile (#6C3FA0), SEO/GEO soignés.
 * Le formulaire poste sur /api/contact (clé Brevo côté serveur) avec fallback mailto:.
 *
 * ┌─────────────────────────────────────────────────────────────────────┐
 * │ AVANT MISE EN LIGNE — voir les variables à régler en bas de ce fichier │
 * └─────────────────────────────────────────────────────────────────────┘
 */
import Layout from '../layouts/Layout.astro';

// ── Constantes de page ──────────────────────────────────────────────
const canonicalUrl = 'https://musique-facile.fr/liens/';
const photo = 'https://musique-facile.fr/images/prof/fred.webp';
const contactEmail = 'support@musique-facile.fr';

const title = 'Liens Musique Facile — Contact, YouTube, TikTok & Instagram | Fred Fieffé';
const description =
  'Contactez Fred Fieffé et retrouvez tous les contenus Musique Facile : chaîne YouTube, TikTok, Instagram et le site officiel. Apprendre la guitare, le ukulélé et le piano simplement. Enseignants : découvrez Kid&zic.';

// UTM ajoutés sur chaque lien sortant pour le tracking
const withUtm = (url: string) =>
  url + (url.includes('?') ? '&' : '?') + 'utm_source=hub&utm_medium=liens&utm_campaign=hub_musiquefacile';

// BLOC 2 — Mes contenus
const contentLinks = [
  {
    href: 'https://www.youtube.com/@musique-facile',
    emoji: '📺',
    label: 'YouTube',
    sub: 'Cours & tutos en vidéo',
    aria: 'Ma chaîne YouTube Musique Facile (nouvel onglet)',
    external: true,
  },
  {
    href: 'https://www.tiktok.com/@musique_facile',
    emoji: '🎵',
    label: 'TikTok',
    sub: 'Astuces musique en 60 secondes',
    aria: 'Mon compte TikTok Musique Facile (nouvel onglet)',
    external: true,
  },
  {
    href: 'https://www.instagram.com/musique_facile/',
    emoji: '📸',
    label: 'Instagram',
    sub: 'Coulisses & inspiration',
    aria: 'Mon compte Instagram Musique Facile (nouvel onglet)',
    external: true,
  },
  {
    href: 'https://musique-facile.fr/',
    emoji: '🌐',
    label: 'Mon site',
    sub: 'Cours de guitare, ukulélé & piano',
    aria: 'Le site Musique Facile',
    external: false,
  },
];

// ── Schema.org (SEO + GEO : entité Fred + Organisation, citables par les LLM) ──
const sameAs = [
  'https://www.youtube.com/@musique-facile',
  'https://www.tiktok.com/@musique_facile',
  'https://www.instagram.com/musique_facile/',
  'https://musique-facile.fr',
];

const profileSchema = {
  '@context': 'https://schema.org',
  '@type': 'ProfilePage',
  dateModified: new Date().toISOString(),
  mainEntity: {
    '@type': 'Person',
    name: 'Fred Fieffé',
    alternateName: 'Musique Facile',
    url: 'https://musique-facile.fr/auteur/fred-fieffe/',
    image: photo,
    jobTitle: 'Musicien professionnel et formateur',
    description:
      "Musicien depuis plus de 40 ans, 15 ans d'enseignement, fondateur de Musique Facile. Il aide à apprendre la guitare, le ukulélé et le piano simplement.",
    knowsAbout: ['guitare', 'ukulélé', 'piano', 'solfège', 'pédagogie musicale'],
    sameAs,
    worksFor: {
      '@type': 'Organization',
      name: 'Musique Facile',
      url: 'https://musique-facile.fr',
    },
  },
};

const organizationSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'Musique Facile',
  url: 'https://musique-facile.fr',
  logo: 'https://musique-facile.fr/images/prof/fred.webp',
  founder: { '@type': 'Person', name: 'Fred Fieffé' },
  sameAs,
  contactPoint: {
    '@type': 'ContactPoint',
    contactType: 'customer support',
    email: contactEmail,
    areaServed: 'FR',
    availableLanguage: 'French',
  },
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Accueil', item: 'https://musique-facile.fr' },
    { '@type': 'ListItem', position: 2, name: 'Liens', item: canonicalUrl },
  ],
};
---

<Layout
  title={title}
  description={description}
  canonicalUrl={canonicalUrl}
  ogImage="https://musique-facile.fr/images/og-default.webp"
  keywords="Musique Facile, Fred Fieffé, liens, contact, YouTube, TikTok, Instagram, guitare, ukulélé, piano, Kid&zic"
>
  <Fragment slot="head">
    <meta name="author" content="Fred Fieffé - Musique Facile" />
    <script type="application/ld+json" set:html={JSON.stringify(profileSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(organizationSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />

    <!--
      ┌───────────────────────────────────────────────────────────────┐
      │ 📊 EMPLACEMENT PIXEL / ANALYTICS SUPPLÉMENTAIRE                  │
      │ GTM est déjà chargé via ConsentManager (après consentement).    │
      │ Pour un pixel dédié à cette page (Meta, TikTok…), colle-le ici : │
      └───────────────────────────────────────────────────────────────┘
    -->
    <!-- <script>/* ton pixel ici */</script> -->
  </Fragment>

  <div class="hub">
    <!-- ════════ HEADER ════════ -->
    <header class="hub-header">
      <img
        class="hub-avatar"
        src="/images/prof/fred.webp"
        width="112"
        height="112"
        alt="Fred Fieffé, fondateur de Musique Facile"
        fetchpriority="high"
        decoding="async"
      />
      <h1 class="hub-title">Musique Facile</h1>
      <p class="hub-tagline">
        Apprendre la musique simplement.<br />
        <span class="hub-instruments">Guitare&nbsp;• Ukulélé&nbsp;• Piano</span>
      </p>
    </header>

    <!-- ════════ BLOC 1 — CONTACT (CTA principal) ════════ -->
    <!--
      <details> = « section dépliante » : fonctionne SANS JavaScript.
      Le JS améliore l'envoi (POST /api/contact). Si le JS échoue,
      le bloc « écris-moi directement » sert de secours immédiat (mailto).
    -->
    <details class="contact" id="contact">
      <summary class="hub-btn hub-btn-contact">
        <span aria-hidden="true">📩</span> Me contacter
      </summary>

      <div class="contact-panel">
        <form id="contact-form" novalidate>
          <div class="field">
            <label for="c-name">Ton nom</label>
            <input id="c-name" name="name" type="text" autocomplete="name" required maxlength="120" placeholder="Ex : Camille" />
          </div>
          <div class="field">
            <label for="c-email">Ton email</label>
            <input id="c-email" name="email" type="email" autocomplete="email" required maxlength="254" placeholder="camille@email.com" />
          </div>
          <div class="field">
            <label for="c-message">Ton message</label>
            <textarea id="c-message" name="message" rows="4" required maxlength="2000" placeholder="Dis-moi tout en quelques mots…"></textarea>
          </div>

          <label class="consent">
            <input type="checkbox" name="consent" required />
            <span>J'accepte d'être recontacté(e) par Musique Facile au sujet de ma demande.</span>
          </label>

          <button type="submit" class="hub-btn hub-btn-submit">
            <span class="submit-text">Envoyer mon message</span>
            <span class="submit-loading" aria-hidden="true">Envoi…</span>
          </button>

          <p class="form-msg form-msg--ok" role="status" aria-live="polite">
            ✅ Merci&nbsp;! Ton message est parti, je te réponds vite.
          </p>
          <p class="form-msg form-msg--err" role="alert" aria-live="assertive">
            ⚠️ Oups, l'envoi a échoué. Écris-moi directement&nbsp;:
            <a href={`mailto:${contactEmail}`} class="mailto-fallback">{contactEmail}</a>
          </p>
        </form>

        <p class="contact-direct">
          Ou par email&nbsp;:
          <a href={`mailto:${contactEmail}`}>{contactEmail}</a>
        </p>
      </div>
    </details>

    <!-- ════════ BLOC 2 — MES CONTENUS ════════ -->
    <nav class="links" aria-label="Mes contenus">
      <p class="links-heading">Mes contenus</p>
      {contentLinks.map((l) => (
        <a
          class="hub-btn hub-btn-link"
          href={withUtm(l.href)}
          data-track={`content:${l.label}`}
          aria-label={l.aria}
          {...(l.external ? { target: '_blank', rel: 'noopener' } : {})}
        >
          <span class="hub-btn-emoji" aria-hidden="true">{l.emoji}</span>
          <span class="hub-btn-body">
            <span class="hub-btn-label">{l.label}</span>
            <span class="hub-btn-sub">{l.sub}</span>
          </span>
          <span class="hub-btn-chevron" aria-hidden="true">→</span>
        </a>
      ))}
    </nav>

    <!-- ════════ BLOC 3 — POUR LES ENSEIGNANTS ════════ -->
    <section class="links" aria-label="Pour les enseignants">
      <p class="links-heading">Pour les enseignants</p>
      <a
        class="hub-btn hub-btn-link hub-btn-teacher"
        href={withUtm('https://kidetzic.fr/')}
        data-track="teacher:kidzic"
        aria-label="Kid&zic, l'espace des professeurs des écoles (nouvel onglet)"
        target="_blank"
        rel="noopener"
      >
        <span class="hub-btn-emoji" aria-hidden="true">🎓</span>
        <span class="hub-btn-body">
          <span class="hub-btn-label">Kid&zic, l'espace des profs des écoles</span>
          <span class="hub-btn-sub">Musique et phonologie pour les cycles 1 à 3</span>
        </span>
        <span class="hub-btn-chevron" aria-hidden="true">→</span>
      </a>
    </section>

    <!-- ════════ FOOTER MINI ════════ -->
    <footer class="hub-footer">
      <nav aria-label="Liens légaux">
        <a href="/mentions-legales-cgv/">Mentions légales</a>
        <span aria-hidden="true">·</span>
        <a href="/politique-confidentialite/">Confidentialité</a>
        <span aria-hidden="true">·</span>
        <a href="/contact/">Contact</a>
      </nav>
      <p class="copyright">© 2026 Musique Facile · Fred Fieffé</p>
    </footer>
  </div>
</Layout>

<style>
  /* Le site n'a pas de reset box-sizing global → on l'applique (scopé au hub)
     sinon width:100% + padding + bordure font déborder les boutons à droite. */
  .hub,
  .hub *,
  .hub *::before,
  .hub *::after {
    box-sizing: border-box;
  }

  /* ════════ LAYOUT GÉNÉRAL (mobile-first) ════════ */
  .hub {
    max-width: 480px;
    margin: 0 auto;
    padding: var(--space-8) var(--space-4) var(--space-12);
    min-height: 100vh;
    background:
      radial-gradient(120% 60% at 50% 0%, var(--brand-50) 0%, transparent 60%),
      var(--surface-white);
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }

  /* ════════ HEADER ════════ */
  .hub-header {
    text-align: center;
    margin-bottom: var(--space-2);
  }

  .hub-avatar {
    width: 112px;
    height: 112px;
    border-radius: var(--radius-full);
    object-fit: cover;
    border: 4px solid var(--surface-white);
    box-shadow: 0 0 0 3px var(--brand-500), var(--shadow-brand);
    margin-bottom: var(--space-4);
  }

  .hub-title {
    font-family: var(--font-heading);
    font-size: var(--text-3xl);
    font-weight: var(--font-extrabold);
    color: var(--brand-700);
    margin: 0 0 var(--space-2);
    letter-spacing: var(--tracking-tight);
  }

  .hub-tagline {
    font-family: var(--font-body);
    font-size: var(--text-base);
    color: var(--text-secondary);
    margin: 0;
    line-height: var(--leading-snug);
  }

  .hub-instruments {
    display: inline-block;
    margin-top: var(--space-1);
    font-weight: var(--font-semibold);
    color: var(--brand-600);
  }

  /* ════════ BOUTONS (base partagée) ════════ */
  .hub-btn {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    width: 100%;
    padding: var(--space-4) var(--space-5);
    border-radius: var(--radius-xl);
    font-family: var(--font-heading);
    font-weight: var(--font-semibold);
    text-decoration: none;
    cursor: pointer;
    transition: transform var(--duration-fast) var(--ease-out),
                box-shadow var(--duration-base) var(--ease-out),
                background-color var(--duration-base) var(--ease-out);
  }

  .hub-btn:active {
    transform: scale(0.985);
  }

  /* ── CTA principal : Me contacter ── */
  .contact {
    margin-top: var(--space-2);
  }

  .hub-btn-contact {
    justify-content: center;
    background: var(--brand-500);
    color: #fff;
    font-size: var(--text-lg);
    box-shadow: var(--shadow-brand);
    list-style: none; /* masque le triangle <summary> (Firefox) */
    text-align: center;
  }

  /* masque le marqueur natif de <summary> (Chrome/Safari) */
  .hub-btn-contact::-webkit-details-marker { display: none; }

  .hub-btn-contact:hover {
    background: var(--brand-600);
    transform: translateY(-2px);
    box-shadow: 0 12px 26px rgba(108, 63, 160, 0.35);
  }

  .contact[open] .hub-btn-contact {
    border-radius: var(--radius-xl) var(--radius-xl) 0 0;
  }

  /* ── Panneau du formulaire ── */
  .contact-panel {
    background: var(--surface-white);
    border: 2px solid var(--brand-100);
    border-top: none;
    border-radius: 0 0 var(--radius-xl) var(--radius-xl);
    padding: var(--space-5);
    animation: slideDown var(--duration-base) var(--ease-out);
  }

  @keyframes slideDown {
    from { opacity: 0; transform: translateY(-6px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .field {
    margin-bottom: var(--space-4);
    text-align: left;
  }

  .field label {
    display: block;
    font-family: var(--font-heading);
    font-size: var(--text-sm);
    font-weight: var(--font-semibold);
    color: var(--text-secondary);
    margin-bottom: var(--space-2);
  }

  .field input,
  .field textarea {
    width: 100%;
    padding: var(--space-3) var(--space-4);
    font-family: var(--font-body);
    font-size: var(--text-base); /* 16px = pas de zoom auto iOS */
    color: var(--text-primary);
    background: var(--surface-light);
    border: 2px solid var(--border-default);
    border-radius: var(--radius-md);
    transition: border-color var(--duration-fast) var(--ease-out);
  }

  .field textarea { resize: vertical; min-height: 96px; }

  .field input:focus,
  .field textarea:focus {
    outline: none;
    border-color: var(--brand-500);
  }

  .consent {
    display: flex;
    align-items: flex-start;
    gap: var(--space-2);
    font-size: var(--text-sm);
    color: var(--text-secondary);
    text-align: left;
    margin-bottom: var(--space-4);
    cursor: pointer;
  }

  .consent input { margin-top: 0.2em; flex-shrink: 0; }

  .hub-btn-submit {
    justify-content: center;
    background: var(--brand-600);
    color: #fff;
    font-size: var(--text-base);
    border: none;
    box-shadow: var(--shadow-sm);
  }

  .hub-btn-submit:hover:not(:disabled) { background: var(--brand-700); }
  .hub-btn-submit:disabled { opacity: 0.7; cursor: not-allowed; }

  .submit-loading { display: none; }
  #contact-form.loading .submit-text { display: none; }
  #contact-form.loading .submit-loading { display: inline; }

  /* Messages succès / erreur (cachés par défaut) */
  .form-msg {
    display: none;
    margin: var(--space-4) 0 0;
    padding: var(--space-3) var(--space-4);
    border-radius: var(--radius-md);
    font-size: var(--text-sm);
    text-align: center;
  }

  .form-msg--ok  { background: var(--success-50); color: var(--success-700); }
  .form-msg--err { background: var(--error-50);   color: var(--error-700); }

  #contact-form.ok    .form-msg--ok  { display: block; }
  #contact-form.ok    .field,
  #contact-form.ok    .consent,
  #contact-form.ok    .hub-btn-submit     { display: none; }
  #contact-form.error .form-msg--err  { display: block; }

  .mailto-fallback { color: inherit; font-weight: var(--font-bold); }

  .contact-direct {
    text-align: center;
    font-size: var(--text-sm);
    color: var(--text-muted);
    margin: var(--space-4) 0 0;
  }
  .contact-direct a { color: var(--brand-600); font-weight: var(--font-semibold); }

  /* ════════ BLOCS DE LIENS ════════ */
  .links { display: flex; flex-direction: column; gap: var(--space-3); }

  .links-heading {
    font-family: var(--font-heading);
    font-size: var(--text-xs);
    font-weight: var(--font-bold);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wider);
    color: var(--text-muted);
    margin: var(--space-2) 0 0;
    padding-left: var(--space-1);
  }

  .hub-btn-link {
    background: var(--surface-white);
    color: var(--text-primary);
    border: 2px solid var(--brand-100);
    box-shadow: var(--shadow-sm);
  }

  .hub-btn-link:hover {
    transform: translateY(-2px);
    border-color: var(--brand-300);
    box-shadow: var(--shadow-md);
  }

  .hub-btn-emoji {
    font-size: 1.6rem;
    line-height: 1;
    flex-shrink: 0;
    width: 2rem;
    text-align: center;
  }

  .hub-btn-body { display: flex; flex-direction: column; flex: 1; min-width: 0; }
  .hub-btn-label { font-size: var(--text-base); font-weight: var(--font-semibold); }
  .hub-btn-sub {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    font-weight: var(--font-normal);
    color: var(--text-muted);
  }

  .hub-btn-chevron {
    flex-shrink: 0;
    color: var(--brand-400);
    font-size: var(--text-lg);
    transition: transform var(--duration-fast) var(--ease-out);
  }
  .hub-btn-link:hover .hub-btn-chevron { transform: translateX(3px); }

  /* Bloc enseignants : mis en avant */
  .hub-btn-teacher {
    background: var(--brand-50);
    border-color: var(--brand-200);
  }
  .hub-btn-teacher:hover { border-color: var(--brand-400); }

  /* ════════ FOOTER MINI ════════ */
  .hub-footer {
    text-align: center;
    margin-top: var(--space-4);
    font-size: var(--text-sm);
  }

  .hub-footer nav { display: inline-flex; flex-wrap: wrap; justify-content: center; gap: var(--space-2); }
  .hub-footer a { color: var(--text-muted); text-decoration: none; }
  .hub-footer a:hover { color: var(--brand-600); text-decoration: underline; }
  .hub-footer span { color: var(--gray-300); }

  .copyright { color: var(--text-muted); margin: var(--space-3) 0 0; font-size: var(--text-xs); }

  /* ════════ RESPONSIVE — petits écrans ════════ */
  @media (max-width: 380px) {
    .hub { padding: var(--space-6) var(--space-3) var(--space-10); }
    .hub-title { font-size: var(--text-2xl); }
  }
</style>

<script>
  // ════════ Formulaire de contact → POST /api/contact (Brevo, clé côté serveur) ════════
  // Fallback : si le réseau / l'API échoue, on affiche un message + lien mailto.
  const form = document.getElementById('contact-form') as HTMLFormElement | null;

  if (form) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      form.classList.remove('error', 'ok');

      const name = (form.querySelector('#c-name') as HTMLInputElement)?.value.trim();
      const email = (form.querySelector('#c-email') as HTMLInputElement)?.value.trim();
      const message = (form.querySelector('#c-message') as HTMLTextAreaElement)?.value.trim();
      const consent = (form.querySelector('input[name="consent"]') as HTMLInputElement)?.checked;

      // Validation native (champs requis + email valide)
      if (!form.reportValidity() || !name || !email || !message || !consent) return;

      form.classList.add('loading');
      const submitBtn = form.querySelector('.hub-btn-submit') as HTMLButtonElement;
      if (submitBtn) submitBtn.disabled = true;

      try {
        const res = await fetch('/api/contact', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ name, email, message, consent: true, source: 'hub:/liens' }),
        });
        const data = await res.json().catch(() => ({}));

        if (res.ok && data.ok) {
          form.classList.add('ok');
          if ((window as any).gtag) {
            (window as any).gtag('event', 'contact_submit', { event_category: 'hub', event_label: 'liens' });
          }
        } else {
          throw new Error('contact failed');
        }
      } catch {
        form.classList.add('error');
      } finally {
        form.classList.remove('loading');
        if (submitBtn) submitBtn.disabled = false;
      }
    });
  }

  // ════════ Tracking des clics sortants (GTM / GA si présent) ════════
  document.querySelectorAll<HTMLAnchorElement>('[data-track]').forEach((a) => {
    a.addEventListener('click', () => {
      if ((window as any).gtag) {
        (window as any).gtag('event', 'hub_click', {
          event_category: 'hub',
          event_label: a.getAttribute('data-track'),
        });
      }
    });
  });
</script>
