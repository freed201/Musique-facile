---
// Page rendue à la volée (SSR) pour pouvoir lire le paramètre ?lm= dans l'URL.
// Sans prerender:false, Astro.url.searchParams renverrait toujours vide au build.
export const prerender = false;

import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import FooterModern from '../components/FooterModern.astro';

// Catalogue des lead magnets actuels.
// Pour en ajouter un : nouvel ID + métadonnées ci-dessous.
const leadMagnets: Record<string, {
  title: string;
  pdfUrl: string;
  instrument: 'guitare' | 'piano' | 'ukulele';
  courseUrl: string;
  emoji: string;
}> = {
  'guitare-5-accords-magiques': {
    title: 'Les 5 Accords Magiques',
    pdfUrl: '/lead-magnets/guitare-5-accords-magiques.pdf',
    instrument: 'guitare',
    courseUrl: '/cours/cours-de-guitare/',
    emoji: '🎸',
  },
  'piano-lire-les-notes': {
    title: 'Lire les notes au piano — 5 astuces',
    pdfUrl: '/lead-magnets/piano-lire-les-notes.pdf',
    instrument: 'piano',
    courseUrl: '/cours/cours-de-piano/',
    emoji: '🎹',
  },
  'ukulele-4-accords': {
    title: 'Les 4 Accords du Ukulélé',
    pdfUrl: '/lead-magnets/ukulele-4-accords.pdf',
    instrument: 'ukulele',
    courseUrl: '/cours/cours-de-ukulele/',
    emoji: '🌺',
  },
};

// Lecture du paramètre ?lm= côté serveur si SSR, sinon défaut.
const lmParam = Astro.url.searchParams.get('lm') || 'guitare-5-accords-magiques';
const lm = leadMagnets[lmParam] || leadMagnets['guitare-5-accords-magiques'];

const title = `Merci ! Ton guide "${lm.title}" arrive | Musique Facile`;
const description = `Ton guide ${lm.title} arrive dans quelques instants. Découvre aussi nos formations complètes.`;
---

<Layout title={title} description={description} robots="noindex, nofollow">
  <Header />

  <main class="thank-you-page">
    <section class="ty-hero">
      <div class="container">
        <div class="ty-content">
          <div class="success-animation">
            <div class="checkmark-circle">
              <div class="checkmark"></div>
            </div>
          </div>

          <h1 class="ty-title">🎉 C'est bon, ton guide arrive !</h1>
          <p class="ty-subtitle">
            Ton guide <strong>{lm.emoji} {lm.title}</strong> arrive dans ta boîte mail
            dans les <strong>2 prochaines minutes</strong>.
          </p>

          <div class="ty-download-now">
            <p class="ty-download-intro">Tu peux aussi le télécharger tout de suite&nbsp;:</p>
            <a
              href={lm.pdfUrl}
              class="ty-download-btn"
              download
              data-lead-magnet={lmParam}
            >
              ⬇️ Télécharger le PDF maintenant
            </a>
          </div>

          <div class="ty-instructions">
            <h2>Et après&nbsp;?</h2>
            <ol>
              <li>
                <strong>📧 Vérifie ta boîte mail</strong><br />
                <small>Regarde aussi dans tes spams/promotions au cas où</small>
              </li>
              <li>
                <strong>📥 Garde le PDF sous la main</strong><br />
                <small>Imprime-le si tu veux l'avoir à côté de toi quand tu joues</small>
              </li>
              <li>
                <strong>{lm.emoji} Commence ce soir</strong><br />
                <small>15 minutes suffisent pour faire ta première progression</small>
              </li>
            </ol>
          </div>

          <div class="ty-timer">
            ⏱️ Redirection automatique vers les cours dans <strong id="countdown">15</strong> secondes…
          </div>
        </div>
      </div>
    </section>

    <section class="ty-upsell">
      <div class="container">
        <div class="upsell-banner">
          <h2>🚀 Envie d'aller plus loin&nbsp;?</h2>
          <p>Tu as les bases. Le cours complet te prend par la main pour les 90 prochains jours.</p>
        </div>

        <div class="upsell-offer">
          <div class="upsell-card featured">
            <div class="upsell-badge">⚡ Recommandé</div>
            <h3>{lm.emoji} Cours {lm.instrument === 'guitare' ? 'de Guitare' : lm.instrument === 'piano' ? 'de Piano' : 'd\'Ukulélé'} complet</h3>
            <ul class="upsell-benefits">
              <li>✓ Vidéos pas à pas, du premier accord au premier morceau</li>
              <li>✓ La méthode Fred Fieffé, 15 ans d'enseignement</li>
              <li>✓ Accès à vie + mises à jour</li>
              <li>✓ Support direct par email</li>
              <li>✓ <strong>Garantie satisfait ou remboursé 15 jours</strong></li>
            </ul>
            <a href={lm.courseUrl} class="upsell-btn primary">
              {lm.emoji} Voir le cours complet
            </a>
          </div>

          <div class="upsell-card">
            <h3>Pack 3 Instruments</h3>
            <div class="price-box">
              <span class="old-price">€297</span>
              <span class="new-price">€149</span>
              <span class="discount">-50%</span>
            </div>
            <ul class="upsell-benefits">
              <li>✓ Guitare + Piano + Ukulélé</li>
              <li>✓ 200+ heures de formation</li>
              <li>✓ Économisez 148€</li>
              <li>✓ Devenez musicien complet</li>
            </ul>
            <a href="/cours/" class="upsell-btn secondary">
              🎹 Découvrir le pack
            </a>
          </div>
        </div>

        <div class="ty-alternative">
          <p>Tu préfères continuer en libre avec le guide gratuit&nbsp;?</p>
          <a href="/blog/">Pas de souci, explore le blog</a>
        </div>
      </div>
    </section>

    <section class="ty-social-proof">
      <div class="container">
        <h3>Ils ont adoré l'expérience Musique Facile</h3>
        <div class="testimonials-mini">
          <div class="testimonial-mini">
            <div class="stars">⭐⭐⭐⭐⭐</div>
            <p>"En une semaine, j'ai joué ma première chanson complète. Les vidéos sont ultra claires !"</p>
            <strong>Marine, débutante</strong>
          </div>
          <div class="testimonial-mini">
            <div class="stars">⭐⭐⭐⭐⭐</div>
            <p>"Fred explique chaque geste en détail. On progresse sans stress. Le support est top !"</p>
            <strong>Marc, 42 ans</strong>
          </div>
        </div>
      </div>
    </section>
  </main>

  <FooterModern />

  <style>
    :global(body) {
      background: #f8f9fc;
    }

    .thank-you-page {
      font-family: 'Poppins', sans-serif;
      color: #1a1a1a;
    }

    .ty-hero {
      padding: 6rem 0;
      background: linear-gradient(135deg, #1a1a1a 0%, #2d2d2d 100%);
      color: white;
      text-align: center;
    }

    .ty-title {
      font-size: 2.8rem;
      margin-bottom: 1rem;
    }

    .ty-subtitle {
      font-size: 1.2rem;
      margin-bottom: 2rem;
    }

    .ty-instructions {
      text-align: left;
      max-width: 600px;
      margin: 0 auto 2rem;
      background: rgba(255, 255, 255, 0.1);
      padding: 2rem;
      border-radius: 16px;
    }

    .ty-instructions h2 {
      margin-bottom: 1rem;
      font-size: 1.4rem;
    }

    .ty-instructions ol {
      list-style: decimal;
      padding-left: 1.5rem;
      display: flex;
      flex-direction: column;
      gap: 1rem;
    }

    .ty-instructions strong {
      color: #4CAF50;
    }

    .ty-timer {
      font-size: 1.1rem;
      font-weight: 600;
    }

    .ty-upsell {
      padding: 4rem 0;
    }

    .upsell-banner {
      text-align: center;
      margin-bottom: 3rem;
    }

    .upsell-offer {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
      gap: 2rem;
    }

    .upsell-card {
      background: white;
      border-radius: 20px;
      padding: 2rem;
      box-shadow: 0 20px 40px rgba(0, 0, 0, 0.1);
      position: relative;
      overflow: hidden;
    }

    .upsell-card.featured {
      border: 3px solid #4CAF50;
      transform: scale(1.02);
    }

    .upsell-badge {
      position: absolute;
      top: 1.5rem;
      right: -4rem;
      background: #ff6b6b;
      color: white;
      padding: 0.5rem 3rem;
      transform: rotate(45deg);
      font-weight: 700;
    }

    .price-box {
      display: flex;
      align-items: baseline;
      gap: 1rem;
      margin: 1.5rem 0;
    }

    .old-price {
      text-decoration: line-through;
      color: #888;
      font-size: 1.1rem;
    }

    .new-price {
      font-size: 2.2rem;
      font-weight: 700;
      color: #1a1a1a;
    }

    .discount {
      background: #4CAF50;
      color: white;
      padding: 0.25rem 0.75rem;
      border-radius: 999px;
      font-weight: 600;
    }

    .upsell-benefits {
      list-style: none;
      padding: 0;
      margin: 1.5rem 0;
      display: grid;
      gap: 0.75rem;
      color: #333;
    }

    .upsell-btn {
      display: block;
      text-align: center;
      padding: 0.85rem 1.25rem;
      font-weight: 600;
      border-radius: 12px;
      text-decoration: none;
      margin-top: 1.5rem;
      transition: transform 0.2s ease, box-shadow 0.2s ease;
    }

    .upsell-btn.primary {
      background: linear-gradient(135deg, #4CAF50 0%, #388e3c 100%);
      color: white;
    }

    .upsell-btn.primary:hover {
      transform: translateY(-2px);
      box-shadow: 0 12px 20px rgba(136, 190, 0, 0.3);
    }

    .upsell-btn.secondary {
      background: #f1f2f6;
      color: #1a1a1a;
    }

    .upsell-btn.secondary:hover {
      background: #e0e0e0;
    }

    .upsell-timer {
      text-align: center;
      margin-top: 1rem;
      color: #ff6b6b;
      font-weight: 600;
      font-size: 0.95rem;
    }

    .ty-alternative {
      text-align: center;
      color: #666;
    }

    .ty-alternative a {
      color: #4CAF50;
      font-weight: 600;
    }

    .ty-social-proof {
      padding: 4rem 0;
      background: #f8f9fc;
    }

    .ty-social-proof h3 {
      text-align: center;
      font-size: 2rem;
      color: #1a1a1a;
      margin-bottom: 2rem;
    }

    .testimonials-mini {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 2rem;
      max-width: 800px;
      margin: 0 auto;
    }

    .testimonial-mini {
      background: white;
      padding: 1.5rem;
      border-radius: 12px;
      box-shadow: 0 4px 15px rgba(0, 0, 0, 0.1);
    }

    .testimonial-mini .stars {
      font-size: 1.2rem;
      margin-bottom: 0.75rem;
    }

    .testimonial-mini p {
      color: #333;
      line-height: 1.6;
      margin-bottom: 0.75rem;
    }

    .testimonial-mini strong {
      color: #4CAF50;
    }

    .ty-download-now {
      margin: 1.5rem auto 2rem;
      max-width: 480px;
      text-align: center;
    }

    .ty-download-intro {
      margin: 0 0 0.75rem;
      font-size: 0.95rem;
      opacity: 0.85;
    }

    .ty-download-btn {
      display: inline-block;
      padding: 1rem 1.75rem;
      border-radius: 12px;
      background: #4CAF50;
      color: white;
      font-weight: 700;
      font-size: 1.05rem;
      text-decoration: none;
      transition: transform 0.2s ease, box-shadow 0.2s ease, background 0.2s ease;
    }

    .ty-download-btn:hover {
      transform: translateY(-2px);
      background: #43a047;
      box-shadow: 0 8px 24px rgba(76, 175, 80, 0.35);
    }

    @media (max-width: 1024px) {
      .upsell-offer {
        grid-template-columns: 1fr;
      }

      .upsell-card.featured {
        transform: scale(1);
      }

      .testimonials-mini {
        grid-template-columns: 1fr;
      }
    }

    @media (max-width: 768px) {
      .ty-title {
        font-size: 2.2rem;
      }

      .ty-hero {
        padding: 4rem 0;
      }
    }
  </style>

  <script define:vars={{ courseUrl: lm.courseUrl, leadMagnetId: lmParam }}>
    type W = Window & { dataLayer?: Array<Record<string, unknown>> };
    let timeLeft = 15;
    const countdownElement = document.getElementById('countdown');

    const countdownInterval = setInterval(() => {
      timeLeft--;
      if (countdownElement) {
        countdownElement.textContent = timeLeft.toString();
      }
      if (timeLeft <= 0) {
        clearInterval(countdownInterval);
        window.location.href = courseUrl;
      }
    }, 1000);

    document.querySelectorAll('.upsell-btn, .ty-alternative a, .ty-download-btn').forEach((el) => {
      el.addEventListener('click', () => clearInterval(countdownInterval));
    });

    const downloadBtn = document.querySelector('.ty-download-btn');
    if (downloadBtn) {
      downloadBtn.addEventListener('click', () => {
        const w = window as W;
        if (w.dataLayer) {
          w.dataLayer.push({
            event: 'lead_magnet_download',
            leadMagnet: leadMagnetId,
          });
        }
      });
    }
  </script>
</Layout>
