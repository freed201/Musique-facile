      flex-direction: column;
    }

    .btn-restart,
    .btn-explore {
      width: 100%;
      justify-content: center;
    }
  }
</style>

<script define:vars={{ quizData }}>
  let currentQuestionIndex = 0;
  let scores = { piano: 0, guitare: 0, ukulele: 0, solfege: 0 };
  let isTransitioning = false;

  // --- Instrument color map (CSS var references) ---
  const instrumentColors = {
    piano: { main: '#2196F3', dark: '#1976d2', light: '#e3f2fd' },
    guitare: { main: '#4CAF50', dark: '#388e3c', light: '#e8f5e9' },
    ukulele: { main: '#FF9800', dark: '#f57c00', light: '#fff3e0' },
    solfege: { main: '#E53935', dark: '#c62828', light: '#ffebee' }
  };

  function renderQuestion(questionIndex, direction) {
    const question = quizData.questions[questionIndex];
    const viewport = document.getElementById('slideViewport');

    let optionsHTML = '';
    question.options.forEach((option, index) => {
      const iconSpan = option.icon ? `<span class="option-emoji" aria-hidden="true">${option.icon}</span>` : '';
      optionsHTML += `
        <button class="option-button" data-option="${index}" type="button">
          ${iconSpan}
          <span>${option.text}</span>
        </button>
      `;
    });

    const newSlide = document.createElement('div');
    newSlide.className = 'quiz-slide';
    newSlide.innerHTML = `
      <h2 class="question-title">${question.question}</h2>
      <div class="options-grid">
        ${optionsHTML}
      </div>
    `;

    if (direction === 'none') {
      // Initial render — no animation
      viewport.innerHTML = '';
      viewport.appendChild(newSlide);
      attachOptionHandlers(newSlide, question);
      return;
    }

    isTransitioning = true;

    // Slide-out the current slide
    const currentSlide = viewport.querySelector('.quiz-slide');
    if (currentSlide) {
      currentSlide.classList.add('slide-out-left');
    }

    // Prepare the new slide off-screen
    newSlide.classList.add('slide-in-right');
    viewport.appendChild(newSlide);

    // Force reflow then animate in
    newSlide.offsetHeight;
    requestAnimationFrame(() => {
      newSlide.classList.remove('slide-in-right');
    });

    // Clean up after transition
    setTimeout(() => {
      if (currentSlide && currentSlide.parentNode) {
        currentSlide.remove();
      }
      isTransitioning = false;
    }, 400);

    attachOptionHandlers(newSlide, question);
  }

  function attachOptionHandlers(slide, question) {
    const buttons = slide.querySelectorAll('.option-button');
    buttons.forEach(button => {
      button.addEventListener('click', () => {
        if (isTransitioning) return;

        // Visual selection
        buttons.forEach(btn => btn.classList.remove('selected'));
        button.classList.add('selected');

        // Score points
        const optionIndex = parseInt(button.dataset.option);
        const points = question.options[optionIndex].points;
        Object.keys(points).forEach(instrument => {
          scores[instrument] += points[instrument];
        });

        // Auto-advance
        setTimeout(() => {
          currentQuestionIndex++;
          updateProgress();

          if (currentQuestionIndex < quizData.questions.length) {
            renderQuestion(currentQuestionIndex, 'forward');
          } else {
            showResults();
          }
        }, 400);
      });
    });
  }

  function updateProgress() {
    const steps = document.querySelectorAll('.progress-step');
    const totalQ = quizData.questions.length;

    steps.forEach((step, i) => {
      const stepNum = i + 1;
      step.classList.remove('active', 'done');
      if (stepNum < currentQuestionIndex + 1) {
        step.classList.add('done');
      } else if (stepNum === currentQuestionIndex + 1) {
        step.classList.add('active');
      }
    });

    // Fill connecting lines
    const line1 = document.getElementById('progressLine1');
    const line2 = document.getElementById('progressLine2');

    if (currentQuestionIndex >= 1) {
      line1.style.width = '100%';
    } else {
      line1.style.width = '0%';
    }

    if (currentQuestionIndex >= 2) {
      line2.style.width = '100%';
    } else {
      line2.style.width = '0%';
    }

    const currentSpan = document.getElementById('currentQuestion');
    currentSpan.textContent = Math.min(currentQuestionIndex + 1, totalQ);
  }

  function showResults() {
    // Determine winner
    let maxScore = 0;
    let recommendedInstrument = 'guitare';
    Object.keys(scores).forEach(instrument => {
      if (scores[instrument] > maxScore) {
        maxScore = scores[instrument];
        recommendedInstrument = instrument;
      }
    });

    const result = quizData.results[recommendedInstrument];
    const colors = instrumentColors[recommendedInstrument];

    // Hide quiz card + progress
    document.getElementById('quizCard').classList.add('hidden');
    document.getElementById('progressContainer').classList.add('hidden');

    // Show results
    const resultsSection = document.getElementById('resultsSection');
    resultsSection.classList.remove('hidden');

    // Apply instrument color theming
    const resultContent = document.getElementById('resultContent');
    document.getElementById('resultIcon').textContent = result.icon;

    const titleEl = document.getElementById('resultTitle');
    titleEl.textContent = result.title;
    titleEl.style.color = colors.dark;

    document.getElementById('resultDescription').textContent = result.description;

    // Benefits with instrument color bg
    const benefitsBox = document.getElementById('resultBenefitsBox');
    benefitsBox.style.background = colors.light;
    benefitsBox.style.color = colors.dark;
    const benefitsList = document.getElementById('resultBenefits');
    benefitsList.innerHTML = result.benefits.map(b => `<li>${b}</li>`).join('');

    // Course card
    const courseCard = document.getElementById('courseCard');
    courseCard.style.borderColor = colors.main;
    courseCard.innerHTML = `
      <img src="${result.course.image}" alt="${result.course.title}" class="course-image" loading="lazy" />
      <div class="course-info">
        <span class="course-title">${result.course.title}</span>
        <span class="course-price" style="color:${colors.dark}">
          ${result.course.price}&euro;
          <span class="price-suffix">/ accès à vie</span>
        </span>
        <a href="${result.course.url}" class="course-cta" style="background:${colors.main}">
          Je commence maintenant
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14m0 0l-6-6m6 6l-6 6"/></svg>
        </a>
      </div>
    `;

    // Confetti
    spawnConfetti(colors.main);

    // Scroll
    setTimeout(() => {
      resultsSection.scrollIntoView({ behavior: 'smooth', block: 'start' });
    }, 150);
  }

  function spawnConfetti(baseColor) {
    const container = document.getElementById('resultConfetti');
    container.innerHTML = '';
    const confettiColors = [baseColor, '#6C3FA0', '#f59e0b', '#10b981', '#ef4444', '#3b82f6'];

    for (let i = 0; i < 30; i++) {
      const piece = document.createElement('div');
      piece.className = 'confetti-piece';
      piece.style.left = Math.random() * 100 + '%';
      piece.style.background = confettiColors[Math.floor(Math.random() * confettiColors.length)];
      piece.style.animationDelay = Math.random() * 0.8 + 's';
      piece.style.animationDuration = (1.5 + Math.random() * 1.5) + 's';
      piece.style.width = (6 + Math.random() * 6) + 'px';
      piece.style.height = (6 + Math.random() * 6) + 'px';
      container.appendChild(piece);
    }
  }

  function restartQuiz() {
    currentQuestionIndex = 0;
    scores = { piano: 0, guitare: 0, ukulele: 0, solfege: 0 };

    document.getElementById('resultsSection').classList.add('hidden');
    document.getElementById('quizCard').classList.remove('hidden');
    document.getElementById('progressContainer').classList.remove('hidden');

    updateProgress();
    renderQuestion(0, 'none');

    window.scrollTo({ top: 0, behavior: 'smooth' });
  }

  // Wire restart button
  document.addEventListener('DOMContentLoaded', () => {
    renderQuestion(0, 'none');
    updateProgress();

    document.getElementById('btnRestart').addEventListener('click', restartQuiz);
  });
</script>
