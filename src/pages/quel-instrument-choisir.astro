---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import FooterModern from '../components/FooterModern.astro';
import AuthorBio from '../components/AuthorBio.astro';

const title = "Quel Instrument Choisir ? Quiz Gratuit | Musique Facile";
const description = "Découvrez l'instrument idéal pour vous en 3 questions ! Piano, guitare, ukulélé ou solfège : notre quiz gratuit vous guide vers le bon choix.";
const canonicalURL = new URL('/quel-instrument-choisir', Astro.site || 'https://musique-facile.fr').toString();

// Questions du quiz
const quizData = {
  questions: [
    {
      id: 1,
      question: "Quel est votre objectif musical principal ?",
      options: [
        { text: "Jouer mes chansons préférées rapidement", icon: "🎵", points: { ukulele: 3, guitare: 2, piano: 1 } },
        { text: "Maîtriser un instrument complet", icon: "🎯", points: { piano: 3, guitare: 2, ukulele: 1 } },
        { text: "Accompagner mes chants ou jouer en groupe", icon: "🎤", points: { guitare: 3, ukulele: 2, piano: 1 } },
        { text: "Comprendre la théorie musicale", icon: "📖", points: { piano: 3, solfege: 3, guitare: 1 } }
      ]
    },
    {
      id: 2,
      question: "Combien de temps pouvez-vous pratiquer par jour ?",
      options: [
        { text: "10-15 minutes (je suis très occupé)", icon: "⏱️", points: { ukulele: 3, guitare: 2, piano: 1 } },
        { text: "30 minutes à 1 heure", icon: "⏰", points: { guitare: 3, piano: 2, ukulele: 2 } },
        { text: "Plus d'1 heure (j'adore la musique !)", icon: "🔥", points: { piano: 3, guitare: 2, solfege: 2 } }
      ]
    },
    {
      id: 3,
      question: "Quel style de musique vous attire le plus ?",
      options: [
        { text: "Pop, folk, chansons françaises", icon: "🎸", points: { guitare: 3, ukulele: 2, piano: 2 } },
        { text: "Classique, jazz, musique de film", icon: "🎹", points: { piano: 3, guitare: 1, solfege: 2 } },
        { text: "Reggae, hawaïen, musique légère", icon: "🏝️", points: { ukulele: 3, guitare: 1, piano: 1 } },
        { text: "Rock, blues, musique énergique", icon: "🤘", points: { guitare: 3, piano: 2, ukulele: 0 } }
      ]
    }
  ],
  results: {
    piano: {
      title: "Le Piano est fait pour vous !",
      icon: "🎹",
      instrument: "piano",
      color: "var(--piano-500)",
      colorDark: "var(--piano-700)",
      colorLight: "var(--piano-50)",
      description: "Le piano est l'instrument idéal pour vous ! Il offre une compréhension complète de la musique, permet de jouer mélodie et accompagnement simultanément, et convient à tous les styles musicaux.",
      benefits: [
        "Instrument complet pour comprendre la musique",
        "Idéal pour composer et créer",
        "Adapté au classique, jazz, pop",
        "Base solide pour apprendre d'autres instruments"
      ],
      course: {
        title: "Piano Facile pour Débutants",
        url: "/cours/piano-facile-apprendre-debutant/",
        price: "299",
        image: "/images/cours/piano-facile-apprendre-debutant/hero.webp"
      }
    },
    guitare: {
      title: "La Guitare est faite pour vous !",
      icon: "🎸",
      instrument: "guitare",
      color: "var(--guitar-500)",
      colorDark: "var(--guitar-700)",
      colorLight: "var(--guitar-50)",
      description: "La guitare est l'instrument parfait pour vous ! Polyvalente et accessible, elle vous permet d'accompagner vos chansons préférées et de jouer dans tous les styles musicaux.",
      benefits: [
        "Instrument polyvalent et populaire",
        "Parfaite pour accompagner le chant",
        "Idéale pour jouer en groupe",
        "Adapté au rock, pop, folk, blues"
      ],
      course: {
        title: "Guitare Débutant Complet",
        url: "/cours/apprendre-guitare-debutant/",
        price: "89",
        image: "/images/cours/apprendre-guitare-debutant/hero.webp"
      }
    },
    ukulele: {
      title: "L'Ukulélé est fait pour vous !",
      icon: "🏝️",
      instrument: "ukulele",
      color: "var(--ukulele-500)",
      colorDark: "var(--ukulele-700)",
      colorLight: "var(--ukulele-50)",
      description: "L'ukulélé est l'instrument idéal pour vous ! Facile à apprendre, transportable et joyeux, il vous permet de jouer rapidement vos premières chansons avec un son ensoleillé.",
      benefits: [
        "Le plus facile à apprendre",
        "Compact et transportable",
        "Sons joyeux et relaxants",
        "Résultats rapides pour débutants"
      ],
      course: {
        title: "Ukulélé pour Tous - Débutant",
        url: "/cours/apprendre-ukulele-debutant/",
        price: "79",
        image: "/images/cours/apprendre-ukulele-debutant/hero.webp"
      }
    },
    solfege: {
      title: "Le Solfège est fait pour vous !",
      icon: "🎼",
      instrument: "solfege",
      color: "var(--solfege-500)",
      colorDark: "var(--solfege-700)",
      colorLight: "var(--solfege-50)",
      description: "Le solfège est parfait pour vous ! Vous voulez comprendre la musique en profondeur et avoir des bases solides. Le solfège ouvre toutes les portes musicales.",
      benefits: [
        "Compréhension profonde de la musique",
        "Facilite l'apprentissage de tous instruments",
        "Lecture de partitions maîtrisée",
        "Base théorique solide"
      ],
      course: {
        title: "Solfège Expert - Formation Complète",
        url: "/cours/solfege-expert-formation/",
        price: "79",
        image: "/images/cours/solfege-expert-formation/hero.webp"
      }
    }
  }
};

const instrumentOrder = ['guitare', 'piano', 'ukulele', 'solfege'];
const instrumentLabels = { guitare: 'Guitare', piano: 'Piano', ukulele: 'Ukulélé', solfege: 'Solfège' };
---

<Layout title={title} description={description} canonicalUrl={canonicalURL} robots="index, follow">
    <Header />

    <div class="quiz-page">
      <!-- Hero Section -->
      <section class="quiz-hero">
        <div class="container">
          <h1>Quel Instrument est Fait Pour Vous ?</h1>
          <p class="quiz-subtitle">Répondez à 3 questions simples et découvrez l'instrument idéal pour commencer la musique !</p>
          <div class="quiz-stats">
            <div class="stat">
              <span class="stat-icon" aria-hidden="true">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
              </span>
              <span class="stat-text">+15 000 personnes ont trouvé leur instrument</span>
            </div>
            <div class="stat">
              <span class="stat-icon" aria-hidden="true">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
              </span>
              <span class="stat-text">Quiz en 60 secondes</span>
            </div>
          </div>
        </div>
      </section>

      <!-- Quiz Container -->
      <section class="quiz-container">
        <div class="container">
          <!-- Progress Bar -->
          <div class="progress-container" id="progressContainer">
            <div class="progress-steps">
              <div class="progress-step active" data-step="1">
                <span class="step-number">1</span>
              </div>
              <div class="progress-line">
                <div class="progress-line-fill" id="progressLine1"></div>
              </div>
              <div class="progress-step" data-step="2">
                <span class="step-number">2</span>
              </div>
              <div class="progress-line">
                <div class="progress-line-fill" id="progressLine2"></div>
              </div>
              <div class="progress-step" data-step="3">
                <span class="step-number">3</span>
              </div>
            </div>
            <p class="progress-text">Question <span id="currentQuestion">1</span> sur 3</p>
          </div>

          <!-- Quiz Card with slide viewport -->
          <div class="quiz-card" id="quizCard">
            <div class="quiz-slide-viewport" id="slideViewport">
              <!-- Questions will be injected here -->
            </div>
          </div>

          <!-- Results Section (hidden initially) -->
          <div class="quiz-results hidden" id="resultsSection">
            <div class="result-content" id="resultContent">
              <div class="result-confetti" id="resultConfetti" aria-hidden="true"></div>
              <div class="result-icon" id="resultIcon"></div>
              <h2 id="resultTitle"></h2>
              <p class="result-description" id="resultDescription"></p>

              <div class="result-benefits" id="resultBenefitsBox">
                <h3>Pourquoi cet instrument vous convient :</h3>
                <ul id="resultBenefits"></ul>
              </div>

              <div class="result-course" id="resultCourseSection">
                <h3>Commencez dès maintenant avec notre cours :</h3>
                <div class="course-card" id="courseCard">
                  <!-- Course details will be injected -->
                </div>
              </div>

              <div class="result-actions">
                <button class="btn-restart" id="btnRestart" type="button">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="1 4 1 10 7 10"/><path d="M3.51 15a9 9 0 1 0 2.13-9.36L1 10"/></svg>
                  Refaire le quiz
                </button>
                <a href="/cours/" class="btn-explore">
                  Explorer tous les cours
                </a>
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- Social Proof -->
      <section class="quiz-testimonials">
        <div class="container">
          <h2>Ils ont trouvé leur instrument grâce au quiz</h2>
          <div class="testimonials-grid">
            <div class="testimonial">
              <div class="stars" aria-label="5 étoiles sur 5">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="#f59e0b"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                <svg width="18" height="18" viewBox="0 0 24 24" fill="#f59e0b"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                <svg width="18" height="18" viewBox="0 0 24 24" fill="#f59e0b"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                <svg width="18" height="18" viewBox="0 0 24 24" fill="#f59e0b"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                <svg width="18" height="18" viewBox="0 0 24 24" fill="#f59e0b"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
              </div>
              <p>"Le quiz m'a orienté vers l'ukulélé et je ne regrette rien ! En 2 semaines je jouais déjà mes premières chansons."</p>
              <strong>- Sophie, 34 ans</strong>
            </div>
            <div class="testimonial">
              <div class="stars" aria-label="5 étoiles sur 5">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="#f59e0b"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                <svg width="18" height="18" viewBox="0 0 24 24" fill="#f59e0b"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                <svg width="18" height="18" viewBox="0 0 24 24" fill="#f59e0b"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                <svg width="18" height="18" viewBox="0 0 24 24" fill="#f59e0b"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                <svg width="18" height="18" viewBox="0 0 24 24" fill="#f59e0b"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
              </div>
              <p>"J'hésitais entre piano et guitare. Le quiz m'a aidé à choisir le piano et c'était le bon choix pour moi !"</p>
              <strong>- Marc, 28 ans</strong>
            </div>
            <div class="testimonial">
              <div class="stars" aria-label="5 étoiles sur 5">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="#f59e0b"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                <svg width="18" height="18" viewBox="0 0 24 24" fill="#f59e0b"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                <svg width="18" height="18" viewBox="0 0 24 24" fill="#f59e0b"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                <svg width="18" height="18" viewBox="0 0 24 24" fill="#f59e0b"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                <svg width="18" height="18" viewBox="0 0 24 24" fill="#f59e0b"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
              </div>
              <p>"Super quiz ! J'ai découvert que la guitare correspondait parfaitement à mes objectifs musicaux."</p>
              <strong>- Julie, 42 ans</strong>
            </div>
          </div>
        </div>
      </section>
    </div>

    <!-- Réponse statique crawlable/citable : quel instrument selon le profil (contenu du quiz exposé en HTML) -->
  <section class="instrument-guide" aria-labelledby="ig-title">
    <div class="container">
      <h2 id="ig-title">Quel instrument choisir selon votre profil ?</h2>
      <p class="ig-intro">Pas envie de faire le quiz ? Voici, en un coup d'œil, l'instrument le plus adapté selon ce que vous recherchez. Tous nos cours débutants : paiement unique, accès à vie, garantie satisfait ou remboursé de 15 jours.</p>

      <div class="ig-scroll">
        <table class="ig-table">
          <thead>
            <tr><th scope="col">Instrument</th><th scope="col">Idéal si vous voulez…</th><th scope="col">Cours pour débuter</th><th scope="col">Prix</th></tr>
          </thead>
          <tbody>
            {instrumentOrder.map((key) => {
              const r = quizData.results[key];
              return (
                <tr>
                  <td><strong>{instrumentLabels[key]}</strong></td>
                  <td>{r.benefits[0]}</td>
                  <td><a href={r.course.url + '/'}>{r.course.title}</a></td>
                  <td><strong>{r.course.price} €</strong></td>
                </tr>
              );
            })}
          </tbody>
        </table>
      </div>

      <div class="ig-cards">
        {instrumentOrder.map((key) => {
          const r = quizData.results[key];
          return (
            <article class="ig-card">
              <h3>{r.title}</h3>
              <p>{r.description}</p>
              <ul>
                {r.benefits.map((b) => <li>{b}</li>)}
              </ul>
              <a class="ig-card-cta" href={r.course.url + '/'}>Découvrir le cours de {instrumentLabels[key].toLowerCase()} →</a>
            </article>
          );
        })}
      </div>
    </div>
  </section>

  <style>
    .instrument-guide { padding: var(--space-16) var(--space-4); background: var(--surface-light); }
    .instrument-guide .container { max-width: 900px; margin: 0 auto; }
    .instrument-guide h2 { font-family: var(--font-heading); font-size: clamp(1.6rem, 4vw, 2.4rem); font-weight: var(--font-bold); text-align: center; color: var(--gray-900); margin-bottom: var(--space-3); }
    .ig-intro { text-align: center; color: var(--gray-600); max-width: 64ch; margin: 0 auto var(--space-8); }
    .ig-scroll { overflow-x: auto; margin-bottom: var(--space-10); }
    .ig-table { width: 100%; border-collapse: collapse; font-size: var(--text-sm); }
    .ig-table th, .ig-table td { padding: var(--space-3) var(--space-4); text-align: left; border-bottom: 1px solid var(--gray-200); vertical-align: top; }
    .ig-table thead th { background: var(--surface); color: var(--gray-700); font-weight: var(--font-semibold); white-space: nowrap; }
    .ig-table a { color: var(--brand-600); font-weight: var(--font-medium); text-decoration: none; }
    .ig-table a:hover { text-decoration: underline; }
    .ig-cards { display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: var(--space-5); }
    .ig-card { background: var(--surface); border: 1px solid var(--gray-200); border-radius: var(--radius-lg); padding: var(--space-5); }
    .ig-card h3 { font-family: var(--font-heading); font-size: var(--text-lg); font-weight: var(--font-bold); color: var(--gray-900); margin-bottom: var(--space-3); }
    .ig-card p { color: var(--gray-700); line-height: 1.6; margin-bottom: var(--space-4); }
    .ig-card ul { list-style: none; padding: 0; margin: 0 0 var(--space-5); display: flex; flex-direction: column; gap: var(--space-2); }
    .ig-card li { color: var(--gray-700); padding-left: 1.4em; position: relative; }
    .ig-card li::before { content: "✓"; position: absolute; left: 0; color: var(--brand-600); font-weight: bold; }
    .ig-card-cta { color: var(--brand-600); font-weight: var(--font-semibold); text-decoration: none; }
    .ig-card-cta:hover { text-decoration: underline; }
  </style>

  <AuthorBio />

  <FooterModern />
</Layout>

<style>
  /* ============================================
     PAGE QUIZ — Design Amélioré Phase 6
     ============================================ */

  .quiz-page {
    background: var(--gray-50);
    min-height: 100vh;
  }

  /* --- Hero --- */
  .quiz-hero {
    text-align: center;
    padding: 6rem 0 3rem;
    background: linear-gradient(135deg, var(--brand-500) 0%, var(--brand-700) 100%);
    color: white;
  }

  .quiz-hero h1 {
    font-family: var(--font-heading, sans-serif);
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 800;
    margin-bottom: 1.5rem;
    color: white;
  }

  .quiz-subtitle {
    font-size: clamp(1.05rem, 2.5vw, 1.3rem);
    margin-bottom: 2rem;
    opacity: 0.95;
    max-width: 600px;
    margin-left: auto;
    margin-right: auto;
  }

  .quiz-stats {
    display: flex;
    justify-content: center;
    gap: 2rem;
    flex-wrap: wrap;
  }

  .stat {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    background: rgba(255, 255, 255, 0.15);
    padding: 0.75rem 1.5rem;
    border-radius: 50px;
    backdrop-filter: blur(10px);
    font-size: 0.95rem;
  }

  .stat-icon {
    display: flex;
    align-items: center;
  }

  .stat-icon svg {
    flex-shrink: 0;
  }

  .stat-text {
    font-weight: 500;
  }

  /* --- Quiz Container --- */
  .quiz-container {
    padding: 3rem 0 4rem;
  }

  /* --- Progress Steps --- */
  .progress-container {
    max-width: 400px;
    margin: 0 auto 2.5rem;
  }

  .progress-steps {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0;
    margin-bottom: 1rem;
  }

  .progress-step {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: var(--gray-200);
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    position: relative;
    flex-shrink: 0;
  }

  .progress-step.active {
    background: var(--brand-500);
    box-shadow: 0 0 0 4px rgba(108, 63, 160, 0.2);
    transform: scale(1.1);
  }

  .progress-step.done {
    background: var(--brand-500);
  }

  .step-number {
    font-weight: 700;
    font-size: 0.95rem;
    color: var(--gray-500);
    transition: color 0.3s ease;
  }

  .progress-step.active .step-number,
  .progress-step.done .step-number {
    color: white;
  }

  .progress-step.done .step-number {
    font-size: 0;
  }

  .progress-step.done::after {
    content: '';
    display: block;
    width: 12px;
    height: 6px;
    border-left: 2.5px solid white;
    border-bottom: 2.5px solid white;
    transform: rotate(-45deg);
    margin-top: -2px;
  }

  .progress-line {
    flex: 1;
    height: 3px;
    background: var(--gray-200);
    position: relative;
    overflow: hidden;
    max-width: 80px;
  }

  .progress-line-fill {
    position: absolute;
    top: 0;
    left: 0;
    height: 100%;
    width: 0%;
    background: var(--brand-500);
    transition: width 0.5s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .progress-text {
    text-align: center;
    font-weight: 600;
    color: var(--gray-600);
    font-size: 0.95rem;
  }

  /* --- Quiz Card & Slide --- */
  .quiz-card {
    max-width: 700px;
    margin: 0 auto;
    background: white;
    border-radius: 16px;
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.08);
    overflow: hidden;
  }

  .quiz-slide-viewport {
    position: relative;
    overflow: hidden;
  }

  .quiz-slide {
    padding: 2.5rem;
    opacity: 1;
    transform: translateX(0);
    transition: opacity 0.35s ease, transform 0.35s ease;
  }

  .quiz-slide.slide-out-left {
    opacity: 0;
    transform: translateX(-40px);
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    pointer-events: none;
  }

  .quiz-slide.slide-in-right {
    opacity: 0;
    transform: translateX(40px);
  }

  .question-title {
    font-family: var(--font-heading, sans-serif);
    font-size: clamp(1.25rem, 3vw, 1.7rem);
    font-weight: 700;
    margin-bottom: 2rem;
    color: var(--gray-800);
    text-align: center;
    line-height: 1.3;
  }

  .options-grid {
    display: grid;
    gap: 0.75rem;
  }

  .option-button {
    display: flex;
    align-items: center;
    gap: 1rem;
    background: white;
    border: 2px solid var(--gray-200);
    padding: 1.25rem 1.5rem;
    border-radius: 12px;
    cursor: pointer;
    transition: all 0.25s ease;
    font-size: 1.05rem;
    font-weight: 500;
