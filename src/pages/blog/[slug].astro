---
import { getCollection } from 'astro:content';
import { marked } from 'marked';
import ArticleLayout from '../../layouts/ArticleLayout.astro';
import FAQSchema from '../../components/FAQSchema.astro';
import RelatedArticles from '../../components/RelatedArticles.astro';
import BreadcrumbsSchema from '../../components/BreadcrumbsSchema.astro';
import ProductListSchema from '../../components/ProductListSchema.astro';
import AuthorBio from '../../components/AuthorBio.astro';
import ProductCards from '../../components/ProductCards.astro';
import TableOfContents from '../../components/TableOfContents.astro';
import PillarLink from '../../components/blog/PillarLink.astro';
import ArticleCTA from '../../components/blog/ArticleCTA.astro';
import BuyingGuideCard from '../../components/blog/BuyingGuideCard.astro';
import InlineOptIn from '../../components/blog/InlineOptIn.astro';

export async function getStaticPaths() {
  const blogEntries = await getCollection('blog');
  
  // Filtrer les articles par date et prod status
  const currentDate = new Date();
  return blogEntries
    .filter(entry => {
      // Ne pas générer si l'article a prod="N"
      if (entry.data.prod !== 'Y') return false;
      
      // Ne pas générer si la date de publication est dans le futur
      const publishDate = new Date(entry.data.datePublished);
      if (publishDate > currentDate) return false;
      
      // Sinon, générer la page
      return true;
    })
    .map(entry => ({
      params: { slug: entry.slug },
      props: { entry },
    }));
}

// Fonction utilitaire pour extraire l'ID YouTube d'une URL et gérer les shorts
function getYouTubeEmbedUrl(url: string) {
  // Gestion des shorts YouTube
  if (url.includes('/shorts/')) {
    const shortId = url.split('/shorts/')[1].split('?')[0];
    return `https://www.youtube.com/embed/${shortId}?si=QQvDZ8APhQNzMK1R`;
  }
  
  // Gestion des URLs YouTube standard
  const regExp = /^.*(youtu.be\/|v\/|u\/\w\/|embed\/|watch\?v=|&v=)([^#&?]*).*/;
  const match = url.match(regExp);
  const videoId = (match && match[2].length === 11) ? match[2] : null;
  
  return videoId ? `https://www.youtube.com/embed/${videoId}?si=QQvDZ8APhQNzMK1R` : null;
}

const { entry } = Astro.props;
const {
  title,
  description,
  ogImage,
  author,
  datePublished,
  dateModified,
  theme,
  schemaType = 'BlogPosting',
  introduction,
  songInfo,
  videos,
  conclusion,
  relatedLinks,
  faqs
} = entry.data;

const { Content, headings } = await entry.render();

// introduction/conclusion sont du Markdown inline (gras, liens) dans le frontmatter,
// il faut le convertir en HTML avant affichage (sinon `**gras**` et `[texte](lien)` s'affichent littéralement)
const introductionHtml = introduction ? marked.parseInline(introduction) : '';
const conclusionHtml = conclusion ? marked.parseInline(conclusion) : '';

// Déterminer si l'article est "long" (5+ headings H2/H3)
const showTOC = headings.filter(h => h.depth === 2 || h.depth === 3).length >= 5;

// Calcul du temps de lecture (estimation basée sur le contenu)
const wordCount = entry.body.split(/\s+/).length; // Nombre de mots
const readingTime = Math.ceil(wordCount / 250); // 250 mots/minute en moyenne

// Date de mise à jour visible : affichée seulement si elle diffère vraiment de
// la date de publication (une date de MàJ identique n'apporte aucun signal, et
// les moteurs IA privilégient les contenus dont la fraîcheur est explicite).
const isUpdated = Boolean(dateModified) &&
  new Date(dateModified).toDateString() !== new Date(datePublished).toDateString();
const formattedDateModified = isUpdated
  ? new Date(dateModified).toLocaleDateString('fr-FR', {
      year: 'numeric',
      month: 'long',
      day: 'numeric'
    })
  : '';

// Construction de l'URL complète pour schema.org
const canonicalURL = new URL(Astro.url.pathname, 'https://musique-facile.fr');

// Construction du schema.org
const schema = {
  "@context": "https://schema.org",
  "@type": schemaType,
  "headline": title,
  "description": description,
  "image": ogImage,
  "author": {
    "@type": "Person",
    "name": author
  },
}

// Mapping instrument → slug du guide d'achat correspondant (pour exclusion auto)
const buyingGuideSlugs: Record<string, string> = {
  guitare: 'quelle-guitare-folk-acheter-guide-comparatif-debutant',
  piano: 'quel-piano-numerique-acheter-guide-comparatif-debutant',
  ukulele: 'quel-ukulele-acheter-guide-comparatif-debutant',
};

// On affiche la carte « guide d'achat » seulement si :
// - L'article cible un instrument supporté
// - L'article n'est pas lui-même le guide d'achat (évite la boucle)
// - L'article n'a pas opt-out via frontmatter (hideBuyingGuide: true)
const showBuyingGuide = (
  entry.data.instrument &&
  ['guitare', 'piano', 'ukulele'].includes(entry.data.instrument) &&
  entry.slug !== buyingGuideSlugs[entry.data.instrument] &&
  entry.data.hideBuyingGuide !== true
);

// On affiche l'opt-in inline si l'article a au moins 3 H2 (sinon trop court)
// et que l'opt-out manuel n'est pas activé.
const h2Count = headings.filter(h => h.depth === 2).length;
const showInlineOptIn = h2Count >= 3 && entry.data.hideInlineOptIn !== true;

// Mapping instrument → ID du lead magnet PDF correspondant (cf catalogue dans merci-lead-magnet.astro)
// Override possible via frontmatter `leadMagnet` de l'article
const leadMagnetByInstrument: Record<string, string> = {
  guitare: 'guitare-5-accords-magiques',
  piano: 'piano-lire-les-notes',
  ukulele: 'ukulele-4-accords',
};
const leadMagnetId = entry.data.leadMagnet
  || (entry.data.instrument ? leadMagnetByInstrument[entry.data.instrument] : undefined);

// Construction des breadcrumbs dynamiques
const breadcrumbItems = [
  { name: "Accueil", url: "/" },
  { name: "Blog", url: "/blog/" }
];

// Ajouter un niveau intermédiaire si l'article a un instrument spécifique
if (entry.data.instrument && entry.data.instrument !== 'général') {
  const instrumentMap: Record<string, { name: string; url: string }> = {
    'guitare': { name: 'Guitare', url: '/blog/guitare/' },
    'piano': { name: 'Piano', url: '/blog/piano/' },
    'ukulele': { name: 'Ukulélé', url: '/blog/ukulele/' },
    'solfege': { name: 'Solfège', url: '/blog/solfege/' }
  };

  const instrumentData = instrumentMap[entry.data.instrument];
  if (instrumentData) {
    breadcrumbItems.push(instrumentData);
  }
}

// Ajouter le niveau article pilier si l'article est dans un silo
if (entry.data.siloSlug && !entry.data.pillar) {
  const allBlogPosts = await getCollection('blog');
  const pillarArticle = allBlogPosts.find(
    post => post.slug === entry.data.siloSlug && post.data.pillar === true
  );
  if (pillarArticle) {
    breadcrumbItems.push({
      name: pillarArticle.data.title,
      url: `/blog/${pillarArticle.slug}/`
    });
  }
}
---

<ArticleLayout
  title={title}
  description={description}
  ogImage={ogImage}
  author={author}
  datePublished={datePublished}
  dateModified={dateModified}
  url={canonicalURL.toString()}
  theme={theme}
  videos={videos}
  songInfo={songInfo}
  showAutoFaq={!(faqs && faqs.length > 0)}
>
  <article>
    <!-- Breadcrumbs -->
    <BreadcrumbsSchema
      items={breadcrumbItems}
      currentPage={title}
    />

    <!-- Schema.org ItemList/Product (guides d'achat avec produits comparés) -->
    {entry.data.products && entry.data.products.length > 0 && (
      <ProductListSchema
        products={entry.data.products}
        author={author}
        datePublished={datePublished}
        pageUrl={canonicalURL.toString()}
        instrument={entry.data.instrument}
      />
    )}

    <!-- Lien retour vers l'article pilier (silo SEO) -->
    {entry.data.siloSlug && !entry.data.pillar && (
      <PillarLink
        pillarSlug={entry.data.siloSlug}
        instrument={entry.data.instrument}
      />
    )}

    <section class="article-hero">
      <div class="article-hero-bg" style={`background-image: url(${ogImage})`}></div>
      <div class="article-hero-content">
        <div class="article-meta">
          {entry.data.number && (
            <span class="article-number" title={`Page ${entry.data.number}`}>
              {entry.data.number}
            </span>
          )}
          <time datetime={datePublished}>
            {new Date(datePublished).toLocaleDateString('fr-FR', {
              year: 'numeric',
              month: 'long',
              day: 'numeric'
            })}
          </time>
          {isUpdated && (
            <span class="article-updated">
              Mis à jour le <time datetime={dateModified}>{formattedDateModified}</time>
            </span>
          )}
          <span class="article-author">Par {author}</span>
          <span class="reading-time" title={`Environ ${readingTime} minute${readingTime > 1 ? 's' : ''} de lecture`}>
            📖 {readingTime} min
          </span>
        </div>
        <h1 class="article-title">{title}</h1>
        <p class="article-description">{description}</p>
      </div>
    </section>

    <!-- Navigation entre les pages (en haut) -->
    {entry.data.multi === 'Y' && (
      <nav class="article-navigation top-nav">
        {entry.data.prev && (
          <a href={`/blog/${entry.data.prev}/`} class="nav-link prev">
            <span class="nav-arrow">←</span>
            <span class="nav-text">Page précédente</span>
          </a>
        )}
        {entry.data.next && (
          <a href={`/blog/${entry.data.next}/`} class="nav-link next">
            <span class="nav-text">Page suivante</span>
            <span class="nav-arrow">→</span>
          </a>
        )}
      </nav>
    )}

  {songInfo && songInfo.inBook && (
  <div class="song-info">
    <div class="song-info-content">
      <div class="song-info-book">
        <img
          src="/images/livres/CARMF2838.webp"
          alt="40 chansons françaises et hits pop-rock - Livre de guitare avec tablatures et partitions"
          width="720"
          height="1024"
          loading="lazy"
          decoding="async"
        />
        <div class="book-details">
          {songInfo.bookPage && (
            <p class="book-message">Plonge directement dans ce morceau avec tous les conseils et la tablature complète à la page {songInfo.bookPage} de mon livre ! 🎸</p>
          )}
          <a href="https://c3po.link/QJCFDcrJfE" class="book-link" target="_blank" rel="noopener noreferrer">
            Découvre le livre maintenant !
          </a>
        </div>
      </div>
      <div class="song-details">
        {songInfo.tempo && (
          <div class="song-detail">
            <span class="detail-icon">🎵</span>
            <span class="detail-label">Tempo</span>
            <span class="detail-value">{songInfo.tempo} BPM</span>
          </div>
        )}
        {songInfo.chordCount && (
          <div class="song-detail">
            <span class="detail-icon">🎸</span>
            <span class="detail-label">Accords</span>
            <span class="detail-value">{songInfo.chordCount}</span>
          </div>
        )}
        {songInfo.key && (
          <div class="song-detail">
            <span class="detail-icon">🎹</span>
            <span class="detail-label">Tonalité</span>
            <span class="detail-value">{songInfo.key}</span>
          </div>
        )}
        {songInfo.difficulty && (
          <div class="song-detail">
            <span class="detail-icon">📊</span>
            <span class="detail-label">Difficulté</span>
            <span class="detail-value">{songInfo.difficulty}</span>
          </div>
        )}
      </div>
    </div>
  </div>
)}

    <div class={`article-content ${showTOC ? 'with-toc' : ''}`}>
      {showTOC && (
        <TableOfContents headings={headings} />
      )}

      <div class="article-main">
        <!-- Introduction -->
        <div class="article-intro" set:html={introductionHtml} />

<!-- Vidéos (si présentes) -->
{videos && videos.length > 0 && (
  <section class="video-section">
    <div class="video-grid">
      {videos.map(video => {
        const embedUrl = getYouTubeEmbedUrl(video.url);
        return embedUrl && (
          <div class="video-item">
            <div class="video-wrapper">
              <iframe
                width="560"
                height="315"
                src={embedUrl}
                title={video.title}
                frameborder="0"
                allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
                referrerpolicy="strict-origin-when-cross-origin"
                allowfullscreen
              ></iframe>
            </div>
          </div>
        );
      })}
    </div>
  </section>
      )}


      <!-- Contenu principal -->
      <div class="article-body">
        {showBuyingGuide && (
          <BuyingGuideCard instrument={entry.data.instrument as 'guitare' | 'piano' | 'ukulele'} />
        )}
        <Content />
        {entry.data.products && entry.data.products.length > 0 && (
          <ProductCards products={entry.data.products} instrument={entry.data.instrument} />
        )}
        {showInlineOptIn && (
          <InlineOptIn
            instrument={entry.data.instrument as any}
            source={`blog:${entry.slug}`}
            leadMagnet={leadMagnetId}
          />
        )}
      </div>

      {(showBuyingGuide || showInlineOptIn) && (
        <script>
          // Réorganise les blocs CTA dans l'article :
          //  - BuyingGuideCard juste après le 1er H2 (sweet spot CRO ~30%)
          //  - InlineOptIn après le H2 à ~65% du contenu (2e sweet spot CRO)
          // Fallback gracieux si pas assez de H2 : laisse la position rendue par Astro.
          (function relocateCTAs() {
            const run = () => {
              const body = document.querySelector('.article-body');
              if (!body) return;
              const h2s = Array.from(body.querySelectorAll(':scope > h2'));

              // Si le 1er H2 est le bloc "En bref" (answer-first), on le laisse tranquille
              // et on cible le H2 suivant pour ne pas intercaler la pub avant la réponse.
              const isEnBref = (h2) => /^en bref/i.test(h2.textContent.trim());
              const cardTargetIdx = h2s.length >= 1 && isEnBref(h2s[0]) ? 1 : 0;
              const cardTarget = h2s[cardTargetIdx];

              const card = body.querySelector(':scope > [data-buying-guide-card]');
              if (card && cardTarget) {
                cardTarget.insertAdjacentElement('afterend', card);
              }

              const optin = body.querySelector(':scope > [data-inline-optin]');
              if (optin && h2s.length >= 3) {
                const targetIdx = Math.floor(h2s.length * 0.65);
                const target = h2s[Math.min(targetIdx, h2s.length - 2)];
                if (target) target.insertAdjacentElement('afterend', optin);
              }
            };
            if (document.readyState === 'loading') {
              document.addEventListener('DOMContentLoaded', run);
            } else {
              run();
            }
          })();
        </script>
      )}

      <!-- Conclusion (seulement si présente et non vide) -->
      {conclusion && conclusion.trim() !== '' && (
        <section class="article-conclusion">
          <div class="conclusion-content">
            <h2>Conclusion</h2>
            <div set:html={conclusionHtml}></div>
          </div>
        </section>
      )}

      <!-- Encadré auteur visible (E-E-A-T DOM, complète le Schema Person) -->
      <AuthorBio author={author} />

      <!-- Navigation entre les pages -->
      {entry.data.multi === 'Y' && (
        <nav class="article-navigation bottom-nav">
          {entry.data.prev && (
            <a href={`/blog/${entry.data.prev}/`} class="nav-link prev">
              <span class="nav-arrow">←</span>
              <span class="nav-text">Page précédente</span>
            </a>
          )}
          {entry.data.next && (
            <a href={`/blog/${entry.data.next}/`} class="nav-link next">
              <span class="nav-text">Page suivante</span>
              <span class="nav-arrow">→</span>
            </a>
          )}
        </nav>
      )}

      <section class="course-buttons">
        <div class="container">
          <h2 class="section-title">Alors, prêt(e) à rejoindre l'aventure ?</h2>
          <div class="buttons-grid">
            <a href="/cours/cours-de-guitare/" class="course-button theme-guitar">
              <div class="button-background" style="background-image: url('/images/cours/cours-de-guitare.webp')"></div>
              <div class="button-content">
                <span class="button-icon">🎸</span>
                <div class="button-text-wrapper">
                  <span class="button-title">Cours de Guitare</span>
                  <span class="button-description">Apprenez la guitare pas à pas</span>
                </div>
                <span class="button-arrow">→</span>
              </div>
            </a>

            <a href="/cours/cours-de-piano/" class="course-button theme-piano">
              <div class="button-background" style="background-image: url('/images/cours/cours-de-piano.webp')"></div>
              <div class="button-content">
                <span class="button-icon">🎹</span>
                <div class="button-text-wrapper">
                  <span class="button-title">Cours de Piano</span>
                  <span class="button-description">Découvrez le piano facilement</span>
                </div>
                <span class="button-arrow">→</span>
              </div>
            </a>

            <a href="/cours/cours-de-ukulele/" class="course-button theme-ukulele">
              <div class="button-background" style="background-image: url('/images/cours/cours-de-ukulele.webp')"></div>
              <div class="button-content">
                <span class="button-icon">🏖️</span>
                <div class="button-text-wrapper">
                  <span class="button-title">Cours d'Ukulélé</span>
                  <span class="button-description">Initiez-vous à l'ukulélé</span>
                </div>
                <span class="button-arrow">→</span>
              </div>
            </a>

            <a href="/cours/cours-de-solfege/" class="course-button theme-solfege">
              <div class="button-background" style="background-image: url('/images/cours/cours-de-solfege.webp')"></div>
              <div class="button-content">
                <span class="button-icon">🎼</span>
                <div class="button-text-wrapper">
                  <span class="button-title">Cours de Solfège</span>
                  <span class="button-description">Maîtrisez la théorie musicale</span>
                </div>
                <span class="button-arrow">→</span>
              </div>
            </a>
          </div>
        </div>
      </section>

      </div> <!-- Fin .article-main -->
    </div> <!-- Fin .article-content -->

    <!-- CTA Formation — séparé du contenu éditorial (GEO) -->
    <ArticleCTA instrument={entry.data.instrument} />

    <!-- FAQ Section (si présente) - En pleine largeur -->
    {faqs && faqs.length > 0 && (
      <FAQSchema faqs={faqs} showVisual={true} />
    )}

    <!-- Section Articles Similaires (Intelligent) - En pleine largeur -->
    <RelatedArticles
      currentSlug={entry.slug}
      currentTags={entry.data.tags || []}
      currentInstrument={entry.data.instrument}
      currentLevel={entry.data.level}
      currentSiloSlug={entry.data.siloSlug}
      maxArticles={3}
    />
  </article>
</ArticleLayout>

<style>
  .article-number {
    background: var(--theme-current);
    color: white;
    padding: 0.3rem 0.8rem;
    border-radius: 50px;
    font-size: 0.9rem;
    font-weight: 600;
    cursor: help;
  }

  .reading-time {
    background: rgba(255, 255, 255, 0.2);
    padding: 0.3rem 0.8rem;
    border-radius: 50px;
    font-size: 0.9rem;
    font-weight: 600;
    cursor: help;
  }

  .article-updated {
    background: rgba(255, 255, 255, 0.2);
    padding: 0.3rem 0.8rem;
    border-radius: 50px;
    font-size: 0.9rem;
    font-weight: 600;
  }

  .song-info {
    position: relative;
    max-width: 800px;
    margin: 2rem auto;
    padding: 0 1.5rem;
  }

  .song-info-content {
    background: var(--color-dark);
    border-radius: var(--border-radius);
    padding: 2rem;
    border: 1px solid rgba(255, 255, 255, 0.1);
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .song-info-book {
    display: flex;
    gap: 2rem;
    align-items: center;
    padding-bottom: 2rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.2);
  }

  .song-info-book img {
    width: 120px;
    height: auto;
    border-radius: 8px;
    box-shadow: 0 4px 10px rgba(0, 0, 0, 0.3);
  }

  .book-details {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .book-message {
    color: white;
    font-size: 1.1rem;
    line-height: 1.5;
    margin: 0;
  }

  .book-link {
    display: inline-block;
    background: var(--theme-current);
    color: white;
    padding: 0.8rem 1.5rem;
    border-radius: var(--border-radius);
    text-decoration: none;
    font-size: 1rem;
    font-weight: 600;
    transition: all 0.3s ease;
    align-self: flex-start;
  }

  .book-link:hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 10px rgba(0, 0, 0, 0.2);
  }

  .song-details {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(120px, 1fr));
    gap: 1.5rem;
  }

  .song-detail {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 0.3rem;
  }

  .detail-icon {
    font-size: 1.5rem;
  }

  .detail-label {
    color: rgba(255, 255, 255, 0.6);
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .detail-value {
    color: white;
    font-weight: 600;
    font-size: 1.1rem;
  }

  @media (max-width: 768px) {
    .song-info-book {
      flex-direction: column;
      text-align: center;
      gap: 1.5rem;
    }

    .book-details {
      align-items: center;
    }

    .book-link {
      align-self: center;
    }

    .song-details {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .course-buttons {
    padding: 4rem 0;
    background: var(--bg-light);
  }

  .course-buttons .section-title {
    text-align: center;
    font-size: 2.5rem;
    margin-bottom: 3rem;
    color: var(--theme-current);
    background: linear-gradient(135deg, var(--theme-current) 0%, var(--theme-current-light) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    animation: fadeInUp 0.6s ease forwards;
  }

  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .buttons-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.5rem;
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .course-button {
    position: relative;
    height: 200px;
    border-radius: var(--border-radius);
    overflow: hidden;
    text-decoration: none;
    color: white;
    transition: all 0.3s ease;
  }

  .button-background {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center;
    transition: all 0.5s ease;
  }

  .button-content {
    position: relative;
    z-index: 1;
    height: 100%;
    padding: 1.5rem;
    background: linear-gradient(
