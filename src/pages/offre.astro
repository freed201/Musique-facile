// Schema FAQ pour SEO
const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Comment accéder aux cours après l'achat ?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Vous recevez vos accès par email dans les 24h. Connectez-vous sur notre plateforme et commencez immédiatement vos formations. L'accès est illimité et à vie."
      }
    },
    {
      "@type": "Question",
      "name": "Quand vais-je recevoir mon cadeau physique ?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Les cadeaux (sourdine guitare, sangle ukulélé ou clips piano) sont expédiés sous 15 jours ouvrés en France métropolitaine par La Poste. Les formations vidéo sont disponibles immédiatement après l'achat."
      }
    },
    {
      "@type": "Question",
      "name": "Les packs sont-ils adaptés aux grands débutants ?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Oui, parfaitement ! Nos packs sont spécialement conçus pour les grands débutants. Vous apprenez étape par étape, sans aucun prérequis. Plus de 80 000 élèves ont déjà appris avec succès grâce à notre méthode progressive."
      }
    },
    {
      "@type": "Question",
      "name": "Puis-je vraiment me faire rembourser si je ne suis pas satisfait ?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Oui, absolument. Vous avez 15 jours pour tester la formation. Si vous n'êtes pas satisfait pour quelque raison que ce soit, nous vous remboursons intégralement, sans poser de question."
      }
    },
    {
      "@type": "Question",
      "name": "Quelle est la différence entre les packs Guitare, Piano et Ukulélé ?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Chaque pack contient 2 à 3 formations complètes spécifiques à l'instrument choisi. Le pack Guitare (267€ de valeur) inclut Débutant + Odyssée + Shuffle. Le pack Ukulélé (187€ de valeur) inclut Débutant + Rythmique + Shuffle. Les packs Piano (378€ ou 307€ de valeur) incluent soit formations débutant soit formations avancées. Tous les packs sont à 99€ et incluent un cadeau physique."
      }
    },
    {
      "@type": "Question",
      "name": "Y a-t-il un support si j'ai des questions pendant ma formation ?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Oui, un support par email est inclus dans tous nos packs. Contactez-nous à contact@musique-facile.fr, nous répondons sous 24h pour vous aider dans votre apprentissage."
      }
    }
