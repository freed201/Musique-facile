    const tabPanels = document.querySelectorAll('.tab-panel');
    
    tabButtons.forEach((button, index) => {
      button.addEventListener('click', () => {
        // Remove active from all
        tabButtons.forEach(btn => {
          btn.classList.remove('active');
          btn.setAttribute('aria-selected', 'false');
        });
        tabPanels.forEach(panel => panel.classList.remove('active'));
        
        // Add active to clicked
        button.classList.add('active');
        button.setAttribute('aria-selected', 'true');
        tabPanels[index].classList.add('active');
      });
    });
    
    // Keyboard navigation
    tabButtons.forEach((button, index) => {
      button.addEventListener('keydown', (e) => {
        if (e.key === 'ArrowLeft' || e.key === 'ArrowRight') {
          e.preventDefault();
          const nextIndex = e.key === 'ArrowLeft' 
            ? (index - 1 + tabButtons.length) % tabButtons.length
            : (index + 1) % tabButtons.length;
          tabButtons[nextIndex].click();
          tabButtons[nextIndex].focus();
        }
      });
    });
    
    // Prefetch purchase links on scroll
    let prefetched = false;
    window.addEventListener('scroll', () => {
      if (!prefetched && window.scrollY > 500) {
        const links = [
          'https://ecole.musique-facile.fr/pack-guitare-cadeau',
          'https://ecole.musique-facile.fr/pack-ukulele',
          'https://ecole.musique-facile.fr/pack-piano-debutant-cadeau',
          'https://ecole.musique-facile.fr/pack-avance-piano-cadeau'
        ];
        
        links.forEach(href => {
          const link = document.createElement('link');
          link.rel = 'prefetch';
          link.href = href;
          document.head.appendChild(link);
        });
        
        prefetched = true;
      }
    });
  });
</script>
