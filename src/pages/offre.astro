---

<Layout
  title={title}
  description={description}
  keywords={keywords}
  ogImage={ogImage}
  canonicalUrl={canonicalURL}
  robots="index, follow, max-snippet:-1, max-image-preview:large"
>
  <Fragment slot="head">
    <!-- Schema.org - Enrichis pour SEO -->
    <script type="application/ld+json" set:html={JSON.stringify(guitarPackSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(ukulelePackSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(pianoBeginnerSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(pianoAdvancedSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

    <!-- Critical CSS inline -->
    <style is:inline>
      .hero { min-height: 100vh; display: flex; align-items: center; }
      .cta-primary { background: var(--brand); color: white; padding: 1rem 2rem; border-radius: var(--radius-md); }
    </style>
  </Fragment>

    <header class="header-simple">
      <div class="container">
        <a href="/" class="logo">
          <img src="/logo.webp" alt="Musique Facile" width="120" height="40" />
        </a>
        <a href="#acheter" class="header-cta">Je profite de l'offre</a>
      </div>
    </header>

    <main>
      <!-- Hero Section -->
      <section class="hero" id="hero">
        <div class="hero-background">
          <picture>
            <source srcset="/images/hero-instruments.webp" type="image/webp" />
            <img 
              src="/images/hero-instruments.webp" 
              alt="Guitare et ukulélé avec formations Musique Facile"
              width="1200"
              height="800"
              loading="eager"
            />
          </picture>
          <div class="hero-overlay"></div>
        </div>
        
        <div class="container">
          <div class="hero-content">
            <div class="hero-badges">
              <span class="urgency-badge">🔥 Offre limitée</span>
              <span class="gift-badge">🎁 Cadeau physique offert</span>
            </div>
            
            <h1>Formation Musique en Ligne à 99€ : Apprenez la Guitare, le Piano ou l'Ukulélé</h1>
            
            <div class="price-hero">
              <div class="price-comparison">
                <span class="old-price">Valeur jusqu'à 378€</span>
                <span class="arrow">→</span>
                <span class="new-price">99€</span>
              </div>
              <div class="savings-badge">
                <span class="savings-text">Économisez jusqu'à 279€</span>
                <span class="percentage">-74%</span>
              </div>
            </div>
            
            <p class="hero-subtitle">
              Pack complet <strong>Guitare</strong>, <strong>Ukulélé</strong> ou <strong>Piano</strong> + <strong>cadeau physique offert</strong>
            </p>
            
            <ul class="hero-benefits">
              <li>✅ Parcours guidé pas à pas pour débutants</li>
              <li>✅ Vos premiers morceaux en quelques semaines</li>
              <li>✅ Accès illimité – apprenez à votre rythme</li>
              <li>✅ Cadeau utile expédié chez vous (France)</li>
            </ul>
            
            <a href="#acheter" class="cta-primary hero-cta" data-analytics="hero-cta">
              Je découvre les packs – 99€
              <span class="cta-arrow">↓</span>
            </a>
            
            <p class="guarantee-text">
              ✅ Garantie 15 jours – remboursé si vous n'êtes pas satisfait
            </p>
          </div>
        </div>
      </section>

      <!-- Preuve Sociale -->
      <section class="social-proof" id="social-proof">
        <div class="container">
          <h2>Rejoignez plus de 80 000 élèves formés</h2>
          
          <div class="social-stats">
            <div class="stat-item">
              <div class="stat-number">80k+</div>
              <div class="stat-label">élèves formés</div>
            </div>
            <div class="stat-item">
              <div class="stat-number">15M+</div>
              <div class="stat-label">vues YouTube</div>
            </div>
            <div class="stat-item">
              <div class="stat-number">106k+</div>
              <div class="stat-label">followers TikTok</div>
            </div>
          </div>
          
          <div class="social-logos">
            <svg class="social-logo" viewBox="0 0 24 24" width="32" height="32">
              <path fill="currentColor" d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
            </svg>
            <svg class="social-logo" viewBox="0 0 24 24" width="32" height="32">
              <path fill="currentColor" d="M12.525.02c1.31-.02 2.61-.01 3.91-.02.08 1.53.63 3.09 1.75 4.17 1.12 1.11 2.7 1.62 4.24 1.79v4.03c-1.44-.05-2.89-.35-4.2-.97-.57-.26-1.1-.59-1.62-.93-.01 2.92.01 5.84-.02 8.75-.08 1.4-.54 2.79-1.35 3.94-1.31 1.92-3.58 3.17-5.91 3.21-1.43.08-2.86-.31-4.08-1.03-2.02-1.19-3.44-3.37-3.65-5.71-.02-.5-.03-1-.01-1.49.18-1.9 1.12-3.72 2.58-4.96 1.66-1.44 3.98-2.13 6.15-1.72.02 1.48-.04 2.96-.04 4.44-.99-.32-2.15-.23-3.02.37-.63.41-1.11 1.04-1.36 1.75-.21.51-.15 1.07-.14 1.61.24 1.64 1.82 3.02 3.5 2.87 1.12-.01 2.19-.66 2.77-1.61.19-.33.4-.67.41-1.06.1-1.79.06-3.57.07-5.36.01-4.03-.01-8.05.02-12.07z"/>
            </svg>
          </div>
        </div>
      </section>

      <!-- Sélecteur d'instrument -->
      <section class="parcours" id="parcours">
        <div class="container">
          <h2>Choisissez votre aventure musicale</h2>
          <p class="section-subtitle">Deux parcours complets conçus pour vous faire progresser rapidement</p>
          
          <div class="tabs-container">
            <div class="tabs-nav" role="tablist">
              <button class="tab-button active" role="tab" aria-selected="true" aria-controls="guitare-panel" id="guitare-tab">
                🎸 Pack Guitare
              </button>
              <button class="tab-button" role="tab" aria-selected="false" aria-controls="ukulele-panel" id="ukulele-tab">
                🏝️ Pack Ukulélé
              </button>
              <button class="tab-button" role="tab" aria-selected="false" aria-controls="piano-debutant-panel" id="piano-debutant-tab">
                🎹 Piano Débutant
              </button>
              <button class="tab-button" role="tab" aria-selected="false" aria-controls="piano-avance-panel" id="piano-avance-tab">
                🎼 Piano Avancé
              </button>
            </div>
            
            <div class="tab-panels">
              <div class="tab-panel active" role="tabpanel" id="guitare-panel" aria-labelledby="guitare-tab">
                <div class="pack-content">
                  <div class="pack-header">
                    <h3>🎸 Votre parcours guitare complet</h3>
                    <p>Trois formations progressives pour maîtriser la guitare de A à Z</p>
                  </div>
                  
                  <div class="pack-items">
                    <div class="pack-item">
                      <h4>📚 Pack Débutant</h4>
                      <p>Apprenez les bases : accords, rythmiques, premières chansons</p>
                      <span class="value-badge">89€</span>
                    </div>
                    <div class="pack-item featured">
                      <h4>🚀 Guitare Odyssée</h4>
                      <p>Un an pour progresser et maîtriser votre instrument</p>
                      <span class="value-badge">149€</span>
                    </div>
                    <div class="pack-item">
                      <h4>🎵 Pack Shuffle</h4>
                      <p>Maîtrisez les rythmes shuffle et blues</p>
                      <span class="value-badge">29€</span>
                    </div>
                  </div>
                  
                  <div class="total-value">
                    <span class="total-text">Valeur totale :</span>
                    <span class="total-price">267€</span>
                    <span class="arrow">→</span>
                    <span class="promo-price">99€</span>
                  </div>
                </div>
              </div>
              
              <div class="tab-panel" role="tabpanel" id="ukulele-panel" aria-labelledby="ukulele-tab">
                <div class="pack-content">
                  <div class="pack-header">
                    <h3>🏝️ Votre parcours ukulélé complet</h3>
                    <p>Trois formations progressives pour maîtriser l'ukulélé facilement</p>
                  </div>
                  
                  <div class="pack-items">
                    <div class="pack-item">
                      <h4>📚 Pack Débutant</h4>
                      <p>Découvrez l'ukulélé de façon simple et amusante</p>
                      <span class="value-badge">79€</span>
                    </div>
                    <div class="pack-item featured">
                      <h4>🎶 Pack Rythmique</h4>
                      <p>Maîtrisez les rythmiques et variations</p>
                      <span class="value-badge">79€</span>
                    </div>
                    <div class="pack-item">
                      <h4>🎵 Pack Shuffle</h4>
                      <p>Apprenez les rythmes shuffle à l'ukulélé</p>
                      <span class="value-badge">29€</span>
                    </div>
                  </div>
                  
                  <div class="total-value">
                    <span class="total-text">Valeur totale :</span>
                    <span class="total-price">187€</span>
                    <span class="arrow">→</span>
                    <span class="promo-price">99€</span>
                  </div>
                </div>
              </div>

              <!-- Panel Piano Débutant -->
              <div class="tab-panel" role="tabpanel" id="piano-debutant-panel" aria-labelledby="piano-debutant-tab">
                <div class="pack-content">
                  <div class="pack-header">
                    <h3>🎹 Votre parcours piano débutant complet</h3>
                    <p>Deux formations progressives pour débuter le piano facilement</p>
                  </div>
                  
                  <div class="pack-items">
                    <div class="pack-item featured">
                      <h4>📚 Pack Débutant Piano</h4>
                      <p>Formation complète pour débuter le piano : bases du clavier, accords, rythmes et premiers morceaux</p>
                      <span class="value-badge">299€</span>
                    </div>
