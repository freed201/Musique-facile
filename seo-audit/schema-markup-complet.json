    "/faq": {
      "url": "https://musique-facile.fr/faq",
      "schemas": [
        {
          "@context": "https://schema.org",
          "@graph": [
            {
              "@type": "FAQPage",
              "name": "FAQ — Questions fréquentes sur les cours Musique Facile",
              "url": "https://musique-facile.fr/faq",
              "mainEntity": [
                { "@type": "Question", "name": "Quelle est la différence entre un cours en ligne et un cours en présentiel ?", "acceptedAnswer": { "@type": "Answer", "text": "Les cours en ligne Musique Facile vous permettent d'apprendre à votre rythme, où vous voulez et quand vous voulez. Contrairement aux cours en présentiel, vous pouvez revoir chaque vidéo autant de fois que nécessaire, sans contrainte d'horaire ni de déplacement. Le contenu est structuré de façon progressive et pensé pour l'apprentissage autonome." } },
                { "@type": "Question", "name": "Quel niveau musical faut-il avoir pour commencer ?", "acceptedAnswer": { "@type": "Answer", "text": "Aucun niveau n'est requis pour nos cours débutants. Que vous n'ayez jamais touché un instrument de votre vie ou que vous souhaitiez passer au niveau supérieur, il existe un cours adapté à votre situation." } },
                { "@type": "Question", "name": "Quels instruments peut-on apprendre sur Musique Facile ?", "acceptedAnswer": { "@type": "Answer", "text": "Musique Facile propose des cours pour la guitare (acoustique et électrique), le piano, l'ukulélé et le solfège. Chaque discipline dispose de parcours allant du niveau débutant absolu au niveau avancé, créés et animés par Fred Fieffé." } },
                { "@type": "Question", "name": "Combien coûtent les cours et y a-t-il des abonnements ?", "acceptedAnswer": { "@type": "Answer", "text": "Les cours sont disponibles à l'achat unique, sans abonnement mensuel. Les prix varient selon le cours : de 79 euros pour les cours courts à 299 euros pour les packs complets. Une fois acheté, vous avez accès au cours à vie." } },
                { "@type": "Question", "name": "Y a-t-il une garantie de remboursement ?", "acceptedAnswer": { "@type": "Answer", "text": "Oui, tous les cours sont garantis satisfait ou remboursé pendant 15 jours. Si vous n'êtes pas entièrement satisfait dans les 15 jours suivant votre achat, vous pouvez demander un remboursement intégral, sans condition ni justification." } },
                { "@type": "Question", "name": "Les cours sont-ils accessibles à vie ?", "acceptedAnswer": { "@type": "Answer", "text": "Oui, tous les cours achetés sont accessibles à vie. Vous pouvez les suivre à votre rythme, les mettre en pause et y revenir quand vous le souhaitez, depuis n'importe quel appareil (ordinateur, tablette, smartphone)." } },
                { "@type": "Question", "name": "Combien de temps faut-il pour apprendre un instrument ?", "acceptedAnswer": { "@type": "Answer", "text": "Avec une pratique régulière de 15 à 30 minutes par jour, vous pouvez jouer vos premières chansons en quelques semaines. Atteindre un bon niveau intermédiaire demande généralement 6 à 12 mois de pratique régulière." } },
                { "@type": "Question", "name": "Est-il possible d'apprendre plusieurs instruments en même temps ?", "acceptedAnswer": { "@type": "Answer", "text": "Il est possible d'apprendre plusieurs instruments, mais il est généralement conseillé de se concentrer sur un instrument principal au départ. Une fois que vous avez acquis de bonnes bases (6 mois à 1 an), vous pouvez commencer à explorer un second instrument." } }
              ]
            },
            {
              "@type": "BreadcrumbList",
              "itemListElement": [
                { "@type": "ListItem", "position": 1, "name": "Accueil", "item": "https://musique-facile.fr/" },
                { "@type": "ListItem", "position": 2, "name": "FAQ", "item": "https://musique-facile.fr/faq" }
              ]
            }
          ]
        }
      ]
    },
