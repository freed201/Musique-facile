            },
            {
              "@type": "BreadcrumbList",
              "itemListElement": [
                { "@type": "ListItem", "position": 1, "name": "Accueil", "item": "https://musique-facile.fr/" },
                { "@type": "ListItem", "position": 2, "name": "Cours", "item": "https://musique-facile.fr/cours" },
                { "@type": "ListItem", "position": 3, "name": "Guitare", "item": "https://musique-facile.fr/cours/cours-de-guitare" }
              ]
            },
            {
              "@type": "FAQPage",
              "mainEntity": [
                {
                  "@type": "Question",
                  "name": "Peut-on vraiment apprendre la guitare en ligne ?",
                  "acceptedAnswer": { "@type": "Answer", "text": "Oui, tout à fait. Apprendre la guitare en ligne est parfaitement efficace, à condition de choisir une méthode structurée avec un bon professeur. Chez Musique Facile, plus de 80 000 élèves ont appris la guitare en ligne avec Fred Fieffé depuis 2015." }
                },
                {
                  "@type": "Question",
                  "name": "Quel niveau faut-il pour s'inscrire aux cours de guitare ?",
                  "acceptedAnswer": { "@type": "Answer", "text": "Il existe des cours pour tous les niveaux : débutant absolu, intermédiaire et avancé. Les cours débutants ne nécessitent aucune connaissance préalable en musique ou en guitare." }
                },
                {
                  "@type": "Question",
                  "name": "Quelle guitare acheter pour débuter ?",
                  "acceptedAnswer": { "@type": "Answer", "text": "Pour débuter, une guitare acoustique ou électrique d'entrée de gamme de marque sérieuse (Yamaha, Fender, Epiphone) entre 100 et 200 euros suffit largement. L'important est d'avoir un instrument bien réglé pour ne pas souffrir des doigts et rester motivé." }
                },
                {
                  "@type": "Question",
                  "name": "Combien de temps faut-il pour jouer ses premières chansons à la guitare ?",
                  "acceptedAnswer": { "@type": "Answer", "text": "Avec 15 à 30 minutes de pratique régulière par jour, la plupart des débutants jouent leurs premières chansons complètes en 4 à 8 semaines." }
                },
                {
                  "@type": "Question",
