            {
              "@type": "FAQPage",
              "mainEntity": [
                {
                  "@type": "Question",
                  "name": "Faut-il savoir jouer de la guitare avant de commencer ce cours ?",
                  "acceptedAnswer": { "@type": "Answer", "text": "Non, aucun prérequis n'est nécessaire. Ce cours de guitare est spécialement conçu pour les débutants absolus. Vous apprendrez tout depuis le début : tenir la guitare, placer les doigts, jouer les premiers accords et enchaîner vos premières chansons." }
                },
                {
                  "@type": "Question",
                  "name": "Combien de temps par jour faut-il pratiquer pour progresser rapidement ?",
                  "acceptedAnswer": { "@type": "Answer", "text": "15 à 30 minutes de pratique quotidienne suffisent pour progresser efficacement. La régularité est beaucoup plus importante que la durée des séances. Avec ce rythme, vous serez capable de jouer vos premiers morceaux en quelques semaines." }
                },
                {
                  "@type": "Question",
                  "name": "Y a-t-il une garantie de remboursement ?",
                  "acceptedAnswer": { "@type": "Answer", "text": "Oui, une garantie satisfait ou remboursé de 15 jours est incluse avec ce cours. Si vous n'êtes pas entièrement satisfait dans les 15 jours suivant votre achat, vous serez remboursé intégralement, sans question ni justification." }
                }
              ]
            }
          ]
